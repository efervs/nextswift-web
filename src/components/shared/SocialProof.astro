---
/**
 * SocialProof — 3 capas reutilizables de prueba social.
 * Fase 17 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 *
 * Variants:
 *  - 'agregada'    -> cifra agregada masiva sobre el fold (texto + métricas). Insertable en Hero o bajo Hero.
 *  - 'logos'       -> banda de 5 logos hiper-locales en tiles uniformes a color (hover = lift + scale).
 *  - 'testimonios' -> 3-4 bloques de testimonios contextuales por objeción anclada.
 *                     SOLO autorizados (NO inventar — CLAUDE.md §10 + DH-NEW-01).
 *  - 'all'         -> las 3 capas en orden agregada → logos → testimonios.
 *
 * Fuente de datos:
 *  - testimonios.ts (DH-NEW-01: solo autorizado=true se publica)
 *  - memory/project_casos_prueba_social.md (logos validados 2026-05-14)
 */
import { testimoniosPublicables } from '../../data/testimonios';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

interface Logo {
  src: string;
  alt: string;
}

interface Props {
  variant: 'agregada' | 'logos' | 'testimonios' | 'all';
  /**
   * Cifra agregada custom para variant='agregada' (default = home).
   * Por dolor en landings se puede sobreescribir.
   */
  metricaAgregada?: string;
  contexto?: string;
  logos?: Logo[];
  /** Para 'agregada' y 'logos': si va sobre Hero (transparente) o bajo Hero (alt). */
  tone?: 'surface' | 'alt' | 'transparent';
}

const {
  variant,
  metricaAgregada = '+42% margen delivery (neto) · $0 → $300k/mes en arranque · 4.4 → 4.6★ en menos de 2 meses',
  contexto = 'en 3 de 5 restaurantes acompañados por NextSwift en Monterrey',
  logos = [
    { src: '/images/logos/pangas.webp', alt: 'Pangas Sabores del Mar — cliente NextSwift' },
    { src: '/images/logos/temaky.webp', alt: 'Temaky Sushi — cliente NextSwift' },
    { src: '/images/logos/oita-fresh.webp', alt: 'Oita Fresh — cliente NextSwift' },
    { src: '/images/logos/sr-boneless.webp', alt: 'Sr. Boneless — cliente NextSwift' },
    { src: '/images/logos/hare-krishna.webp', alt: 'Hare Krishna — cliente NextSwift' },
  ],
  tone = 'alt',
} = Astro.props;

const showAgregada = variant === 'agregada' || variant === 'all';
const showLogos = variant === 'logos' || variant === 'all';
const showTestimonios = variant === 'testimonios' || variant === 'all';

const testimonios = showTestimonios ? testimoniosPublicables() : [];

/**
 * Iniciales para el placeholder del avatar cuando NO hay foto autorizada.
 * Toma las primeras letras de las 2 primeras palabras significativas del nombre
 * (descarta conectores). No inventa una cara — solo ancla visual neutral.
 */
function getInitials(name: string): string {
  const stop = new Set(['de', 'del', 'la', 'las', 'los', 'el', 'en', 'y', 'a']);
  const words = name
    .replace(/[,·.]/g, ' ')
    .split(/\s+/)
    .filter((w) => w.length > 0 && !stop.has(w.toLowerCase()));
  const initials = words.slice(0, 2).map((w) => w.charAt(0).toUpperCase());
  return initials.join('') || '—';
}
---

{showAgregada && (
  tone === 'transparent' ? (
    <aside class="sp-agregada sp-agregada--inline" aria-label="Métrica agregada de clientes">
      <p class="sp-agregada__metric">
        <strong class="metric-md">{metricaAgregada}</strong>
        <span class="sp-agregada__context">— {contexto}</span>
      </p>
    </aside>
  ) : (
    <Section spacing="sm" tone={tone === 'surface' ? 'surface' : 'alt'} as="div">
      <aside class="sp-agregada" aria-label="Métrica agregada de clientes">
        <p class="sp-agregada__metric">
          <strong class="metric-md">{metricaAgregada}</strong>
          <span class="sp-agregada__context">— {contexto}</span>
        </p>
      </aside>
    </Section>
  )
)}

{showLogos && (
  <Section spacing="sm" tone={tone === 'surface' ? 'surface' : 'alt'} as="div">
    <aside class="sp-logos-band" aria-label="Restaurantes representativos atendidos por NextSwift">
      <p class="sp-logos-band__lede">Acompañando restaurantes en Monterrey:</p>
      <ul class="sp-logos-band__list" role="list">
        {logos.map((l, i) => (
          <li class="sp-logos-band__item">
            <img
              src={l.src}
              alt={l.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              width="480"
              height="240"
              class="sp-logos-band__img"
            />
          </li>
        ))}
      </ul>
    </aside>
  </Section>
)}

{showTestimonios && testimonios.length > 0 && (
  <Section spacing="md" tone="surface" as="section">
    <Eyebrow tone="neutral">PRUEBA DOCUMENTADA · UNA OBJECIÓN POR TESTIMONIO</Eyebrow>
    <ul class="sp-testimonios" role="list">
      {testimonios.map((t) => (
        <li class="sp-testimonio">
          <p class="sp-testimonio__objecion">{t.objecionLabel}</p>

          <header class="sp-testimonio__head">
            <span class="sp-testimonio__avatar">
              {t.avatar ? (
                <img
                  src={t.avatar}
                  alt={`Foto de ${t.cliente}`}
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  class="sp-testimonio__avatar-img"
                />
              ) : (
                <span class="sp-testimonio__avatar-fallback" aria-hidden="true">
                  {getInitials(t.cliente)}
                </span>
              )}
            </span>
            <span class="sp-testimonio__id">
              <span class="sp-testimonio__cliente">{t.cliente}</span>
              <span class="sp-testimonio__restaurante">{t.restaurante}</span>
              {t.roleLabel && <span class="sp-testimonio__role">{t.roleLabel}</span>}
            </span>
          </header>

          {t.cita && (
            <blockquote class="sp-testimonio__cita">
              <p>“{t.cita}”</p>
            </blockquote>
          )}

          {t.contexto && <p class="sp-testimonio__contexto">{t.contexto}</p>}

          <p class="sp-testimonio__metrica"><strong>{t.metrica}</strong></p>
        </li>
      ))}
    </ul>
  </Section>
)}

<style>
  /* ----- Capa 1: cifra agregada ----------------------------------------- */
  .sp-agregada {
    text-align: center;
    max-width: 64rem;
    margin-inline: auto;
  }

  .sp-agregada--inline {
    padding: var(--space-3) 0 0;
  }

  .sp-agregada__metric {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: var(--fs-body);
    line-height: var(--line-snug);
    color: var(--color-text);
  }

  /* .sp-agregada__metric strong — tipografía gobernada por .metric-md (utilities.css / M15).
     font-family, font-weight, color y font-size eliminados para que la util-class global
     gane especificidad (los estilos scoped de Astro con data-astro-* ganarían si se
     repitieran las mismas props). Se conservan solo las props de layout. */
  .sp-agregada__metric strong {
    display: block;
    margin-bottom: var(--space-2);
  }

  .sp-agregada__context {
    color: var(--color-text-muted);
    font-size: 0.95em;
  }

  /* ----- Capa 2: banda de logos ----------------------------------------- */
  .sp-logos-band {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
  }

  .sp-logos-band__lede {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .sp-logos-band__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    /* mobile-first: 2 columnas → la banda envuelve en filas, sin scroll horizontal */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
    align-items: center;
    justify-items: center;
    max-width: var(--content-max);
    width: 100%;
  }

  @media (min-width: 520px) {
    .sp-logos-band__list { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (min-width: 768px) {
    .sp-logos-band__list {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }

  /* Cada logo en un tile uniforme 2:1. El fondo nativo de la marca (negro, verde,
     crema, blanco) queda enmarcado como card para que los logos claros no se fundan
     con la sección y los oscuros lean a color, sin grayscale. */
  .sp-logos-band__item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 6rem;            /* 2:1 → altura <= 3rem en mobile */
    aspect-ratio: 2 / 1;
    overflow: hidden;
    border-radius: var(--radius-3, 0.75rem);
    border: 1px solid var(--color-border, rgba(0, 51, 102, 0.12));
    box-shadow: var(--shadow-1);
    background: var(--color-surface, #fff);
    transition: transform var(--dur-2, 180ms) var(--ease-out, ease-out),
                box-shadow var(--dur-2, 180ms) var(--ease-out, ease-out);
  }

  @media (min-width: 768px) {
    .sp-logos-band__item { max-width: 8rem; }  /* 2:1 → altura <= 4rem en desktop */
  }

  .sp-logos-band__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;          /* el tile ya es 2:1 → llena la card sin distorsión */
    opacity: 0.85;
    transition: opacity var(--dur-2, 180ms) var(--ease-out, ease-out);
  }

  .sp-logos-band__item:hover,
  .sp-logos-band__item:focus-within {
    transform: scale(1.05);
    box-shadow: var(--shadow-2, 0 8px 24px rgba(0, 51, 102, 0.14));
  }

  .sp-logos-band__item:hover .sp-logos-band__img,
  .sp-logos-band__item:focus-within .sp-logos-band__img {
    opacity: 1;
  }

  /* ----- Capa 3: testimonios contextuales ------------------------------- */
  .sp-testimonios {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .sp-testimonios {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  .sp-testimonio {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, rgba(0, 51, 102, 0.12));
    border-left: 4px solid var(--color-accent, #3EEAF3);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-1);
  }

  /* Objeción anclada como eyebrow, arriba de todo */
  .sp-testimonio__objecion {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: var(--fs-eyebrow);
    color: var(--color-primary-dark);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    font-weight: 600;
    line-height: var(--line-snug);
  }

  /* Header humano: avatar (foto o iniciales) + nombre/restaurante/role */
  .sp-testimonio__head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .sp-testimonio__avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-pill);
    overflow: hidden;
    display: block;
  }

  .sp-testimonio__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sp-testimonio__avatar-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: var(--color-accent-ink);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .sp-testimonio__id {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .sp-testimonio__cliente {
    font-family: var(--font-subheading);
    font-weight: 600;
    color: var(--color-dark-1);
    font-size: 0.9375rem;
    line-height: var(--line-snug);
  }

  .sp-testimonio__restaurante {
    font-family: var(--font-subheading);
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: var(--line-snug);
  }

  .sp-testimonio__role {
    align-self: flex-start;
    margin-top: 0.25rem;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-subheading);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary-dark);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: var(--radius-pill);
  }

  /* Quote grande, voz heading italic */
  .sp-testimonio__cita {
    margin: 0;
    border-left: 0;
    padding: 0;
  }

  .sp-testimonio__cita p {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.0625rem, 0.95rem + 0.6vw, 1.25rem);
    line-height: var(--line-snug, 1.3);
    color: var(--color-dark-1);
    font-style: italic;
  }

  .sp-testimonio__contexto {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: var(--line-base, 1.55);
  }

  /* Métrica en bloque destacado, anclada al pie de la card */
  .sp-testimonio__metrica {
    margin: auto 0 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: var(--line-snug);
    color: var(--color-text);
    background: rgba(62, 234, 243, 0.12);
    border-radius: var(--radius-3);
    padding: var(--space-3) var(--space-4);
  }

  .sp-testimonio__metrica strong {
    color: var(--color-dark-1);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-logos-band__item,
    .sp-logos-band__img {
      transition: none;
    }
    .sp-logos-band__item:hover,
    .sp-logos-band__item:focus-within {
      transform: none;
    }
  }
</style>
