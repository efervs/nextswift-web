---
/**
 * SocialProof — 3 capas reutilizables de prueba social.
 * Fase 17 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 *
 * Variants:
 *  - 'agregada'    -> cifra agregada masiva sobre el fold (texto + métricas). Insertable en Hero o bajo Hero.
 *  - 'logos'       -> banda de 5 logos hiper-locales en escala de grises (hover = color).
 *  - 'testimonios' -> 3-4 bloques de testimonios contextuales por objeción anclada.
 *                     SOLO autorizados (NO inventar — CLAUDE.md §10 + DH-NEW-01).
 *  - 'all'         -> las 3 capas en orden agregada → logos → testimonios.
 *
 * Fuente de datos:
 *  - testimonios.ts (DH-NEW-01: solo autorizado=true se publica)
 *  - memory/project_casos_prueba_social.md (logos validados 2026-05-14)
 */
import { testimoniosPublicables } from '../../data/testimonios';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

interface Logo {
  src: string;
  alt: string;
}

interface Props {
  variant: 'agregada' | 'logos' | 'testimonios' | 'all';
  /**
   * Cifra agregada custom para variant='agregada' (default = home).
   * Por dolor en landings se puede sobreescribir.
   */
  metricaAgregada?: string;
  contexto?: string;
  logos?: Logo[];
  /** Para 'agregada' y 'logos': si va sobre Hero (transparente) o bajo Hero (alt). */
  tone?: 'surface' | 'alt' | 'transparent';
}

const {
  variant,
  metricaAgregada = '+42% margen delivery (neto) · $0 → $300k/mes en arranque · 4.4 → 4.6★ en menos de 2 meses',
  contexto = 'en 3 de 5 restaurantes acompañados por NextSwift en Monterrey',
  logos = [
    { src: '/images/logos/pangas.webp', alt: 'Pangas Sabores del Mar — cliente NextSwift' },
    { src: '/images/logos/temaky.webp', alt: 'Temaky Sushi — cliente NextSwift' },
    { src: '/images/logos/oita-fresh.webp', alt: 'Oita Fresh — cliente NextSwift' },
    { src: '/images/logos/sr-boneless.webp', alt: 'Sr. Boneless — cliente NextSwift' },
    { src: '/images/logos/hare-krishna.webp', alt: 'Hare Krishna — cliente NextSwift' },
  ],
  tone = 'alt',
} = Astro.props;

const showAgregada = variant === 'agregada' || variant === 'all';
const showLogos = variant === 'logos' || variant === 'all';
const showTestimonios = variant === 'testimonios' || variant === 'all';

const testimonios = showTestimonios ? testimoniosPublicables() : [];
---

{showAgregada && (
  tone === 'transparent' ? (
    <aside class="sp-agregada sp-agregada--inline" aria-label="Métrica agregada de clientes">
      <p class="sp-agregada__metric">
        <strong>{metricaAgregada}</strong>
        <span class="sp-agregada__context">— {contexto}</span>
      </p>
    </aside>
  ) : (
    <Section spacing="sm" tone={tone === 'surface' ? 'surface' : 'alt'} as="div">
      <aside class="sp-agregada" aria-label="Métrica agregada de clientes">
        <p class="sp-agregada__metric">
          <strong>{metricaAgregada}</strong>
          <span class="sp-agregada__context">— {contexto}</span>
        </p>
      </aside>
    </Section>
  )
)}

{showLogos && (
  <Section spacing="sm" tone={tone === 'surface' ? 'surface' : 'alt'} as="div">
    <aside class="sp-logos-band" aria-label="Restaurantes representativos atendidos por NextSwift">
      <p class="sp-logos-band__lede">Acompañando restaurantes en Monterrey:</p>
      <ul class="sp-logos-band__list" role="list">
        {logos.map((l, i) => (
          <li class="sp-logos-band__item">
            <img
              src={l.src}
              alt={l.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              width="120"
              height="60"
              class="sp-logos-band__img"
            />
          </li>
        ))}
      </ul>
    </aside>
  </Section>
)}

{showTestimonios && testimonios.length > 0 && (
  <Section spacing="md" tone="surface" as="section">
    <Eyebrow tone="neutral">PRUEBA DOCUMENTADA · UNA OBJECIÓN POR TESTIMONIO</Eyebrow>
    <ul class="sp-testimonios" role="list">
      {testimonios.map((t) => (
        <li class="sp-testimonio">
          <p class="sp-testimonio__objecion">{t.objecionLabel}</p>
          {t.cita && (
            <blockquote class="sp-testimonio__cita">
              <p>“{t.cita}”</p>
            </blockquote>
          )}
          <p class="sp-testimonio__contexto">{t.contexto}</p>
          <p class="sp-testimonio__metrica"><strong>{t.metrica}</strong></p>
          <footer class="sp-testimonio__autor">
            <span class="sp-testimonio__cliente">{t.cliente}</span>
            <span class="sp-testimonio__restaurante">{t.restaurante}</span>
          </footer>
        </li>
      ))}
    </ul>
  </Section>
)}

<style>
  /* ----- Capa 1: cifra agregada ----------------------------------------- */
  .sp-agregada {
    text-align: center;
    max-width: 64rem;
    margin-inline: auto;
  }

  .sp-agregada--inline {
    padding: var(--space-3) 0 0;
  }

  .sp-agregada__metric {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: var(--fs-body);
    line-height: var(--line-snug);
    color: var(--color-text);
  }

  .sp-agregada__metric strong {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-dark-1);
    font-size: clamp(1rem, 0.92rem + 0.4vw, 1.25rem);
    display: block;
    margin-bottom: var(--space-2);
  }

  .sp-agregada__context {
    color: var(--color-text-muted);
    font-size: 0.95em;
  }

  /* ----- Capa 2: banda de logos ----------------------------------------- */
  .sp-logos-band {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
  }

  .sp-logos-band__lede {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .sp-logos-band__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: var(--space-5);
    align-items: center;
    justify-items: center;
    max-width: var(--content-max);
    width: 100%;
  }

  .sp-logos-band__item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3rem;
  }

  .sp-logos-band__img {
    max-width: 100%;
    max-height: 3rem;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.75;
    transition: filter var(--dur-2, 180ms) var(--ease-out, ease-out),
                opacity var(--dur-2, 180ms) var(--ease-out, ease-out);
  }

  .sp-logos-band__item:hover .sp-logos-band__img,
  .sp-logos-band__item:focus-within .sp-logos-band__img {
    filter: grayscale(0);
    opacity: 1;
  }

  /* ----- Capa 3: testimonios contextuales ------------------------------- */
  .sp-testimonios {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .sp-testimonios {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  .sp-testimonio {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, rgba(0, 51, 102, 0.12));
    border-left: 4px solid var(--color-accent, #003366);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-1);
  }

  .sp-testimonio__objecion {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: 0.8125rem;
    color: var(--color-accent, #003366);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-weight: 600;
  }

  .sp-testimonio__cita {
    margin: 0;
    border-left: 0;
    padding: 0;
  }

  .sp-testimonio__cita p {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.0625rem, 0.95rem + 0.6vw, 1.25rem);
    line-height: var(--line-snug, 1.3);
    color: var(--color-dark-1);
    font-style: italic;
  }

  .sp-testimonio__contexto,
  .sp-testimonio__metrica {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: var(--line-base, 1.55);
  }

  .sp-testimonio__metrica strong {
    color: var(--color-dark-1);
  }

  .sp-testimonio__autor {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border, rgba(0, 51, 102, 0.08));
    font-family: var(--font-subheading);
  }

  .sp-testimonio__cliente {
    font-weight: 600;
    color: var(--color-dark-1);
    font-size: 0.9375rem;
  }

  .sp-testimonio__restaurante {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-logos-band__img {
      transition: none;
    }
  }
</style>
