---
/**
 * FAQ — accordion semántico con Schema.org FAQPage.
 * Fase 18 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 *
 * Variants:
 *  - 'global'  -> FAQ de home (8-10 preguntas, scope='home').
 *  - 'landing' -> FAQ por dolor (3-5 preguntas, scope=<painSlug>). Requiere `painSlug`.
 *
 * Regla anti-duplicación: cada PÁGINA emite UNA SOLA instancia de Schema.org FAQPage.
 * NO incluir <FAQ variant="global"/> Y <FAQ variant="landing" .../> en la misma página.
 *
 * A11y: <details>/<summary> nativos. NO usa JS pesado. Foco visible vía CSS tokens.
 */
import { faqsByScope, type FaqScope, type FaqEntry } from '../../data/faq';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Heading from '../ui/Heading.astro';

interface Props {
  variant: 'global' | 'landing';
  painSlug?: Exclude<FaqScope, 'home'>;
  tone?: 'surface' | 'alt';
  /** Si true, el primer item arranca abierto (orientación al usuario). */
  defaultOpenFirst?: boolean;
}

const { variant, painSlug, tone = 'alt', defaultOpenFirst = true } = Astro.props;

if (variant === 'landing' && !painSlug) {
  throw new Error('FAQ: variant="landing" requiere prop painSlug.');
}

const scope: FaqScope = variant === 'global' ? 'home' : (painSlug as FaqScope);
const entries = faqsByScope(scope);

// M11 — agrupación por bloque temático (`categoria`).
// Se preserva el orden de primera aparición de cada categoría; las entries
// internas ya vienen ordenadas por `orden` desde faqsByScope().
// Default: si ninguna entry trae `categoria`, todo cae en un solo grupo.
const DEFAULT_CATEGORIA = 'Preguntas frecuentes';
const grupos: { categoria: string; items: FaqEntry[] }[] = [];
for (const item of entries) {
  const cat = item.categoria ?? DEFAULT_CATEGORIA;
  let grupo = grupos.find((g) => g.categoria === cat);
  if (!grupo) {
    grupo = { categoria: cat, items: [] };
    grupos.push(grupo);
  }
  grupo.items.push(item);
}
// Solo mostramos subheaders cuando hay agrupación real (2+ bloques);
// con un grupo único el subheader duplicaría el título de sección.
const mostrarSubheaders = grupos.length > 1;
// Primera entry global -> arranca abierta si defaultOpenFirst.
const firstId = entries[0]?.id;

const eyebrow = variant === 'global'
  ? 'PREGUNTAS DE DUEÑOS QUE YA NOS PREGUNTARON ESTO'
  : 'FAQ ESPECÍFICA AL DOLOR';

const titulo = variant === 'global' ? 'Preguntas frecuentes' : 'FAQ — preguntas específicas';

const headingLevel: 'h2' | 'h3' = variant === 'global' ? 'h2' : 'h3';

// Schema.org FAQPage — UNA emisión por página.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: entries.map((e) => ({
    '@type': 'Question',
    name: e.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: e.respuesta,
    },
  })),
};
---

{entries.length > 0 && (
  <Section spacing="md" tone={tone} as="section" id="faq">
    <Eyebrow tone="neutral">{eyebrow}</Eyebrow>
    <Heading as={headingLevel} size={headingLevel === 'h2' ? 'h2' : 'h3'}>
      {titulo}
    </Heading>

    <div class="faq-list" aria-label="Preguntas frecuentes">
      {grupos.map((grupo) => (
        <div class="faq-group">
          {mostrarSubheaders && (
            <h3 class="faq-group__title">{grupo.categoria}</h3>
          )}
          {grupo.items.map((item) => (
            <details
              class="faq-item"
              name={variant === 'global' ? 'faq-global' : `faq-${painSlug}`}
              open={defaultOpenFirst && item.id === firstId}
            >
              <summary class="faq-item__q">
                <svg
                  class="faq-item__icon"
                  width="18"
                  height="18"
                  viewBox="0 0 18 18"
                  aria-hidden="true"
                  focusable="false"
                >
                  <line x1="9" y1="3.25" x2="9" y2="14.75" />
                  <line x1="3.25" y1="9" x2="14.75" y2="9" />
                </svg>
                <span>{item.pregunta}</span>
              </summary>
              <div class="faq-item__a">
                <p>{item.respuesta}</p>
              </div>
            </details>
          ))}
        </div>
      ))}
    </div>

    {/* JSON-LD FAQPage — Rich Results elegible. */}
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(faqSchema)}
    />
  </Section>
)}

<style>
  .faq-list {
    display: grid;
    gap: var(--space-6); /* aire entre bloques temáticos */
    margin: var(--space-4) 0 0;
    padding: 0;
  }

  /* Bloque temático (M11): subheader + sus items */
  .faq-group {
    display: grid;
    gap: var(--space-2);
  }

  .faq-group__title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    font-family: var(--font-subheading);
    font-size: var(--fs-eyebrow);
    font-weight: 700;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .faq-group__title::before {
    content: '';
    width: 1.25rem;
    height: 2px;
    background: var(--color-accent, #3eeaf3);
    border-radius: 1px;
    flex-shrink: 0;
  }

  .faq-item {
    border: 1px solid var(--color-border, rgba(0, 51, 102, 0.12));
    border-left: 4px solid transparent; /* reserva el ancho del acento -> sin salto al abrir */
    border-radius: var(--radius-2);
    background: var(--color-bg, #fff);
    transition:
      border-color var(--dur-2, 200ms) var(--ease-out, ease-out),
      background-color var(--dur-2, 200ms) var(--ease-out, ease-out);
  }

  .faq-item:hover,
  .faq-item:focus-within {
    border-color: var(--color-accent-on-light); /* M5: 4.89:1 sobre blanco, WCAG 1.4.11 */
  }

  /* Item activo: borde-acento visible + fondo teal tenue */
  .faq-item[open] {
    border-left-color: var(--color-accent-on-light); /* M5: era #3EEAF3 (1.47:1), ahora #147D83 (4.89:1) */
    background: rgba(20, 125, 131, 0.05);
  }

  .faq-item__q {
    cursor: pointer;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-subheading);
    font-weight: 600;
    color: var(--color-dark-1, #003366);
    list-style: none;
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: var(--space-3);
    align-items: center;
    min-height: 44px; /* WCAG target táctil */
  }

  .faq-item__q::-webkit-details-marker {
    display: none;
  }

  .faq-item__q:focus-visible {
    outline: 2px solid var(--color-accent, #3eeaf3);
    outline-offset: 2px;
    border-radius: var(--radius-2);
  }

  /* Ícono +/- como SVG: rota 45deg al expandir (+ -> x), color on-light */
  .faq-item__icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-accent-on-light); /* M5: era #3EEAF3 (1.47:1 sobre blanco), ahora #147D83 (4.89:1) */
    transition: transform var(--dur-2, 200ms) var(--ease-out, ease-out);
  }

  .faq-item__icon line {
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(45deg);
  }

  .faq-item[open] .faq-item__q {
    border-bottom: 1px solid var(--color-border, rgba(0, 51, 102, 0.08));
  }

  .faq-item__a {
    padding: var(--space-3) var(--space-4) var(--space-4);
  }

  .faq-item__a p {
    margin: 0;
    font-family: var(--font-body);
    color: var(--color-text, #003366);
    line-height: var(--line-base, 1.6);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item,
    .faq-item__icon {
      transition: none;
    }
  }
</style>
