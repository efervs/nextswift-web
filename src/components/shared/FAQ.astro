---
/**
 * FAQ — accordion semántico con Schema.org FAQPage.
 * Fase 18 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 *
 * Variants:
 *  - 'global'  -> FAQ de home (8-10 preguntas, scope='home').
 *  - 'landing' -> FAQ por dolor (3-5 preguntas, scope=<painSlug>). Requiere `painSlug`.
 *
 * Regla anti-duplicación: cada PÁGINA emite UNA SOLA instancia de Schema.org FAQPage.
 * NO incluir <FAQ variant="global"/> Y <FAQ variant="landing" .../> en la misma página.
 *
 * A11y: <details>/<summary> nativos. NO usa JS pesado. Foco visible vía CSS tokens.
 */
import { faqsByScope, type FaqScope, type FaqEntry } from '../../data/faq';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Heading from '../ui/Heading.astro';

interface Props {
  variant: 'global' | 'landing';
  painSlug?: Exclude<FaqScope, 'home'>;
  tone?: 'surface' | 'alt';
  /** Si true, el primer item arranca abierto (orientación al usuario). */
  defaultOpenFirst?: boolean;
}

const { variant, painSlug, tone = 'alt', defaultOpenFirst = true } = Astro.props;

if (variant === 'landing' && !painSlug) {
  throw new Error('FAQ: variant="landing" requiere prop painSlug.');
}

const scope: FaqScope = variant === 'global' ? 'home' : (painSlug as FaqScope);
const entries = faqsByScope(scope);

// M11 — agrupación por bloque temático (`categoria`).
// Se preserva el orden de primera aparición de cada categoría; las entries
// internas ya vienen ordenadas por `orden` desde faqsByScope().
// Default: si ninguna entry trae `categoria`, todo cae en un solo grupo.
const DEFAULT_CATEGORIA = 'Preguntas frecuentes';
const grupos: { categoria: string; items: FaqEntry[] }[] = [];
for (const item of entries) {
  const cat = item.categoria ?? DEFAULT_CATEGORIA;
  let grupo = grupos.find((g) => g.categoria === cat);
  if (!grupo) {
    grupo = { categoria: cat, items: [] };
    grupos.push(grupo);
  }
  grupo.items.push(item);
}
// Solo mostramos subheaders cuando hay agrupación real (2+ bloques);
// con un grupo único el subheader duplicaría el título de sección.
const mostrarSubheaders = grupos.length > 1;
// Primera entry global -> arranca abierta si defaultOpenFirst.
const firstId = entries[0]?.id;

const eyebrow = variant === 'global'
  ? 'PREGUNTAS DE DUEÑOS QUE YA NOS PREGUNTARON ESTO'
  : 'FAQ ESPECÍFICA AL DOLOR';

const titulo = variant === 'global' ? 'Preguntas frecuentes' : 'FAQ — preguntas específicas';

const headingLevel: 'h2' | 'h3' = variant === 'global' ? 'h2' : 'h3';

// Schema.org FAQPage — UNA emisión por página.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: entries.map((e) => ({
    '@type': 'Question',
    name: e.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: e.respuesta,
    },
  })),
};
---

{entries.length > 0 && (
  <Section spacing="md" tone={tone} as="section" id="faq">
    <Eyebrow tone="neutral">{eyebrow}</Eyebrow>
    <Heading as={headingLevel} size={headingLevel === 'h2' ? 'h2' : 'h3'}>
      {titulo}
    </Heading>

    <div class="faq-list" aria-label="Preguntas frecuentes">
      {grupos.map((grupo) => (
        <div class="faq-group">
          {mostrarSubheaders && (
            <h3 class="faq-group__title">{grupo.categoria}</h3>
          )}
          {grupo.items.map((item) => (
            <details
              class="faq-item"
              name={variant === 'global' ? 'faq-global' : `faq-${painSlug}`}
              open={defaultOpenFirst && item.id === firstId}
            >
              <summary class="faq-item__q">
                <span>{item.pregunta}</span>
                <svg
                  class="faq-item__icon"
                  width="20"
                  height="20"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                  focusable="false"
                >
                  <line x1="10" y1="3.5" x2="10" y2="16.5" />
                  <line x1="3.5" y1="10" x2="16.5" y2="10" />
                </svg>
              </summary>
              <div class="faq-item__a">
                <p>{item.respuesta}</p>
              </div>
            </details>
          ))}
        </div>
      ))}
    </div>

    {/* JSON-LD FAQPage — Rich Results elegible. */}
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(faqSchema)}
    />
  </Section>
)}

<style>
  /* =======================================================================
     V4-14 — FAQ con sistema v4 (Lane CIERRE). Anti card-soup: el FAQ deja de
     ser una pila de cards bordeadas (border + radio + fondo teal + hover) y
     pasa a una LISTA PLANA dividida por reglas hairline cálidas. La elevación
     está RESERVADA a oferta + garantía → aquí NO hay sombra (--elevation-flat).
     Tipografía del sistema: preguntas en --font-display (Fraunces), respuestas
     en --font-body (Inter). Ritmo por doctrina V4-13 (--rhythm-*). Estados de
     acordeón claros por COLOR + ícono (no por caja). A11y intacta: <details>/
     <summary> nativos, foco global 3px de global.css.
     ======================================================================= */

  .faq-list {
    display: grid;
    gap: var(--rhythm-within); /* respiro tier-2 entre bloques temáticos */
    margin: var(--rhythm-within) 0 0;
    padding: 0;
  }

  /* Bloque temático (M11): subheader + sus items como lista continua */
  .faq-group {
    display: grid;
    gap: 0; /* sin gap: las filas se separan con hairline, no con aire */
  }

  .faq-group__title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-2);
    font-family: var(--font-body); /* Inter: label institucional (no es una pregunta) */
    font-size: var(--fs-eyebrow);
    font-weight: 700;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .faq-group__title::before {
    content: '';
    width: 1.25rem;
    height: 2px;
    background: var(--color-action); /* deep teal v4 (6.16:1) — hilo con el acento del home */
    border-radius: 1px;
    flex-shrink: 0;
  }

  /* Fila plana: SIN caja. La divide una regla hairline cálida (doctrina tier-3).
     Cada item lleva su divisor superior; el borde de cierre del grupo lo pone el
     último item. No hay border-radius, fondo ni sombra: la jerarquía es el ritmo. */
  .faq-item {
    border-top: var(--rhythm-hairline);
  }

  .faq-group .faq-item:last-child {
    border-bottom: var(--rhythm-hairline);
  }

  .faq-item__q {
    cursor: pointer;
    padding: var(--space-4) var(--space-2);
    font-family: var(--font-display); /* Fraunces: la pregunta como voz editorial del sistema */
    font-size: var(--fs-h3);
    font-weight: 600;
    line-height: var(--line-snug);
    letter-spacing: var(--tracking-heading);
    color: var(--color-text);
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 20px;
    gap: var(--space-4);
    align-items: baseline;
    min-height: var(--touch-target); /* WCAG 2.5.5 target táctil */
    text-wrap: balance;
    transition: color var(--dur-2, 200ms) var(--ease-out, ease-out);
  }

  .faq-item__q::-webkit-details-marker {
    display: none;
  }

  /* Estado hover/foco: la pregunta vira a deep teal (señal clara, sin caja). */
  .faq-item:hover .faq-item__q,
  .faq-item:focus-within .faq-item__q {
    color: var(--color-action); /* 6.16:1 sobre blanco (AA) */
  }

  /* Estado activo: pregunta abierta se ancla en deep teal → contraste claro con
     las cerradas (navy). El ícono + -> x refuerza el estado. */
  .faq-item[open] > .faq-item__q {
    color: var(--color-action);
  }

  /* M14 (TA-08): el foco visible lo hereda del global 3px de global.css
     (:focus-visible) sin override — mismo patrón que el resto del sitio. */

  /* Ícono +/- como SVG (a la derecha de la pregunta): rota 45deg al expandir
     (+ -> x). Deep teal v4 (--color-action). */
  .faq-item__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    align-self: center;
    color: var(--color-action); /* 6.16:1 sobre blanco (AA) */
    transition: transform var(--dur-2, 200ms) var(--ease-out, ease-out);
  }

  .faq-item__icon line {
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(45deg);
  }

  /* Respuesta: Inter, sangrada al ancho de lectura. Respiro inferior tier-2 sin
     recurrir a caja ni fondo. */
  .faq-item__a {
    padding: 0 var(--space-2) var(--space-5);
  }

  .faq-item__a p {
    margin: 0;
    max-width: var(--content-narrow); /* medida de lectura cómoda */
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--color-text-muted); /* jerarquía: respuesta más suave que la pregunta */
    line-height: var(--line-base, 1.6);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item__q,
    .faq-item__icon {
      transition: none;
    }
  }
</style>
