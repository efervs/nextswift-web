---
/**
 * Stakes — Costo de no actuar (P6 / F6 plan).
 *
 * Bloque oscuro, cuantificado, tono Ciancio (operador-estratega): cifras frías,
 * cero alarmismo, cero FOMO artificial, cero countdowns. Cierra reencuadrando el
 * precio del servicio como gasto de protección, no discrecional.
 *
 * Fuentes verificadas:
 * - Brief §4 (Ecuación de Valor Hormozi por dolor — rangos por margen y plazos).
 * - Brief §5 (dualidad operador-estratega Ciancio — voz del reframe final).
 * - Auditoría §3.6 (banda compacta legacy — esta versión la cuantifica).
 * - Mercado público (comisiones delivery MX: Rappi/UberEats/DiDi 23-35%).
 *
 * Cifras: rangos con asunción declarada. Sin invenciones puntuales.
 * Iconografía (M18): `lock-open` se sirve desde el sistema central <Icon/>
 * (era un duplicado byte-a-byte del ícono canónico). Las otras 3 fugas conservan
 * su SVG bespoke por diseño: son variantes DIRECCIONALES (calculator-down /
 * delivery-out / person-cycle) con flecha de fuga, fuera del set plano de Icon.
 */
import Eyebrow from '../ui/Eyebrow.astro';
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Icon from '../ui/Icon.astro';

type Variant = 'home' | 'landing';
type Dolor =
  | 'utilidad'
  | 'autonomia'
  | 'ventas-delivery'
  | 'personal'
  | 'metricas-control'
  | 'crecimiento-controlado';

type IconKey = 'calculator-down' | 'delivery-out' | 'person-cycle' | 'lock-open';

interface Props {
  variant?: Variant;
  painSlug?: Dolor;
  class?: string;
}

const { variant = 'home', painSlug, class: className = '' } = Astro.props;

interface Leak {
  id: string;
  icon: IconKey;
  metric: string;
  title: string;
  body: string;
  doloresPrimario: Dolor;
  doloresSecundarios?: Dolor[];
}

const leaks: Leak[] = [
  {
    id: 'promociones-sin-roi',
    icon: 'calculator-down',
    metric: '$60k-$120k',
    title: 'Promociones sin ROI medido',
    body:
      'Una promo 2x1 o 30% off sin costeo previo, 4 semanas en un negocio de $2M MXN/mes, regala $60k-$120k de utilidad neta. Sin medir ticket pre/post promo, la decisión se repite cada mes.',
    doloresPrimario: 'utilidad',
    doloresSecundarios: ['metricas-control', 'ventas-delivery'],
  },
  {
    id: 'comisiones-delivery',
    icon: 'delivery-out',
    metric: '25-35%',
    title: 'Comisiones de marketplaces sin canal directo',
    body:
      'Rappi, UberEats y DiDi cobran 25-35% por orden. Si el delivery vale 20-25% de un negocio de $2M MXN/mes, la comisión se lleva $100k-$175k mensuales que nunca tocan tu utilidad.',
    doloresPrimario: 'ventas-delivery',
    doloresSecundarios: ['utilidad'],
  },
  {
    id: 'rotacion-personal',
    icon: 'person-cycle',
    metric: '0.5-1.5×',
    title: 'Rotación de personal sin estructura',
    body:
      'Cada salida cuesta 0.5-1.5 sueldos del puesto entre reclutamiento, formación y errores iniciales. Equipo de 15 con 30-50% rotación anual: $30k-$100k al año en costo directo.',
    doloresPrimario: 'personal',
    doloresSecundarios: ['utilidad', 'autonomia'],
  },
  {
    id: 'dependencia-dueno',
    icon: 'lock-open',
    metric: '0 días',
    title: 'Dependencia operativa del dueño',
    body:
      'Si no puedes ausentarte 72 horas sin que caiga ticket, merma o satisfacción, el negocio no es un activo: es un empleo caro. Sin SOPs ni encargado, el techo es tu propia agenda.',
    doloresPrimario: 'autonomia',
    doloresSecundarios: ['crecimiento-controlado'],
  },
];

const metricUnitMap: Record<string, string> = {
  'promociones-sin-roi': 'MXN/mes',
  'comisiones-delivery': 'ticket bruto',
  'rotacion-personal': 'sueldos por reemplazo',
  'dependencia-dueno': 'fuera sin caída',
};

function selectLeaks(): Leak[] {
  if (variant === 'home' || !painSlug) return leaks;

  const primario = leaks.filter((l) => l.doloresPrimario === painSlug);
  const secundarios = leaks.filter(
    (l) => l.doloresPrimario !== painSlug && (l.doloresSecundarios ?? []).includes(painSlug),
  );

  const ordenados = [...primario, ...secundarios].slice(0, 3);
  return ordenados.length > 0 ? ordenados : leaks.slice(0, 3);
}

const visibleLeaks = selectLeaks();

const headlineHome = 'Cada mes sin sistema, entre 3% y 7% de margen se va por la coladera.';
const headlineLanding = painSlug === 'utilidad'
  ? 'El margen no se pierde de golpe. Se pierde 3-7% cada mes hasta que el año cierra en rojo.'
  : 'Mientras no se ordena la operación, cada mes se va una fracción del margen que ya no vuelve.';
const headline = variant === 'landing' ? headlineLanding : headlineHome;

const subhead =
  variant === 'home'
    ? 'Asunción: restaurante de 50-150 comensales facturando $2M MXN/mes. Cifras de mercado y rangos del diagnóstico inicial. Sin retórica.'
    : 'Mismas cifras del diagnóstico inicial NextSwift. Cada fuga es un cálculo aplicable a tu propio P&L — no una promesa genérica.';

const reframe =
  'Una consultoría que recupera 3-7 puntos de margen en 90 días sobre tu base actual paga su propio costo dentro del primer trimestre. No es gasto discrecional — es gasto de protección sobre la utilidad que ya estás generando.';
---

<section
  class:list={['stakes', `stakes--${variant}`, painSlug ? `stakes--pain-${painSlug}` : '', className]}
  aria-labelledby="stakes-heading"
>
  <div class="stakes__inner">
    <header class="stakes__header">
      <Eyebrow tone="on-dark">El costo de no actuar</Eyebrow>
      <Heading as="h2" tone="on-dark" id="stakes-heading">{headline}</Heading>
      <Body size="lead" tone="on-dark" class="stakes__subhead">{subhead}</Body>
    </header>

    <ul class="stakes__list" role="list">
      {visibleLeaks.map((leak) => (
        <li class="leak" data-dolor={leak.doloresPrimario}>
          <span class="leak__icon" aria-hidden="true">
            {leak.icon === 'calculator-down' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="2" width="14" height="16" rx="2" />
                <rect x="8" y="5" width="8" height="3" />
                <circle cx="9" cy="12" r="0.6" fill="currentColor" />
                <circle cx="12" cy="12" r="0.6" fill="currentColor" />
                <circle cx="15" cy="12" r="0.6" fill="currentColor" />
                <circle cx="9" cy="15" r="0.6" fill="currentColor" />
                <circle cx="12" cy="15" r="0.6" fill="currentColor" />
                <circle cx="15" cy="15" r="0.6" fill="currentColor" />
                <path d="M12 19v3" />
                <path d="M9 21l3 3 3-3" />
              </svg>
            )}
            {leak.icon === 'delivery-out' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="6" cy="17" r="3" />
                <circle cx="17" cy="17" r="3" />
                <path d="M6 17h6l3-5h-4" />
                <path d="M14 7h2.5l1.5 5" />
                <path d="M19 9l3-3" />
                <path d="M22 6h-3M22 6v3" />
              </svg>
            )}
            {leak.icon === 'person-cycle' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="3" />
                <path d="M7 21v-1a4 4 0 0 1 4-4h2a4 4 0 0 1 4 4v1" />
                <path d="M3 13a9 9 0 0 1 3-6.7" />
                <path d="M3 9v4h4" />
                <path d="M21 11a9 9 0 0 1-3 6.7" />
                <path d="M21 15v-4h-4" />
              </svg>
            )}
            {leak.icon === 'lock-open' && (
              <Icon name="lock-open" size={32} />
            )}
          </span>
          <div class="leak__head">
            <span class="leak__metric metric-xl" aria-hidden="true">{leak.metric}</span>
            <span class="leak__unit">{metricUnitMap[leak.id]}</span>
          </div>
          <h3 class="leak__title">{leak.title}</h3>
          <p class="leak__body">
            <span class="visually-hidden">Costo estimado: {leak.metric} {metricUnitMap[leak.id]}. </span>
            {leak.body}
          </p>
        </li>
      ))}
    </ul>

    <aside class="stakes__reframe" aria-label="Reencuadre">
      <p>{reframe}</p>
    </aside>
  </div>
</section>

<style>
  .stakes {
    width: 100%;
    background: var(--color-dark-1);
    color: var(--color-text-on-dark);
    position: relative;
    isolation: isolate;
  }

  .stakes::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at top right, rgba(62, 234, 243, 0.08), transparent 55%),
      linear-gradient(180deg, var(--color-dark-1) 0%, var(--color-dark-4) 100%);
    z-index: -1;
  }

  .stakes__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-10) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .stakes--landing .stakes__inner {
    padding-block: var(--space-9);
    gap: var(--space-7);
  }

  /* ----- Header ----------------------------------------------------------- */
  .stakes__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 56rem;
  }

  .stakes__subhead {
    color: var(--color-soft);
  }

  /* ----- Lista de fugas --------------------------------------------------- */
  .stakes__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 720px) {
    .stakes__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .leak {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas:
      'icon head'
      'icon title'
      'body body';
    column-gap: var(--space-4);
    row-gap: var(--space-2);
    align-items: start;
    padding: var(--space-6);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-4);
    transition: border-color var(--dur-3) var(--ease-out),
                background var(--dur-3) var(--ease-out),
                transform var(--dur-3) var(--ease-out);
  }

  .leak:hover {
    border-color: rgba(62, 234, 243, 0.45);
    border-left-color: var(--color-accent);
    background: rgba(255, 255, 255, 0.06);
  }

  .leak__icon {
    grid-area: icon;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .leak__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .leak__head {
    grid-area: head;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  /* .leak__metric — tipografía gobernada por .metric-xl (utilities.css / M15).
     Sin props aquí para que la util-class global gane especificidad
     (el atributo data-astro-* de Astro elevaría la especificidad scoped
     sobre cualquier selector global si se repitieran las mismas props). */

  .leak__unit {
    font-family: var(--font-body);
    font-size: var(--fs-small, 0.8125rem);
    line-height: 1.2;
    color: var(--color-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .leak__title {
    grid-area: title;
    font-family: var(--font-heading);
    font-size: var(--fs-h3);
    font-weight: 600;
    line-height: var(--line-snug);
    color: var(--color-text-on-dark);
    margin: var(--space-3) 0 0 0;
    text-wrap: balance;
  }

  .leak__body {
    grid-area: body;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-soft);
    margin: var(--space-2) 0 0 0;
    max-width: 56ch;
  }

  /* ----- Reframe final (Ciancio: gasto de protección) -------------------- */
  .stakes__reframe {
    background: var(--color-dark-2);
    border-top: 3px solid var(--color-accent);
    border-radius: var(--radius-4);
    padding: var(--space-7) var(--space-6);
    text-align: center;
  }

  .stakes__reframe p {
    font-family: var(--font-subheading);
    font-size: var(--fs-lead);
    line-height: var(--line-snug);
    color: var(--color-text-on-dark);
    margin: 0 auto;
    max-width: 60ch;
    text-wrap: pretty;
  }

  /* ----- A11y helper ----------------------------------------------------- */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ----- Mobile (<480px): mantiene jerarquía con métrica grande --------- */
  @media (max-width: 480px) {
    .leak {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        'icon head'
        'title title'
        'body body';
      column-gap: var(--space-3);
      padding: var(--space-5);
    }

    /* .leak__metric mobile override eliminado — .metric-xl ya escala por vw (M15). */

    .leak__title {
      margin-top: var(--space-2);
    }

    .stakes__reframe {
      padding: var(--space-6) var(--space-4);
    }
  }
</style>
