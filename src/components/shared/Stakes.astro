---
/**
 * Stakes — Costo de no actuar (P6 / F6 plan).
 *
 * Bloque oscuro, cuantificado, tono Ciancio (operador-estratega): cifras frías,
 * cero alarmismo, cero FOMO artificial, cero countdowns. Cierra reencuadrando el
 * precio del servicio como gasto de protección, no discrecional.
 *
 * Fuentes verificadas:
 * - Brief §4 (Ecuación de Valor Hormozi por dolor — rangos por margen y plazos).
 * - Brief §5 (dualidad operador-estratega Ciancio — voz del reframe final).
 * - Auditoría §3.6 (banda compacta legacy — esta versión la cuantifica).
 * - Mercado público (comisiones delivery MX: Rappi/UberEats/DiDi 23-35%).
 *
 * Cifras: rangos con asunción declarada. Sin invenciones puntuales.
 */
import Eyebrow from '../ui/Eyebrow.astro';
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';

type Variant = 'home' | 'landing';
type Dolor =
  | 'utilidad'
  | 'autonomia'
  | 'ventas-delivery'
  | 'personal'
  | 'metricas-control'
  | 'crecimiento-controlado';

interface Props {
  variant?: Variant;
  painSlug?: Dolor;
  class?: string;
}

const { variant = 'home', painSlug, class: className = '' } = Astro.props;

interface Leak {
  id: string;
  metric: string;
  title: string;
  body: string;
  doloresPrimario: Dolor;
  doloresSecundarios?: Dolor[];
}

const leaks: Leak[] = [
  {
    id: 'promociones-sin-roi',
    metric: '$60k-$120k MXN/mes',
    title: 'Promociones sin ROI medido',
    body:
      'Una promo 2x1 o 30% off sin costeo previo, corriendo 4 semanas en un negocio de $2M MXN/mes, regala entre $60k y $120k de utilidad neta — y casi nunca compensa con clientes nuevos recurrentes. Sin medir ticket pre/post promo, la decisión se repite el mes siguiente.',
    doloresPrimario: 'utilidad',
    doloresSecundarios: ['metricas-control', 'ventas-delivery'],
  },
  {
    id: 'comisiones-delivery',
    metric: '25-35% ticket bruto',
    title: 'Comisiones de marketplaces sin canal directo',
    body:
      'Rappi, UberEats y DiDi Food cobran entre 25% y 35% por orden. Si el delivery suma 20-25% de un negocio de $2M MXN/mes ($400k-$500k bruto), la comisión se lleva $100k-$175k mensuales que nunca tocan tu utilidad — y crecen con cada nuevo cliente que no es tuyo.',
    doloresPrimario: 'ventas-delivery',
    doloresSecundarios: ['utilidad'],
  },
  {
    id: 'rotacion-personal',
    metric: '0.5-1.5 sueldos por reemplazo',
    title: 'Rotación de personal sin estructura',
    body:
      'Cada salida cuesta entre medio y un sueldo y medio del puesto entre reclutamiento, formación, errores de servicio e ineficiencia inicial. En un equipo de 15 con 30-50% rotación anual, son $30k-$100k al año en costo directo — sin contar reseñas bajas ni caída de ticket por mal servicio.',
    doloresPrimario: 'personal',
    doloresSecundarios: ['utilidad', 'autonomia'],
  },
  {
    id: 'dependencia-dueno',
    metric: '0 días fuera',
    title: 'Dependencia operativa del dueño',
    body:
      'Si no puedes ausentarte 72 horas sin que caiga ticket, merma o satisfacción, el negocio no es un activo — es un empleo caro. Sin SOPs ni encargado entrenado, el techo de crecimiento es tu propia agenda.',
    doloresPrimario: 'autonomia',
    doloresSecundarios: ['crecimiento-controlado'],
  },
];

function selectLeaks(): Leak[] {
  if (variant === 'home' || !painSlug) return leaks;

  const primario = leaks.filter((l) => l.doloresPrimario === painSlug);
  const secundarios = leaks.filter(
    (l) => l.doloresPrimario !== painSlug && (l.doloresSecundarios ?? []).includes(painSlug),
  );

  const ordenados = [...primario, ...secundarios].slice(0, 3);
  return ordenados.length > 0 ? ordenados : leaks.slice(0, 3);
}

const visibleLeaks = selectLeaks();

const headlineHome = 'Cada mes sin sistema, entre 3% y 7% de margen se va por la coladera.';
const headlineLanding = painSlug === 'utilidad'
  ? 'El margen no se pierde de golpe. Se pierde 3-7% cada mes hasta que el año cierra en rojo.'
  : 'Mientras no se ordena la operación, cada mes se va una fracción del margen que ya no vuelve.';
const headline = variant === 'landing' ? headlineLanding : headlineHome;

const subhead =
  variant === 'home'
    ? 'Asunción: restaurante de 50-150 comensales facturando $2M MXN/mes. Cifras de mercado y rangos del diagnóstico inicial. Sin retórica.'
    : 'Mismas cifras del diagnóstico inicial NextSwift. Cada fuga es un cálculo aplicable a tu propio P&L — no una promesa genérica.';

const reframe =
  'Verlo así: una consultoría que recupera 3-7 puntos de margen en 90 días sobre tu base actual paga su propio costo dentro del primer trimestre. No es gasto discrecional — es gasto de protección sobre la utilidad que ya estás generando.';
---

<section
  class:list={['stakes', `stakes--${variant}`, painSlug ? `stakes--pain-${painSlug}` : '', className]}
  aria-labelledby="stakes-heading"
>
  <div class="stakes__inner">
    <header class="stakes__header">
      <Eyebrow tone="on-dark">El costo de no actuar</Eyebrow>
      <Heading as="h2" tone="on-dark" id="stakes-heading">{headline}</Heading>
      <Body size="lead" tone="on-dark" class="stakes__subhead">{subhead}</Body>
    </header>

    <ul class="stakes__list" role="list">
      {visibleLeaks.map((leak) => (
        <li class="leak" data-dolor={leak.doloresPrimario}>
          <span class="leak__metric" aria-hidden="true">{leak.metric}</span>
          <div class="leak__copy">
            <h3 class="leak__title">{leak.title}</h3>
            <p class="leak__body">
              <span class="visually-hidden">Costo estimado: {leak.metric}. </span>
              {leak.body}
            </p>
          </div>
        </li>
      ))}
    </ul>

    <p class="stakes__reframe">{reframe}</p>
  </div>
</section>

<style>
  .stakes {
    width: 100%;
    background: var(--color-dark-1);
    color: var(--color-text-on-dark);
    position: relative;
    isolation: isolate;
  }

  .stakes::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at top right, rgba(62, 234, 243, 0.08), transparent 55%),
      linear-gradient(180deg, var(--color-dark-1) 0%, var(--color-dark-4) 100%);
    z-index: -1;
  }

  .stakes__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-10) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .stakes--landing .stakes__inner {
    padding-block: var(--space-9);
    gap: var(--space-7);
  }

  /* ----- Header ----------------------------------------------------------- */
  .stakes__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 56rem;
  }

  .stakes__subhead {
    color: var(--color-soft);
  }

  /* ----- Lista de fugas --------------------------------------------------- */
  .stakes__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 720px) {
    .stakes__list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
  }

  .leak {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-5);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-4);
    transition: border-color var(--dur-3) var(--ease-out),
                background var(--dur-3) var(--ease-out);
  }

  .leak:hover {
    border-color: rgba(62, 234, 243, 0.45);
    background: rgba(255, 255, 255, 0.06);
  }

  .leak__metric {
    font-family: var(--font-heading);
    font-size: var(--fs-h3);
    line-height: var(--line-tight);
    color: var(--color-accent);
    letter-spacing: var(--tracking-tight);
    padding: var(--space-2) var(--space-3);
    border: 1px solid rgba(62, 234, 243, 0.35);
    border-radius: var(--radius-3);
    white-space: nowrap;
    align-self: start;
    min-width: max-content;
  }

  .leak__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .leak__title {
    font-family: var(--font-heading);
    font-size: var(--fs-h3);
    line-height: var(--line-snug);
    color: var(--color-text-on-dark);
    margin: 0;
    text-wrap: balance;
  }

  .leak__body {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-soft);
    margin: 0;
    max-width: 60ch;
  }

  /* ----- Reframe final (Ciancio: gasto de protección) -------------------- */
  .stakes__reframe {
    font-family: var(--font-subheading);
    font-size: var(--fs-lead);
    line-height: var(--line-snug);
    color: var(--color-text-on-dark);
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    max-width: 64rem;
    text-wrap: pretty;
  }

  /* ----- A11y helper ----------------------------------------------------- */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ----- Mobile: stack metric arriba del copy --------------------------- */
  @media (max-width: 480px) {
    .leak {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      padding: var(--space-4);
    }

    .leak__metric {
      justify-self: start;
    }
  }
</style>
