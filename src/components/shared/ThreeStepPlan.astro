---
/**
 * ThreeStepPlan — 3 pasos Miller (StoryBrand SB7). Ley de Hick: nunca > 3.
 *
 * El plan se siente lineal, fácil, predecible. Reduce fricción cognitiva
 * antes del CTA. Reusable Home / landings con `variant` + `painContext`.
 *
 * M7: linealidad temporal explícita — badge circular numerado que cabalga
 * sobre una línea conectora cyan (desktop) + ícono SVG por paso (lupa →
 * engranaje → gráfica). `<ol>` semántico intacto. NO emojis (regla CLAUDE.md
 * anti-decorativo).
 *
 * M18: la iconografía pasó al sistema central `ui/Icon.astro` (24×24, stroke
 * 1.75, hereda color vía currentColor). Se elimina el SVG inline provisional.
 *
 * V4-13 (anti card-soup): los 3 pasos dejan de ser cards bordeadas idénticas
 * con borde+radio+hover-shadow (la misma textura de plantilla que Oferta y
 * Garantías) y pasan a una SECUENCIA numerada (timeline): número display
 * dominante que ENCODA el orden, unidos por una regla hairline continua (spine).
 * Superficie blanca quieta, SIN elevación (la elevación queda reservada a los 2
 * momentos-firma: oferta + garantía). La jerarquía la da la numeración + el
 * respiro, no el contorno de cada celda.
 */
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Icon from '../ui/Icon.astro';

type Variant = 'home' | 'landing';

interface Props {
  variant?: Variant;
  painContext?: string;
  class?: string;
}

const { variant = 'home', painContext, class: className = '' } = Astro.props;

const headline =
  variant === 'landing' && painContext
    ? `Cómo recuperamos ${painContext} en 3 pasos`
    : 'Cómo trabajamos contigo en 3 pasos';

const subhead =
  variant === 'landing'
    ? 'Mismo método, contextualizado al dolor que estás resolviendo.'
    : 'Sin contratos eternos. Sin promesas vagas. Diagnóstico, ejecución, control.';

// Íconos del sistema central Icon.astro (M18). lupa→search, engranaje→gear,
// gráfica→chart-up. Subconjunto de IconName (canónico).
type IconKey = 'search' | 'gear' | 'chart-up';

interface Paso {
  numero: 1 | 2 | 3;
  titulo: string;
  descripcion: string;
  icon: IconKey;
  href?: string;
}

const pasos: [Paso, Paso, Paso] = [
  {
    numero: 1,
    titulo: 'Aplique al programa',
    descripcion:
      'Forma corta de calificación. Si su restaurante encaja, agendamos diagnóstico de 30 min. Si no, se lo decimos sin rodeos.',
    icon: 'search',
    href: '/auditoria',
  },
  {
    numero: 2,
    titulo: 'Implementación del Acelerador 3 Palancas',
    descripcion:
      '10 días hábiles dentro de su operación. Margen, sistema operativo y canal comercial — ejecutado con usted, no presentado en PDF.',
    icon: 'gear',
  },
  {
    numero: 3,
    titulo: 'Estado final: control y rentabilidad',
    descripcion:
      'Dashboard semanal, encargado entrenado, P&L que ya entiende. Sigue siendo su restaurante, ahora sin sangrar margen.',
    icon: 'chart-up',
  },
];
---

<section class:list={['plan', `plan--${variant}`, className]} aria-labelledby="plan-heading">
  <div class="plan__inner">
    <header class="plan__header">
      <Eyebrow>El plan</Eyebrow>
      <Heading as="h2" id="plan-heading">{headline}</Heading>
      <Body tone="muted">{subhead}</Body>
    </header>

    <ol class="plan__steps">
      {pasos.map((p) => (
        <li class="step" data-num={p.numero}>
          <div class="step__num" aria-hidden="true">{String(p.numero).padStart(2, '0')}</div>
          <span class="step__icon" aria-hidden="true">
            <Icon name={p.icon} />
          </span>
          {p.href ? (
            <a class="step__title" href={p.href}>{p.titulo}</a>
          ) : (
            <span class="step__title">{p.titulo}</span>
          )}
          <p class="step__desc">{p.descripcion}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  /* V4-13: superficie blanca quieta (era surface-alt). En el ritmo del home queda
     entre Stakes (oscuro) y testimonios (blanco); la alternancia de fondo la maneja
     index.astro. Sin card-soup: el bloque es una SECUENCIA, no una rejilla de cajas. */
  .plan {
    width: 100%;
    background: var(--color-surface);
    color: var(--color-text);
  }

  .plan__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    /* Ritmo tier-1 (respiro entre secciones) via padding-block; tier-2 dentro del bloque. */
    padding: var(--rhythm-block) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--rhythm-within);
  }

  .plan__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--content-narrow);
  }

  /* SECUENCIA numerada (timeline). Mobile: columna con spine vertical hairline a la
     izquierda de los números. Sin cards: cada paso es una celda plana. */
  .plan__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    position: relative;
  }

  .step {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas:
      'num  icon'
      'num  title'
      'num  desc';
    column-gap: var(--space-4);
    row-gap: var(--space-2);
    align-items: start;
  }

  /* Número display dominante: ENCODA el orden (01 · 02 · 03). Es el ancla visual del
     paso, no una card. Mono tabular = firma "tablero de operador" (igual que Stakes). */
  .step__num {
    grid-area: num;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums lining-nums;
    font-feature-settings: "tnum" 1, "lnum" 1;
    font-size: clamp(2rem, 1.4rem + 2vw, 2.75rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-action);        /* deep teal v4: el número es el acento, no un badge neón */
  }

  /* Spine hairline vertical que une los números en la secuencia (mobile). Reemplaza la
     línea conectora neón que cabalgaba sobre las cards. */
  .step:not(:last-child) .step__num::after {
    content: '';
    position: absolute;
    top: 3rem;
    bottom: calc(-1 * var(--space-6) - 0.5rem);
    left: calc(1.625rem - 1px);        /* centrado bajo el número (mitad de 3.25rem) */
    width: 2px;
    background: var(--color-border);
  }

  .step__icon {
    grid-area: icon;
    display: inline-flex;
    width: 24px;
    height: 24px;
    color: var(--color-primary-dark);
  }

  .step__title {
    grid-area: title;
    max-width: 100%;
    font-family: var(--font-heading);
    font-size: var(--fs-h3);
    font-weight: 600;
    line-height: var(--line-snug);
    color: var(--color-text);
    text-decoration: none;
    text-wrap: balance;
  }

  a.step__title {
    align-self: start;
    justify-self: start;
    border-bottom: 2px solid transparent;
    transition: border-color var(--dur-2) var(--ease-out), color var(--dur-2) var(--ease-out);
  }

  a.step__title:hover {
    color: var(--color-action);
    border-bottom-color: var(--color-action);
  }

  a.step__title:focus-visible {
    outline: 3px solid var(--color-action);
    outline-offset: 2px;
    box-shadow: var(--shadow-focus);
    border-radius: var(--radius-1);
  }

  .step__desc {
    grid-area: desc;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-text-muted);
    max-width: 46ch;
  }

  /* Desktop: la secuencia se despliega en 3 columnas, número arriba de cada paso,
     unidos por una regla hairline HORIZONTAL continua (el spine se voltea). */
  @media (min-width: 768px) {
    .plan__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }

    /* Regla horizontal continua que atraviesa la fila de números (la secuencia). */
    .plan__steps::before {
      content: '';
      position: absolute;
      top: calc((clamp(2rem, 1.4rem + 2vw, 2.75rem)) / 2);   /* centro vertical del número */
      left: 0;
      right: 0;
      height: 2px;
      background: var(--color-border);
      z-index: 0;
    }

    .step {
      grid-template-columns: 1fr;
      grid-template-areas:
        'num'
        'icon'
        'title'
        'desc';
      row-gap: var(--space-3);
      text-align: left;
    }

    .step__num {
      justify-content: flex-start;
      width: auto;
      /* El número se apoya sobre la regla horizontal con un respaldo de superficie que
         la "corta", dando la sensación de nodo en la línea. */
      position: relative;
      z-index: 1;
      padding-right: var(--space-3);
      background: var(--color-surface);
    }

    /* En desktop el spine es la regla horizontal (::before), no el pseudo del número. */
    .step:not(:last-child) .step__num::after { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    a.step__title { transition: none; }
  }

  /* Compacto en landing: se conserva la secuencia, más apretada. */
  .plan--landing .plan__inner { padding-block: var(--rhythm-within); }
  .plan--landing .step__desc { font-size: 0.9375rem; }
</style>
