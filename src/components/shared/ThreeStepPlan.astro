---
/**
 * ThreeStepPlan — 3 pasos Miller (StoryBrand SB7). Ley de Hick: nunca > 3.
 *
 * El plan se siente lineal, fácil, predecible. Reduce fricción cognitiva
 * antes del CTA. Reusable Home / landings con `variant` + `painContext`.
 *
 * M7: linealidad temporal explícita — badge circular numerado que cabalga
 * sobre una línea conectora cyan (desktop) + ícono SVG por paso (lupa →
 * engranaje → gráfica). `<ol>` semántico intacto. NO emojis (regla CLAUDE.md
 * anti-decorativo).
 *
 * M18: la iconografía pasó al sistema central `ui/Icon.astro` (24×24, stroke
 * 1.75, hereda color vía currentColor). Se elimina el SVG inline provisional.
 */
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Icon from '../ui/Icon.astro';

type Variant = 'home' | 'landing';

interface Props {
  variant?: Variant;
  painContext?: string;
  class?: string;
}

const { variant = 'home', painContext, class: className = '' } = Astro.props;

const headline =
  variant === 'landing' && painContext
    ? `Cómo recuperamos ${painContext} en 3 pasos`
    : 'Cómo trabajamos contigo en 3 pasos';

const subhead =
  variant === 'landing'
    ? 'Mismo método, contextualizado al dolor que estás resolviendo.'
    : 'Sin contratos eternos. Sin promesas vagas. Diagnóstico, ejecución, control.';

// Íconos del sistema central Icon.astro (M18). lupa→search, engranaje→gear,
// gráfica→chart-up. Subconjunto de IconName (canónico).
type IconKey = 'search' | 'gear' | 'chart-up';

interface Paso {
  numero: 1 | 2 | 3;
  titulo: string;
  descripcion: string;
  icon: IconKey;
  href?: string;
}

const pasos: [Paso, Paso, Paso] = [
  {
    numero: 1,
    titulo: 'Aplique al programa',
    descripcion:
      'Forma corta de calificación. Si su restaurante encaja, agendamos diagnóstico de 30 min. Si no, se lo decimos sin rodeos.',
    icon: 'search',
    href: '/auditoria',
  },
  {
    numero: 2,
    titulo: 'Implementación del Acelerador 3 Palancas',
    descripcion:
      '10 días hábiles dentro de su operación. Margen, sistema operativo y canal comercial — ejecutado con usted, no presentado en PDF.',
    icon: 'gear',
  },
  {
    numero: 3,
    titulo: 'Estado final: control y rentabilidad',
    descripcion:
      'Dashboard semanal, encargado entrenado, P&L que ya entiende. Sigue siendo su restaurante, ahora sin sangrar margen.',
    icon: 'chart-up',
  },
];
---

<section class:list={['plan', `plan--${variant}`, className]} aria-labelledby="plan-heading">
  <div class="plan__inner">
    <header class="plan__header">
      <Eyebrow>El plan</Eyebrow>
      <Heading as="h2" id="plan-heading">{headline}</Heading>
      <Body tone="muted">{subhead}</Body>
    </header>

    <ol class="plan__steps">
      {pasos.map((p) => (
        <li class="step" data-num={p.numero}>
          <div class="step__num" aria-hidden="true">{String(p.numero).padStart(2, '0')}</div>
          <span class="step__icon" aria-hidden="true">
            <Icon name={p.icon} />
          </span>
          {p.href ? (
            <a class="step__title" href={p.href}>{p.titulo}</a>
          ) : (
            <span class="step__title">{p.titulo}</span>
          )}
          <p class="step__desc">{p.descripcion}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .plan {
    width: 100%;
    background: var(--color-surface-alt);
    color: var(--color-text);
  }

  .plan__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-9) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .plan__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--content-narrow);
  }

  .plan__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    /* gap holgado: los badges sobresalen -28px y deben caber entre cards apiladas */
    gap: var(--space-7);
    counter-reset: step;
    position: relative;
    /* colchón superior para el badge del primer paso (sobresale del card) */
    margin-top: var(--space-5);
  }

  @media (min-width: 768px) {
    .plan__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }

    /* Línea conectora horizontal: une los centros de los 3 badges.
       Vive detrás de las cards (z-index 0); solo visible en los gaps. */
    .plan__steps::before {
      content: '';
      position: absolute;
      top: -1px;            /* centrada en el eje de los badges (borde sup. de las cards) */
      left: 16.666%;        /* centro de la 1ª columna */
      right: 16.666%;       /* centro de la 3ª columna */
      height: 2px;
      background: var(--color-accent);
      z-index: 0;
    }
  }

  .step {
    position: relative;
    z-index: 1;                       /* sobre la línea conectora */
    display: flex;
    flex-direction: column;
    text-align: center;
    gap: var(--space-2);
    /* padding-top holgado: deja pasar el badge que cabalga en top:-28px */
    padding: var(--space-7) var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-4);
    transition: transform var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out), box-shadow var(--dur-2) var(--ease-out);
  }

  .step:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-3);
  }

  @media (prefers-reduced-motion: reduce) {
    .step { transition: border-color var(--dur-2) var(--ease-out), box-shadow var(--dur-2) var(--ease-out); }
    .step:hover { transform: none; }
  }

  /* Badge circular numerado: cabalga sobre la línea conectora. */
  .step__num {
    position: absolute;
    top: -28px;                       /* centro del badge = borde sup. del card */
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;                       /* sobre la línea y el card */
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: var(--color-dark-1);
    border: 3px solid var(--color-surface);   /* anillo que lo separa de la línea */
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }

  /* Ícono por paso (search → gear → chart-up) vía ui/Icon.astro (M18).
     El chip fija caja 24×24 y color; Icon hereda color (currentColor) y se
     dimensiona por su atributo size (default 24). */
  .step__icon {
    align-self: center;               /* centra el SVG; título/desc quedan full-width */
    display: inline-flex;
    width: 24px;
    height: 24px;
    color: var(--color-primary-dark);
  }

  .step__title {
    align-self: center;               /* se ajusta al texto: subrayado del enlace acotado */
    max-width: 100%;
    font-family: var(--font-heading);
    font-size: var(--fs-h3);
    font-weight: 600;
    line-height: var(--line-snug);
    color: var(--color-text);
    text-decoration: none;
  }

  a.step__title {
    border-bottom: 2px solid transparent;
    transition: border-color var(--dur-2) var(--ease-out), color var(--dur-2) var(--ease-out);
  }

  a.step__title:hover {
    color: var(--color-primary-dark);
    border-bottom-color: var(--color-accent);
  }

  a.step__title:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
    box-shadow: var(--shadow-focus);
    border-radius: var(--radius-1);
  }

  .step__desc {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-text-muted);
  }

  /* Compacto en landing: bloque ≤ 200px alto desktop (criterio aceptación).
     Se conserva el padding-top space-7 para que el badge no se recorte. */
  .plan--landing .plan__inner { padding-block: var(--space-7); }
  .plan--landing .step { padding: var(--space-7) var(--space-4) var(--space-3); }
  .plan--landing .step__desc { font-size: 0.9375rem; }
</style>
