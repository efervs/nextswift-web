---
/**
 * Icon — Sistema central de iconografía SVG inline (M18, plan_de_mejoras_v1).
 *
 * Fuente única de los íconos compartidos del sitio. SVG inline en el HTML
 * estático (cero JS, cero request HTTP extra, cero font-icon). Sustituye los
 * SVG inline duplicados que M7/M8/M9 traían como "provisional hasta M18".
 *
 * Decisión de M18 (cuerpo del prompt, autoritativo sobre la tabla §1 del plan):
 *   - SIN sprite externo (`public/icons.svg`): map interno inline.
 *   - SIN font-icons (peso y a11y peores que SVG inline).
 *   - 9 íconos canónicos. M6/Stakes conserva sus variantes direccionales
 *     bespoke (calculator-down/delivery-out/person-cycle) — son íconos de
 *     "fuga" con flecha de dirección, fuera de este set plano por diseño.
 *
 * Estilo base (heredado de los componentes cerrados M6-M9): viewBox 0 0 24 24,
 * trazo `stroke-width: 1.75`, `currentColor` para heredar el color del
 * contenedor (color es propiedad heredada → cruza el límite de componente,
 * a diferencia de los estilos scoped de Astro). `whatsapp` es glifo de marca
 * (relleno), no trazo.
 *
 * Uso:
 *   <Icon name="shield" />                  // 24px, hereda color del padre
 *   <Icon name="search" size={32} />        // tamaño explícito
 *   <Icon name="whatsapp" color="#25D366" /> // verde de marca (default: currentColor)
 *
 * A11y: decorativo por defecto (aria-hidden). Si se pasa `title`, pasa a
 * semántico (role="img" + aria-label).
 */
export type IconName =
  | 'shield'
  | 'calculator'
  | 'gear'
  | 'chart-up'
  | 'person'
  | 'search'
  | 'lock-open'
  | 'truck'
  | 'whatsapp';

interface Props {
  name: IconName;
  size?: number;
  color?: string;
  class?: string;
  title?: string;
}

const { name, size = 24, color = 'currentColor', class: className = '', title } = Astro.props;

// `whatsapp` es glifo de marca: se pinta con relleno, no con trazo.
const isFilled = name === 'whatsapp';
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill={isFilled ? color : 'none'}
  stroke={isFilled ? undefined : color}
  stroke-width={isFilled ? undefined : 1.75}
  stroke-linecap={isFilled ? undefined : 'round'}
  stroke-linejoin={isFilled ? undefined : 'round'}
  class:list={['icon', `icon--${name}`, className]}
  role={title ? 'img' : undefined}
  aria-label={title ?? undefined}
  aria-hidden={title ? undefined : 'true'}
  focusable="false"
>
  {title && <title>{title}</title>}

  {name === 'shield' && (
    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
  )}

  {name === 'calculator' && (
    <Fragment>
      <rect x="4" y="2" width="16" height="20" rx="2" />
      <line x1="8" y1="6" x2="16" y2="6" />
      <line x1="16" y1="14" x2="16" y2="18" />
      <path d="M8 10h.01" />
      <path d="M12 10h.01" />
      <path d="M16 10h.01" />
      <path d="M8 14h.01" />
      <path d="M12 14h.01" />
      <path d="M8 18h.01" />
      <path d="M12 18h.01" />
    </Fragment>
  )}

  {name === 'gear' && (
    <Fragment>
      <path d="M12.5 2h-1a2 2 0 0 0-2 2 1.7 1.7 0 0 1-.85 1.48l-.36.2a1.7 1.7 0 0 1-1.7 0l-.13-.07a2 2 0 0 0-2.73.73l-.5.87a2 2 0 0 0 .73 2.73l.13.07a1.7 1.7 0 0 1 .85 1.48v.42a1.7 1.7 0 0 1-.85 1.48l-.13.07a2 2 0 0 0-.73 2.73l.5.87a2 2 0 0 0 2.73.73l.13-.07a1.7 1.7 0 0 1 1.7 0l.36.2A1.7 1.7 0 0 1 9.5 20a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2 1.7 1.7 0 0 1 .85-1.48l.36-.2a1.7 1.7 0 0 1 1.7 0l.13.07a2 2 0 0 0 2.73-.73l.5-.87a2 2 0 0 0-.73-2.73l-.13-.07a1.7 1.7 0 0 1-.85-1.48v-.42a1.7 1.7 0 0 1 .85-1.48l.13-.07a2 2 0 0 0 .73-2.73l-.5-.87a2 2 0 0 0-2.73-.73l-.13.07a1.7 1.7 0 0 1-1.7 0l-.36-.2A1.7 1.7 0 0 1 14.5 4a2 2 0 0 0-2-2z" />
      <circle cx="12" cy="12" r="3" />
    </Fragment>
  )}

  {name === 'chart-up' && (
    <Fragment>
      <path d="M3 3v16a2 2 0 0 0 2 2h16" />
      <path d="m7 14 4-4 3 3 5-5" />
      <path d="M19 8h2v2" />
    </Fragment>
  )}

  {name === 'person' && (
    <Fragment>
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
      <circle cx="12" cy="7" r="4" />
    </Fragment>
  )}

  {name === 'search' && (
    <Fragment>
      <circle cx="11" cy="11" r="7" />
      <path d="m21 21-4.3-4.3" />
    </Fragment>
  )}

  {name === 'lock-open' && (
    <Fragment>
      <rect x="4" y="11" width="16" height="10" rx="2" />
      <path d="M8 11V7a4 4 0 0 1 7.5-2" />
      <circle cx="12" cy="16" r="1" fill={color} stroke="none" />
    </Fragment>
  )}

  {name === 'truck' && (
    <Fragment>
      <path d="M14 18V6a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v11a1 1 0 0 0 1 1h2" />
      <path d="M15 18H9" />
      <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14" />
      <circle cx="17" cy="18" r="2" />
      <circle cx="7" cy="18" r="2" />
    </Fragment>
  )}

  {name === 'whatsapp' && (
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.94.51 3.83 1.48 5.49L2 22l4.74-1.24a9.9 9.9 0 0 0 5.3 1.52h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.84 9.84 0 0 0 12.04 2zm0 18.03h-.01a8.16 8.16 0 0 1-4.17-1.14l-.3-.18-3.09.81.82-3.01-.19-.31a8.18 8.18 0 0 1-1.25-4.3c0-4.51 3.68-8.19 8.2-8.19a8.14 8.14 0 0 1 5.79 2.4 8.14 8.14 0 0 1 2.4 5.8c0 4.51-3.68 8.19-8.2 8.19zm4.5-6.13c-.25-.12-1.46-.72-1.69-.8-.23-.08-.39-.12-.56.12-.16.25-.64.8-.78.96-.14.16-.29.18-.54.06-.25-.12-1.04-.38-1.99-1.22a7.45 7.45 0 0 1-1.38-1.71c-.14-.25-.02-.38.1-.5.11-.11.25-.29.37-.43.12-.14.16-.25.24-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42h-.48a.91.91 0 0 0-.66.31c-.23.25-.86.84-.86 2.05 0 1.21.89 2.38 1.01 2.55.12.16 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.55.1.47-.07 1.46-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z" />
  )}
</svg>

<style>
  /* Reemplaza el `svg { display: block }` que cada padre (M6-M9) declaraba en
     su <style> scoped — esos selectores ya NO alcanzan este svg (Astro no
     filtra estilos scoped a componentes hijos). El tamaño lo fijan los
     atributos width/height; el color se hereda vía currentColor. */
  .icon {
    display: block;
  }
</style>
