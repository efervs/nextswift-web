---
/**
 * Button — primitivo institucional NextSwift.
 * Variantes: primary (cyan, ink dark), ghost (border dark, transparente), wa (WhatsApp).
 * Tamaños: sm (40px), md (48px), lg (56px). Touch target >= 44px en md/lg.
 * Renderiza <a> si recibe `href`, <button> en cualquier otro caso.
 */
type Variant = 'primary' | 'ghost' | 'wa';
type Size = 'sm' | 'md' | 'lg';

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  fullWidth?: boolean;
  rel?: string;
  target?: string;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  fullWidth = false,
  rel,
  target,
  class: className = '',
  ariaLabel,
} = Astro.props;

const Tag = href ? 'a' : 'button';
const isLink = Tag === 'a';
---

<Tag
  class:list={['btn', `btn--${variant}`, `btn--${size}`, fullWidth && 'btn--full', className]}
  href={isLink ? href : undefined}
  type={!isLink ? type : undefined}
  disabled={!isLink && disabled ? true : undefined}
  aria-disabled={isLink && disabled ? 'true' : undefined}
  rel={rel}
  target={target}
  aria-label={ariaLabel}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-subheading);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    line-height: 1;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    user-select: none;
    transition:
      background-color var(--dur-2) var(--ease-out),
      color var(--dur-2) var(--ease-out),
      border-color var(--dur-2) var(--ease-out),
      box-shadow var(--dur-2) var(--ease-out),
      transform var(--dur-1) var(--ease-out);
    white-space: nowrap;
  }

  .btn--sm { font-size: 0.875rem; padding: 0.625rem 1rem; min-height: 2.5rem; border-radius: var(--radius-2); }
  .btn--md { font-size: 1rem;     padding: 0.875rem 1.5rem; min-height: 3rem;   border-radius: var(--radius-3); }
  .btn--lg { font-size: 1.0625rem; padding: 1.125rem 1.875rem; min-height: 3.5rem; border-radius: var(--radius-3); }

  .btn--full { width: 100%; }

  /* Primary — cyan acento sobre texto navy */
  .btn--primary {
    background: var(--color-accent);
    color: var(--color-accent-ink);
    box-shadow: var(--shadow-2);
  }
  .btn--primary:hover {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
    box-shadow: var(--shadow-3);
  }
  .btn--primary:active { transform: translateY(1px); box-shadow: var(--shadow-1); }

  /* Ghost — borde navy, fondo transparente */
  .btn--ghost {
    background: transparent;
    color: var(--color-dark-1);
    border-color: var(--color-dark-1);
  }
  .btn--ghost:hover {
    background: var(--color-dark-1);
    color: var(--color-text-on-dark);
  }
  .btn--ghost:active { transform: translateY(1px); }

  /* WhatsApp — verde institucional implícito vía custom (no en tokens base) */
  .btn--wa {
    background: var(--color-dark-1);
    color: var(--color-text-on-dark);
    border-color: var(--color-dark-1);
  }
  .btn--wa:hover {
    background: var(--color-dark-2);
    border-color: var(--color-dark-2);
  }
  .btn--wa:active { transform: translateY(1px); }

  /* Disabled */
  .btn:disabled,
  .btn[aria-disabled='true'] {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
    box-shadow: none;
    transform: none;
  }

  /* Focus visible — anillo cyan unificado */
  .btn:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }
</style>
