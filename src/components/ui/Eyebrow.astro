---
/**
 * Eyebrow — etiqueta institucional sobre H1/H2. Small-caps, color de marca.
 * Voz consultoría (Ciancio + Beaudoin): siempre concreta, nunca decorativa.
 */
type Tone = 'accent' | 'neutral' | 'on-dark';

interface Props {
  tone?: Tone;
  as?: 'span' | 'p' | 'div';
  class?: string;
}

const { tone = 'accent', as: Tag = 'span', class: className = '' } = Astro.props;
---

<Tag class:list={['eyebrow', `eyebrow--${tone}`, className]}>
  <slot />
</Tag>

<style>
  .eyebrow {
    display: inline-block;
    font-family: var(--font-subheading);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    line-height: var(--line-snug);
    /* M20: reparte el texto en líneas equilibradas en vez de una larga + una corta;
       evita la 3ª línea huérfana de los eyebrow largos en móvil. */
    text-wrap: balance;
  }
  /* M14 (TA-08): 'accent' es el énfasis semántico (marca/CTA-adjacent), no el
     valor crudo --color-accent — pintarlo con el cian crudo fallaría AA como
     texto (1.47:1). Se documenta en vez de renombrar: el prop se consume con
     tone="accent" (o por default) en ~20 paginas/componentes fuera del
     alcance de M14; renombrarlo ahora rompería esos usos sin verificarlos. */
  .eyebrow--accent   { color: var(--color-primary-dark); }
  .eyebrow--neutral  { color: var(--color-text-muted); }
  .eyebrow--on-dark  { color: var(--color-accent); }

  /* M20: en móviles cortos el eyebrow largo rompía en 3 líneas a 360px.
     El tracking ya se cierra vía token (tokens.css); aquí un nudge de tamaño
     para asegurar 1-2 líneas sin tocar el copy. Desktop intacto. */
  @media (max-width: 480px) {
    .eyebrow { font-size: 0.6875rem; }  /* 11px */
  }
</style>
