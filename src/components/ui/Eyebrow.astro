---
/**
 * Eyebrow — etiqueta institucional sobre H1/H2. Small-caps, color de marca.
 * Voz consultoría (Ciancio + Beaudoin): siempre concreta, nunca decorativa.
 */
type Tone = 'accent' | 'neutral' | 'on-dark';

interface Props {
  tone?: Tone;
  as?: 'span' | 'p' | 'div';
  class?: string;
}

const { tone = 'accent', as: Tag = 'span', class: className = '' } = Astro.props;
---

<Tag class:list={['eyebrow', `eyebrow--${tone}`, className]}>
  <slot />
</Tag>

<style>
  .eyebrow {
    display: inline-block;
    font-family: var(--font-subheading);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    line-height: var(--line-snug);
  }
  .eyebrow--accent   { color: var(--color-primary-dark); }
  .eyebrow--neutral  { color: var(--color-text-muted); }
  .eyebrow--on-dark  { color: var(--color-accent); }
</style>
