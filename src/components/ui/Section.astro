---
/**
 * Section — contenedor narrativo con padding fluido y max-width tokenizado.
 * El eyebrow es opcional; cuando viene, se ancla arriba con espacio reducido.
 */
type Width = 'content' | 'narrow' | 'full';
type Tone = 'surface' | 'alt' | 'dark';
type SpacingBlock = 'sm' | 'md' | 'lg';

interface Props {
  width?: Width;
  tone?: Tone;
  spacing?: SpacingBlock;
  as?: 'section' | 'article' | 'div';
  id?: string;
  class?: string;
}

const {
  width = 'content',
  tone = 'surface',
  spacing = 'md',
  as: Tag = 'section',
  id,
  class: className = '',
} = Astro.props;
---

<Tag id={id} class:list={['section', `section--tone-${tone}`, `section--spacing-${spacing}`, className]}>
  <div class:list={['section__inner', `section__inner--${width}`]}>
    <slot />
  </div>
</Tag>

<style>
  .section { width: 100%; }
  .section--tone-surface { background: var(--color-surface); color: var(--color-text); }
  .section--tone-alt     { background: var(--color-surface-alt); color: var(--color-text); }
  .section--tone-dark    { background: var(--color-dark-1); color: var(--color-text-on-dark); }

  .section--spacing-sm { padding-block: var(--space-7); }
  .section--spacing-md { padding-block: var(--space-9); }
  .section--spacing-lg { padding-block: var(--space-11); }

  .section__inner {
    margin-inline: auto;
    padding-inline: var(--space-4);
  }
  .section__inner--content { max-width: var(--content-max); }
  .section__inner--narrow  { max-width: var(--content-narrow); }
  .section__inner--full    { max-width: none; padding-inline: 0; }
</style>
