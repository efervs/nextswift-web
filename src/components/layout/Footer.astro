---
/**
 * Footer — red de seguridad jerárquica de NextSwift.
 * 4 columnas desktop / stack vertical mobile.
 * Mini-CTA final → /auditoria.
 */
import { WHATSAPP_PHONE } from '../../lib/whatsapp-phone';
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">

    <!-- Marca + claim -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="NextSwift — inicio">
        <img src="/images/logo-nextswift.webp" alt="NextSwift" width="200" height="50" loading="lazy" class="footer-logo__img" />
      </a>
      <p class="footer-claim">Partner operativo B2B para restaurantes</p>

      <!-- Redes sociales -->
      <nav class="footer-social" aria-label="Redes sociales">
        <a
          href="https://www.instagram.com/nextswift.mx"
          target="_blank"
          rel="noopener"
          aria-label="Instagram de NextSwift"
          class="footer-social__link"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="footer-social__icon">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/company/nextswift-mx"
          target="_blank"
          rel="noopener"
          aria-label="LinkedIn de NextSwift"
          class="footer-social__link"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="footer-social__icon">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </nav>
    </div>

    <!-- Col 1: Servicios -->
    <nav class="footer-col" aria-label="Servicios de NextSwift">
      <h3 class="footer-col__title">Servicios</h3>
      <ul class="footer-col__list">
        <li><a href="/utilidad">Restaurante que vende pero no gana</a></li>
        <li><a href="/autonomia">Dependencia total del dueño</a></li>
        <li><a href="/ventas-delivery">Ventas estancadas y delivery</a></li>
        <li><a href="/personal">Crisis de personal y rotación</a></li>
        <li><a href="/metricas-control">Sin números ni control</a></li>
        <li><a href="/crecimiento-controlado">Crecer sin reventar</a></li>
      </ul>
    </nav>

    <!-- Col 2: Empresa -->
    <nav class="footer-col" aria-label="Empresa">
      <h3 class="footer-col__title">Empresa</h3>
      <ul class="footer-col__list">
        <li><a href="/sobre-efer">Sobre Efer</a></li>
        <li><a href="/garantia">Garantía NextSwift</a></li>
        <li><a href="/casos-de-exito">Casos de éxito</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </nav>

    <!-- Col 3: Legal -->
    <nav class="footer-col" aria-label="Legal">
      <h3 class="footer-col__title">Legal</h3>
      <ul class="footer-col__list">
        <li><a href="/legales/aviso-de-privacidad">Aviso de Privacidad</a></li>
        <li><a href="/legales/terminos-y-condiciones">Términos y Condiciones</a></li>
      </ul>
    </nav>

    <!-- Col 4: Contacto -->
    <div class="footer-col">
      <h3 class="footer-col__title">Contacto</h3>
      <ul class="footer-col__list footer-col__list--contact">
        <li>
          <a
            href={`https://wa.me/${WHATSAPP_PHONE}`}
            target="_blank"
            rel="noopener"
            aria-label="Escribir por WhatsApp"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="footer-contact__icon">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.94.51 3.83 1.48 5.49L2 22l4.74-1.24a9.9 9.9 0 0 0 5.3 1.52h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.84 9.84 0 0 0 12.04 2zm0 18.03h-.01a8.16 8.16 0 0 1-4.17-1.14l-.3-.18-3.09.81.82-3.01-.19-.31a8.18 8.18 0 0 1-1.25-4.3c0-4.51 3.68-8.19 8.2-8.19a8.14 8.14 0 0 1 5.79 2.4 8.14 8.14 0 0 1 2.4 5.8c0 4.51-3.68 8.19-8.2 8.19zm4.5-6.13c-.25-.12-1.46-.72-1.69-.8-.23-.08-.39-.12-.56.12-.16.25-.64.8-.78.96-.14.16-.29.18-.54.06-.25-.12-1.04-.38-1.99-1.22a7.45 7.45 0 0 1-1.38-1.71c-.14-.25-.02-.38.1-.5.11-.11.25-.29.37-.43.12-.14.16-.25.24-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42h-.48a.91.91 0 0 0-.66.31c-.23.25-.86.84-.86 2.05 0 1.21.89 2.38 1.01 2.55.12.16 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.55.1.47-.07 1.46-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/>
            </svg>
            +52 811 042 5674
          </a>
        </li>
        <li>
          <a href="mailto:hola@nextswift.mx">hola@nextswift.mx</a>
        </li>
        <li class="footer-contact__location">Monterrey, Nuevo León, México</li>
      </ul>
    </div>

  </div>

  <!-- Mini-CTA final -->
  <div class="footer-cta-bar">
    <p class="footer-cta-bar__copy">¿Listo para una auditoría sin compromisos?</p>
    <a href="/auditoria" class="footer-cta-bar__btn">
      Solicitar auditoría gratuita&nbsp;&rarr;
    </a>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p class="footer-bottom__copy">
      &copy; <span id="footer-year">2025</span> NextSwift. Todos los derechos reservados.
    </p>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>

<style>
  .site-footer {
    background: var(--color-dark-1);
    color: var(--color-text-on-dark);
    padding-top: var(--space-10);
  }

  .footer-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--space-6);
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1.2fr;
    gap: var(--space-7);
    align-items: start;
    padding-bottom: var(--space-10);
  }

  /* Brand column */
  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: var(--space-3);
  }
  .footer-logo__img {
    height: clamp(36px, 3vw, 48px);
    width: auto;
    display: block;
    transition: filter 0.15s;
  }
  .footer-logo:hover .footer-logo__img {
    filter: brightness(1.15);
  }
  .footer-claim {
    font-family: var(--font-subheading);
    font-size: var(--fs-eyebrow);
    color: var(--color-neutral-300);
    margin: 0 0 var(--space-5);
    line-height: var(--line-snug);
    max-width: 18ch;
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: var(--space-3);
  }
  .footer-social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* M18 (T7-05): era 2.25rem (36px) < 44px → tap target WCAG */
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1px solid var(--color-neutral-700);
    color: var(--color-neutral-300);
    text-decoration: none;
    transition: border-color 0.18s, color 0.18s;
  }
  .footer-social__link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .footer-social__link:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 3px;
  }
  .footer-social__icon {
    width: 1rem;
    height: 1rem;
  }

  /* Nav columns */
  .footer-col__title {
    font-family: var(--font-subheading);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-neutral-300);
    margin: 0 0 var(--space-4);
  }
  .footer-col__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .footer-col__list a {
    font-size: clamp(0.875rem, 0.84rem + 0.15vw, 1rem);
    color: var(--color-neutral-300);
    text-decoration: none;
    line-height: var(--line-snug);
    transition: color 0.15s;
  }
  .footer-col__list a:hover {
    color: var(--color-accent);
  }

  /* Contact extras */
  .footer-col__list--contact li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .footer-col__list--contact a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .footer-contact__icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: #25D366;
  }
  .footer-contact__location {
    font-size: clamp(0.8rem, 0.76rem + 0.15vw, 0.875rem);
    color: var(--color-muted);
  }

  /* Mini-CTA final */
  .footer-cta-bar {
    background: var(--color-dark-4);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    padding: var(--space-6) var(--space-6);
    flex-wrap: wrap;
    text-align: center;
  }
  .footer-cta-bar__copy {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: var(--fs-lead);
    font-weight: 600;
    color: #fff;
  }
  .footer-cta-bar__btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: var(--color-accent-ink);
    font-family: var(--font-subheading);
    font-weight: 700;
    font-size: var(--fs-body);
    border-radius: var(--radius-3);
    text-decoration: none;
    white-space: nowrap;
    transition: filter 0.15s;
  }
  .footer-cta-bar__btn:hover {
    filter: brightness(1.07);
    color: var(--color-accent-ink);
  }

  /* Bottom bar */
  .footer-bottom {
    background: var(--color-dark-4);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: var(--space-4) var(--space-6);
    text-align: center;
  }
  .footer-bottom__copy {
    margin: 0;
    font-size: var(--fs-eyebrow);
    color: var(--color-muted);
  }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8) var(--space-6);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-claim {
      max-width: none;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
    .footer-cta-bar {
      flex-direction: column;
      gap: var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-social__link,
    .footer-col__list a,
    .footer-cta-bar__btn { transition: none; }
  }
</style>
