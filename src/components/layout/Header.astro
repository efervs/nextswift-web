---
/**
 * Header — navegación minimalista global NextSwift.
 * Logo + 4 anclas (Servicios ▾ / Casos / Sobre Efer / Blog) + CTA sticky.
 * Dropdown desktop: mega-menú 6 dolores.
 * Mobile: hamburguesa → lista vertical (sin mega-menú).
 * Sticky con shrink/elevación al scroll — CSS only.
 */

import Icon from '../ui/Icon.astro';
import { buildWaUrl } from '../../lib/whatsapp-url';

const NAV_ID = 'site-nav';
const MENU_BTN_ID = 'mobile-menu-btn';

// CTA WhatsApp del panel móvil (M3) — UTM canónico vía helper, una verdad por tema.
const waMenuUrl = buildWaUrl({
  source: 'home',
  content: 'header_mobile_menu',
});
---

<header class="site-header" id="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="NextSwift — inicio">
      <img src="/images/logo-nextswift.webp" alt="NextSwift" width="160" height="40" loading="eager" fetchpriority="high" class="header-logo__img" />
    </a>

    <!-- Nav desktop -->
    <nav class="header-nav" id={NAV_ID} aria-label="Navegación principal">
      <ul class="header-nav__list" role="list">

        <!-- Servicios ▾ con dropdown -->
        <li class="header-nav__item header-nav__item--dropdown">
          <button
            class="header-nav__link header-nav__dropdown-btn"
            aria-expanded="false"
            aria-controls="servicios-dropdown"
            type="button"
          >
            Servicios
            <svg class="header-nav__chevron" viewBox="0 0 12 7" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M1 1l5 5 5-5"/>
            </svg>
          </button>

          <div class="header-dropdown" id="servicios-dropdown" role="region" aria-label="Menú de servicios">
            <ul class="header-dropdown__list" role="list">
              <li>
                <a href="/utilidad" class="header-dropdown__link">
                  <span class="header-dropdown__label">Restaurante que vende pero no gana</span>
                  <span class="header-dropdown__desc">Costos desordenados, margen invisible</span>
                </a>
              </li>
              <li>
                <a href="/autonomia" class="header-dropdown__link">
                  <span class="header-dropdown__label">Dependencia total del dueño</span>
                  <span class="header-dropdown__desc">El negocio para cuando tú paras</span>
                </a>
              </li>
              <li>
                <a href="/ventas-delivery" class="header-dropdown__link">
                  <span class="header-dropdown__label">Ventas estancadas y delivery</span>
                  <span class="header-dropdown__desc">Plataformas que no convierten</span>
                </a>
              </li>
              <li>
                <a href="/personal" class="header-dropdown__link">
                  <span class="header-dropdown__label">Crisis de personal y rotación</span>
                  <span class="header-dropdown__desc">Equipo inestable, servicio inconsistente</span>
                </a>
              </li>
              <li>
                <a href="/metricas-control" class="header-dropdown__link">
                  <span class="header-dropdown__label">Sin números ni control</span>
                  <span class="header-dropdown__desc">Decisiones a ciegas, sin reportes</span>
                </a>
              </li>
              <li>
                <a href="/crecimiento-controlado" class="header-dropdown__link">
                  <span class="header-dropdown__label">Crecer sin reventar</span>
                  <span class="header-dropdown__desc">Escalar con estructura y sin caos</span>
                </a>
              </li>
            </ul>
          </div>
        </li>

        <li class="header-nav__item">
          <a href="/casos-de-exito" class="header-nav__link">Casos</a>
        </li>
        <li class="header-nav__item">
          <a href="/sobre-efer" class="header-nav__link">Sobre Efer</a>
        </li>
        <li class="header-nav__item">
          <a href="/blog" class="header-nav__link">Blog</a>
        </li>
      </ul>

      {/* CTA de conversión dentro del panel móvil (M3) — oculto en desktop vía CSS */}
      <div class="header-mobile-cta">
        <a
          href="/auditoria"
          class="header-mobile-cta__primary"
          data-cta="header-mobile-primary"
        >
          Solicitar auditoría
        </a>
        <a
          href={waMenuUrl}
          class="header-mobile-cta__wa"
          data-cta="header-mobile-wa"
          target="_blank"
          rel="noopener"
        >
          <Icon name="whatsapp" size={18} />
          <span>WhatsApp directo</span>
        </a>
      </div>
    </nav>

    <!-- CTA sticky desktop -->
    <a href="/auditoria" class="header-cta" data-cta="header-primary">
      Solicitar auditoría
    </a>

    <!-- Hamburguesa mobile -->
    <button
      class="header-hamburger"
      id={MENU_BTN_ID}
      aria-controls={NAV_ID}
      aria-expanded="false"
      aria-label="Abrir menú"
      type="button"
    >
      <span class="header-hamburger__bar"></span>
      <span class="header-hamburger__bar"></span>
      <span class="header-hamburger__bar"></span>
    </button>

  </div>
</header>

<!-- Mobile overlay backdrop -->
<div class="mobile-backdrop" id="mobile-backdrop" aria-hidden="true"></div>

<script>
  const header = document.getElementById('site-header')!;
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const nav = document.getElementById('site-nav')!;
  const backdrop = document.getElementById('mobile-backdrop')!;
  const dropdownBtn = header.querySelector<HTMLButtonElement>('.header-nav__dropdown-btn')!;
  const dropdown = document.getElementById('servicios-dropdown')!;

  // En mobile, la nav se oculta visualmente pero sigue siendo accesible por teclado.
  // `inert` la elimina del árbol de accesibilidad y del tab order cuando está cerrada.
  // M21: el breakpoint de navegación es único (--bp-nav, definido en :root abajo). El JS lo
  // lee del token para que JS y CSS nunca diverjan; el @media usa el literal (las media
  // queries no pueden consumir custom properties). Fallback a 820px si el token no resuelve.
  const navBp = getComputedStyle(document.documentElement)
    .getPropertyValue('--bp-nav').trim() || '820px';
  const mobileQuery = window.matchMedia(`(max-width: ${navBp})`);
  function syncNavInert(): void {
    if (mobileQuery.matches && !nav.classList.contains('is-open')) {
      nav.setAttribute('inert', '');
    } else {
      nav.removeAttribute('inert');
    }
  }
  mobileQuery.addEventListener('change', syncNavInert);
  syncNavInert();

  // ── Sticky shrink al scroll (CSS-driven via data attribute) ──────────────
  const observer = new IntersectionObserver(
    ([entry]) => {
      header.dataset.scrolled = entry.isIntersecting ? 'false' : 'true';
    },
    { rootMargin: '-1px 0px 0px 0px', threshold: 0 },
  );
  // Sentinel element para detectar scroll
  const sentinel = document.createElement('div');
  sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
  document.body.prepend(sentinel);
  observer.observe(sentinel);

  // ── Hamburguesa mobile ───────────────────────────────────────────────────
  function openMenu() {
    nav.removeAttribute('inert');
    nav.classList.add('is-open');
    backdrop.classList.add('is-visible');
    menuBtn.setAttribute('aria-expanded', 'true');
    menuBtn.setAttribute('aria-label', 'Cerrar menú');
    menuBtn.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    nav.classList.remove('is-open');
    backdrop.classList.remove('is-visible');
    menuBtn.setAttribute('aria-expanded', 'false');
    menuBtn.setAttribute('aria-label', 'Abrir menú');
    menuBtn.classList.remove('is-open');
    document.body.style.overflow = '';
    if (mobileQuery.matches) nav.setAttribute('inert', '');
    // Cerrar dropdown si estaba abierto
    closeDropdown();
    // Devolver el foco al disparador (igual que CookieBanner) — WCAG 2.4.3.
    menuBtn.focus();
  }

  menuBtn.addEventListener('click', () => {
    const isOpen = nav.classList.contains('is-open');
    isOpen ? closeMenu() : openMenu();
  });

  backdrop.addEventListener('click', closeMenu);

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (nav.classList.contains('is-open')) closeMenu();
      if (dropdown.classList.contains('is-open')) closeDropdown();
    }
  });

  // ── Dropdown Servicios (desktop) ──────────────────────────────────────────
  function openDropdown() {
    dropdown.classList.add('is-open');
    dropdownBtn.setAttribute('aria-expanded', 'true');
    dropdownBtn.classList.add('is-active');
  }

  function closeDropdown() {
    dropdown.classList.remove('is-open');
    dropdownBtn.setAttribute('aria-expanded', 'false');
    dropdownBtn.classList.remove('is-active');
  }

  dropdownBtn.addEventListener('click', () => {
    const isOpen = dropdown.classList.contains('is-open');
    isOpen ? closeDropdown() : openDropdown();
  });

  // Cerrar dropdown al clickear fuera
  document.addEventListener('click', (e) => {
    const target = e.target as Element;
    if (!header.contains(target)) closeDropdown();
  });

  // Focus trap básico: cerrar al perder foco del dropdown container
  dropdown.addEventListener('focusout', (e) => {
    const relatedTarget = (e as FocusEvent).relatedTarget as Element | null;
    if (!dropdown.contains(relatedTarget) && !dropdownBtn.contains(relatedTarget)) {
      closeDropdown();
    }
  });
</script>

<style>
  /* ── Base ──────────────────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-dark-1);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 1px 0 rgba(0,0,0,0.15);
    transition: background 0.2s, box-shadow 0.2s, border-color 0.2s, padding 0.2s;
  }

  /* Scrolled state — shrink + elevación */
  .site-header[data-scrolled="true"] {
    background: rgba(0, 51, 102, 0.97);
    border-bottom-color: rgba(255,255,255,0.08);
    box-shadow: 0 2px 20px rgba(0,0,0,0.35);
  }

  .header-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--space-6);
    height: 4rem;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    transition: height 0.2s;
  }

  .site-header[data-scrolled="true"] .header-inner {
    height: 3.25rem;
  }

  /* ── Logo ────────────────────────────────────────────────────────────────── */
  .header-logo {
    text-decoration: none;
    flex-shrink: 0;
  }
  .header-logo__img {
    height: clamp(28px, 2.5vw, 36px);
    width: auto;
    display: block;
    transition: filter 0.15s;
  }
  .site-header[data-scrolled="true"] .header-logo__img {
    height: clamp(22px, 2vw, 28px);
  }
  .header-logo:hover .header-logo__img {
    filter: brightness(1.15);
  }

  /* ── Nav desktop ─────────────────────────────────────────────────────────── */
  .header-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .header-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }
  .header-nav__item {
    position: relative;
  }
  .header-nav__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-subheading);
    font-size: clamp(0.875rem, 0.84rem + 0.15vw, 1rem);
    font-weight: 600;
    color: var(--color-neutral-300);
    text-decoration: none;
    border-radius: var(--radius-2);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
  }
  .header-nav__link:hover,
  .header-nav__link.is-active {
    color: #fff;
    background: rgba(255,255,255,0.07);
  }

  /* Chevron Servicios */
  .header-nav__chevron {
    width: 0.65rem;
    height: 0.65rem;
    transition: transform 0.18s;
  }
  .header-nav__dropdown-btn.is-active .header-nav__chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown mega-menú ──────────────────────────────────────────────────── */
  .header-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 22rem;
    background: var(--color-dark-4);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-3);
    box-shadow: 0 12px 40px rgba(0,0,0,0.45);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s, transform 0.18s, visibility 0s 0.18s;
    transform-origin: top center;
    z-index: 200;
  }
  .header-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
    transition: opacity 0.18s, transform 0.18s;
  }
  .header-dropdown__list {
    list-style: none;
    margin: 0;
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .header-dropdown__link {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-2);
    text-decoration: none;
    transition: background 0.15s;
  }
  .header-dropdown__link:hover {
    background: rgba(255,255,255,0.06);
  }
  .header-dropdown__label {
    font-family: var(--font-subheading);
    font-size: clamp(0.875rem, 0.84rem + 0.15vw, 1rem);
    font-weight: 600;
    color: #fff;
    line-height: var(--line-snug);
  }
  .header-dropdown__desc {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    color: var(--color-neutral-300);
    line-height: var(--line-snug);
  }

  /* ── CTA sticky desktop ──────────────────────────────────────────────────── */
  .header-cta {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background: var(--color-accent);
    color: var(--color-accent-ink);
    font-family: var(--font-subheading);
    font-weight: 700;
    font-size: clamp(0.8rem, 0.76rem + 0.15vw, 0.9375rem);
    border-radius: var(--radius-pill, 999px);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: filter 0.15s;
    margin-left: auto;
  }
  .header-cta:hover {
    filter: brightness(1.08);
    color: var(--color-accent-ink);
  }

  /* CTA del panel móvil — solo se muestra dentro del menú hamburguesa (media query) */
  .header-mobile-cta { display: none; }

  /* ── Hamburguesa ─────────────────────────────────────────────────────────── */
  .header-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 2.75rem;
    height: 2.75rem;
    background: none;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-2);
    cursor: pointer;
    flex-shrink: 0;
    margin-left: auto;
    padding: 0;
  }
  .header-hamburger__bar {
    display: block;
    width: 1.25rem;
    height: 2px;
    background: var(--color-neutral-300);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.22s, opacity 0.22s, background 0.15s;
  }
  .header-hamburger.is-open .header-hamburger__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background: #fff;
  }
  .header-hamburger.is-open .header-hamburger__bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .header-hamburger.is-open .header-hamburger__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background: #fff;
  }

  /* ── Mobile backdrop ─────────────────────────────────────────────────────── */
  .mobile-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 99;
    opacity: 0;
    transition: opacity 0.22s;
  }
  .mobile-backdrop.is-visible {
    opacity: 1;
  }

  /* ── Mobile breakpoint ─────────────────────────────────────────────────────
     M21: --bp-nav es la ÚNICA fuente de verdad del breakpoint de navegación/layout.
     Lo consume el JS de este componente (matchMedia) y lo refleja Hero.astro (2 col a
     partir de 821px). Las @media no pueden leer var(--bp-nav), por eso el literal 820px
     es el espejo del token. Si cambias el valor, cámbialo en :global(:root) y aquí. */
  :global(:root) { --bp-nav: 820px; }

  @media (max-width: 820px) { /* = --bp-nav */
    .header-hamburger { display: flex; }
    .header-cta { display: none; }

    .header-nav {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(20rem, 85vw);
      background: var(--color-dark-4);
      flex-direction: column;
      justify-content: flex-start;
      align-items: stretch;
      padding: var(--space-7) var(--space-5) var(--space-8);
      transform: translateX(100%);
      transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
      z-index: 101;
      border-left: 1px solid rgba(255,255,255,0.08);
    }
    .header-nav.is-open {
      transform: translateX(0);
    }
    .mobile-backdrop { display: block; }

    .header-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }
    .header-nav__item { position: static; }
    .header-nav__link {
      font-size: 1rem;
      padding: var(--space-4) var(--space-3);
      border-radius: var(--radius-2);
      width: 100%;
      justify-content: space-between;
      color: var(--color-neutral-300);
    }
    .header-nav__link:hover { color: #fff; background: rgba(255,255,255,0.06); }

    /* Dropdown mobile — lista inline sin mega-menú */
    .header-dropdown {
      position: static;
      transform: none;
      min-width: 0;
      width: 100%;
      opacity: 1;
      visibility: hidden;
      pointer-events: none;
      box-shadow: none;
      border: none;
      border-radius: 0;
      background: rgba(255,255,255,0.04);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.28s ease, visibility 0s 0.28s;
    }
    .header-dropdown.is-open {
      visibility: visible;
      pointer-events: auto;
      max-height: 40rem;
      transition: max-height 0.32s ease;
    }
    .header-dropdown__list {
      padding: var(--space-2) var(--space-3) var(--space-3);
    }
    .header-dropdown__link {
      padding: var(--space-3);
    }
    .header-dropdown__desc { display: none; }

    /* CTA de conversión anclado al final del panel móvil (M3) */
    .header-mobile-cta {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      margin-top: auto;
      padding-top: var(--space-6);
    }
    .header-mobile-cta__primary {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: var(--touch-target, 44px);
      padding: var(--space-3) var(--space-5);
      background: var(--color-accent);
      color: var(--color-accent-ink);
      font-family: var(--font-subheading);
      font-weight: 700;
      font-size: 1rem;
      border-radius: var(--radius-pill, 999px);
      text-decoration: none;
      transition: filter 0.15s;
    }
    .header-mobile-cta__primary:hover,
    .header-mobile-cta__primary:focus-visible {
      filter: brightness(1.08);
      color: var(--color-accent-ink);
    }
    .header-mobile-cta__wa {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      min-height: var(--touch-target, 44px);
      padding: var(--space-2) var(--space-4);
      color: var(--color-neutral-300);
      font-family: var(--font-subheading);
      font-weight: 600;
      font-size: 0.9375rem;
      text-decoration: none;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: var(--radius-pill, 999px);
      transition: color 0.15s, border-color 0.15s, background 0.15s;
    }
    .header-mobile-cta__wa:hover,
    .header-mobile-cta__wa:focus-visible {
      color: #fff;
      border-color: rgba(255,255,255,0.35);
      background: rgba(255,255,255,0.06);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .header-inner,
    .header-logo__img,
    .header-nav__link,
    .header-nav__chevron,
    .header-dropdown,
    .header-cta,
    .header-mobile-cta__primary,
    .header-mobile-cta__wa,
    .header-hamburger__bar,
    .header-nav,
    .mobile-backdrop { transition: none; }
  }
</style>
