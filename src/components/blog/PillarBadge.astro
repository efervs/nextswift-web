---
/**
 * PillarBadge — pill compacta con label del pillar.
 * Toma color por modificador CSS (sin tokens dinámicos para no inflar runtime).
 */
import { getPillarMeta } from '../../data/blog-pillars';
import type { Pillar } from '../../content.config';

interface Props {
  pillar: Pillar;
  size?: 'sm' | 'md';
  class?: string;
}

const { pillar, size = 'md', class: className = '' } = Astro.props;
const meta = getPillarMeta(pillar);
---

<span
  class:list={['pillar-badge', `pillar-badge--${pillar}`, `pillar-badge--${size}`, className]}
  data-pillar={pillar}
  data-pagefind-meta={`pillar:${meta.short}`}
>
  {meta.short}
</span>

<style>
  .pillar-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-subheading);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: var(--color-surface-alt);
    color: var(--color-text);
    white-space: nowrap;
    line-height: 1.4;
  }
  .pillar-badge--sm { font-size: 0.6875rem; padding: 0.15rem 0.5rem; }
  .pillar-badge--md { font-size: 0.8125rem; padding: 0.25rem 0.625rem; }

  .pillar-badge--utilidad,
  .pillar-badge--ventas-delivery {
    background: var(--color-accent);
    color: var(--color-accent-ink);
    border-color: transparent;
  }
  .pillar-badge--autonomia,
  .pillar-badge--personal {
    background: var(--color-dark-1);
    color: var(--color-text-on-dark);
    border-color: transparent;
  }
  .pillar-badge--metricas-control,
  .pillar-badge--crecimiento-controlado {
    background: transparent;
    color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
  }
  .pillar-badge--transversal {
    background: transparent;
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }
</style>
