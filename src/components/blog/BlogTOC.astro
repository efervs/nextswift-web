---
/**
 * BlogTOC — Tabla de contenidos derivada de los headings H2/H3.
 * variant="mobile" → <details> colapsable al inicio del contenido.
 * variant="desktop" → aside sticky en columna lateral.
 * Render externo decide qué variante usar y dónde colocarla en el layout.
 */
import type { TocHeading } from '../../lib/blog-helpers';

interface Props {
  headings: TocHeading[];
  variant: 'mobile' | 'desktop';
}

const { headings, variant } = Astro.props;
---

{variant === 'mobile' && (
  <details class="blog-toc blog-toc--mobile" data-pagefind-ignore>
    <summary>Tabla de contenidos</summary>
    <nav aria-label="Tabla de contenidos">
      <ol>
        {headings.map((h) => (
          <li class={`toc-depth-${h.depth}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  </details>
)}

{variant === 'desktop' && (
  <aside class="blog-toc blog-toc--desktop" aria-label="Tabla de contenidos" data-pagefind-ignore>
    <p class="blog-toc__heading">En este artículo</p>
    <ol>
      {headings.map((h) => (
        <li class={`toc-depth-${h.depth}`}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
  </aside>
)}

<style>
  .blog-toc ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .blog-toc a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .blog-toc a:hover { color: var(--color-primary-dark); }
  .toc-depth-3 a { padding-inline-start: var(--space-4); font-size: 0.8125rem; }

  .blog-toc--mobile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-alt);
  }
  .blog-toc--mobile summary {
    font-family: var(--font-subheading);
    font-weight: 600;
    cursor: pointer;
    list-style: none;
  }
  .blog-toc--mobile summary::-webkit-details-marker { display: none; }
  .blog-toc--mobile[open] summary { margin-block-end: var(--space-3); }
  @media (min-width: 1024px) {
    .blog-toc--mobile { display: none; }
  }

  .blog-toc--desktop {
    position: sticky;
    top: var(--space-5);
    max-height: calc(100vh - var(--space-9));
    overflow-y: auto;
  }
  .blog-toc__heading {
    font-family: var(--font-subheading);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3) 0;
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.blog-toc a[href^="#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      const id = a.getAttribute('href')?.slice(1);
      if (!id) return;
      const el = document.getElementById(id);
      if (!el) return;
      e.preventDefault();
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      history.replaceState(null, '', `#${id}`);
    });
  });
</script>
