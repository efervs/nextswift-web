---
/**
 * CookieBanner — Consent manager LFPDPPP-compliant.
 * Checks localStorage['cookieConsent'] on load:
 *   - undefined → shows banner (first visit)
 *   - 'all'       → fires window.__ns_loadTracking() (called from Base.astro)
 *   - 'necessary' → no tracking
 * NO dark patterns: reject is as visible as accept.
 */
---

<div
  id="cookie-banner"
  class="cookie-banner"
  role="dialog"
  aria-modal="true"
  aria-label="Preferencias de cookies"
  aria-describedby="cookie-banner-desc"
  hidden
>
  <div class="cookie-banner__inner">
    <!-- Main panel -->
    <div id="cookie-main" class="cookie-panel">
      <p class="cookie-banner__title">Este sitio usa cookies</p>
      <p id="cookie-banner-desc" class="cookie-banner__desc">
        Usamos cookies necesarias para que el sitio funcione y, con tu permiso, cookies de análisis
        y marketing (Meta Pixel, Google Analytics). Puedes aceptar todo, elegir solo las necesarias
        o personalizar tu elección. Ver <a href="/legales/aviso-de-privacidad" target="_blank" rel="noopener" class="cookie-banner__link">Aviso de Privacidad</a>.
      </p>
      <div class="cookie-banner__actions">
        <button id="cookie-necessary" class="cookie-btn cookie-btn--secondary" type="button">
          Solo necesarias
        </button>
        <button id="cookie-configure" class="cookie-btn cookie-btn--secondary" type="button">
          Configurar
        </button>
        <button id="cookie-accept-all" class="cookie-btn cookie-btn--primary" type="button">
          Aceptar todas
        </button>
      </div>
    </div>

    <!-- Configure panel (hidden by default) -->
    <div id="cookie-config-panel" class="cookie-panel" hidden>
      <p class="cookie-banner__title">Configurar preferencias</p>

      <div class="cookie-toggle-group">
        <label class="cookie-toggle">
          <span class="cookie-toggle__info">
            <strong>Necesarias</strong>
            <span class="cookie-toggle__desc">Requeridas para el funcionamiento del sitio. No se pueden desactivar.</span>
          </span>
          <input type="checkbox" checked disabled aria-label="Cookies necesarias (siempre activas)" />
          <span class="cookie-toggle__slider cookie-toggle__slider--locked" aria-hidden="true"></span>
        </label>

        <label class="cookie-toggle" id="analytics-toggle-row">
          <span class="cookie-toggle__info">
            <strong>Análisis y marketing</strong>
            <span class="cookie-toggle__desc">Meta Pixel, Google Analytics. Nos ayudan a medir el tráfico y mejorar el sitio.</span>
          </span>
          <input type="checkbox" id="cookie-analytics-toggle" aria-label="Cookies de análisis y marketing" />
          <span class="cookie-toggle__slider" aria-hidden="true"></span>
        </label>
      </div>

      <div class="cookie-banner__actions">
        <button id="cookie-config-back" class="cookie-btn cookie-btn--ghost" type="button">
          ← Atrás
        </button>
        <button id="cookie-config-save" class="cookie-btn cookie-btn--primary" type="button">
          Guardar preferencias
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'cookieConsent';

  const banner = document.getElementById('cookie-banner');
  const mainPanel = document.getElementById('cookie-main');
  const configPanel = document.getElementById('cookie-config-panel');
  const analyticsToggle = document.getElementById('cookie-analytics-toggle') as HTMLInputElement | null;

  function getConsent(): string | null {
    try { return localStorage.getItem(STORAGE_KEY); } catch { return null; }
  }

  function setConsent(value: 'all' | 'necessary'): void {
    try { localStorage.setItem(STORAGE_KEY, value); } catch { /* private mode */ }
  }

  function hideBanner(): void {
    if (!banner) return;
    banner.hidden = true;
    banner.removeAttribute('aria-modal');
  }

  function showBanner(): void {
    if (!banner) return;
    banner.hidden = false;
  }

  function activateTracking(): void {
    if (typeof (window as unknown as { __ns_loadTracking?: () => void }).__ns_loadTracking === 'function') {
      (window as unknown as { __ns_loadTracking: () => void }).__ns_loadTracking();
    }
  }

  function acceptAll(): void {
    setConsent('all');
    activateTracking();
    hideBanner();
  }

  function acceptNecessary(): void {
    setConsent('necessary');
    hideBanner();
  }

  function saveConfig(): void {
    const wantsAnalytics = analyticsToggle?.checked ?? false;
    if (wantsAnalytics) {
      acceptAll();
    } else {
      acceptNecessary();
    }
  }

  function showConfig(): void {
    if (!mainPanel || !configPanel) return;
    mainPanel.hidden = true;
    configPanel.hidden = false;
    if (analyticsToggle) {
      analyticsToggle.checked = getConsent() === 'all';
    }
  }

  function showMain(): void {
    if (!mainPanel || !configPanel) return;
    configPanel.hidden = true;
    mainPanel.hidden = false;
  }

  // Init: show banner only on first visit
  const existing = getConsent();
  if (!existing) {
    showBanner();
  } else if (existing === 'all') {
    activateTracking();
  }

  document.getElementById('cookie-accept-all')?.addEventListener('click', acceptAll);
  document.getElementById('cookie-necessary')?.addEventListener('click', acceptNecessary);
  document.getElementById('cookie-configure')?.addEventListener('click', showConfig);
  document.getElementById('cookie-config-back')?.addEventListener('click', showMain);
  document.getElementById('cookie-config-save')?.addEventListener('click', saveConfig);

  // Expose reset function for preferences link (future use)
  (window as unknown as { __ns_resetConsent?: () => void }).__ns_resetConsent = function () {
    try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }
    showMain();
    showBanner();
  };
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: var(--color-dark-1, #001a33);
    color: #fff;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.35);
    border-top: 2px solid var(--color-accent, #f4a822);
  }

  .cookie-banner__inner {
    max-width: var(--content-max, 1200px);
    margin-inline: auto;
    padding: var(--space-5, 1.25rem) var(--space-6, 1.5rem);
  }

  .cookie-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-4, 1rem);
  }

  .cookie-banner__title {
    font-family: var(--font-subheading, sans-serif);
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }

  .cookie-banner__desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-neutral-300, #b0b8c4);
    margin: 0;
    max-width: 70ch;
  }

  .cookie-banner__link {
    color: var(--color-accent, #f4a822);
    text-decoration: underline;
  }

  .cookie-banner__link:hover {
    opacity: 0.85;
  }

  .cookie-banner__actions {
    display: flex;
    gap: var(--space-3, 0.75rem);
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Buttons — equal visual weight, no dark patterns ─────────────────────── */
  .cookie-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-3, 6px);
    font-family: var(--font-subheading, sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    min-height: 40px;
    border: 2px solid transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .cookie-btn--primary {
    background: var(--color-accent, #f4a822);
    color: #001a33;
    border-color: var(--color-accent, #f4a822);
  }

  .cookie-btn--primary:hover {
    filter: brightness(1.08);
  }

  /* Reject / necessary — same size, bordered, clearly visible */
  .cookie-btn--secondary {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .cookie-btn--secondary:hover {
    border-color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.06);
  }

  .cookie-btn--ghost {
    background: transparent;
    color: var(--color-neutral-300, #b0b8c4);
    border-color: transparent;
    padding-left: 0;
  }

  .cookie-btn--ghost:hover {
    color: #fff;
  }

  /* ── Toggle group ─────────────────────────────────────────────────────────── */
  .cookie-toggle-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4, 1rem);
  }

  .cookie-toggle {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4, 1rem);
    cursor: pointer;
  }

  .cookie-toggle input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .cookie-toggle__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .cookie-toggle__info strong {
    font-size: 0.9rem;
    color: #fff;
  }

  .cookie-toggle__desc {
    font-size: 0.8rem;
    color: var(--color-neutral-300, #b0b8c4);
    line-height: 1.4;
  }

  /* Custom toggle switch */
  .cookie-toggle__slider {
    flex-shrink: 0;
    width: 44px;
    height: 24px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
    border: 2px solid rgba(255, 255, 255, 0.3);
    position: relative;
    transition: background 0.2s, border-color 0.2s;
    margin-top: 2px;
  }

  .cookie-toggle__slider::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.2s;
  }

  .cookie-toggle__slider--locked {
    background: var(--color-accent, #f4a822);
    border-color: var(--color-accent, #f4a822);
    opacity: 0.7;
    cursor: not-allowed;
  }

  .cookie-toggle__slider--locked::after {
    transform: translateX(20px);
  }

  /* Toggle checked state */
  .cookie-toggle input:checked ~ .cookie-toggle__slider:not(.cookie-toggle__slider--locked) {
    background: var(--color-accent, #f4a822);
    border-color: var(--color-accent, #f4a822);
  }

  .cookie-toggle input:checked ~ .cookie-toggle__slider:not(.cookie-toggle__slider--locked)::after {
    transform: translateX(20px);
  }

  /* Focus visible on toggle */
  .cookie-toggle input:focus-visible ~ .cookie-toggle__slider {
    outline: 2px solid var(--color-accent, #f4a822);
    outline-offset: 2px;
  }

  /* ── Desktop: horizontal layout ──────────────────────────────────────────── */
  @media (min-width: 768px) {
    .cookie-panel:not(#cookie-config-panel) {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-6, 1.5rem);
    }

    .cookie-panel:not(#cookie-config-panel) .cookie-banner__title {
      white-space: nowrap;
      align-self: flex-start;
      padding-top: 0.15rem;
    }

    .cookie-panel:not(#cookie-config-panel) .cookie-banner__desc {
      flex: 1;
    }

    .cookie-banner__actions {
      flex-shrink: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-btn,
    .cookie-toggle__slider,
    .cookie-toggle__slider::after { transition: none; }
  }
</style>
