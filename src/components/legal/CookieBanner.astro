---
// CookieBanner — notice bar informativo (modelo opt-out, LFPDPPP art. 8 pár. 2).
// Al cargar, acepta todo automáticamente si no hay preferencia guardada.
// Storage: localStorage['nx-consent'] = JSON { v:1, analytics:bool, marketing:bool }
// El usuario puede ajustar o revocar en cualquier momento con "Personalizar".
---

<!-- ── Notice bar informativo ────────────────────────────────────────────── -->
<div
  id="ns-cbar"
  class="ns-cbar"
  role="region"
  aria-label="Aviso de cookies"
  hidden
>
  <div class="ns-cbar__inner">
    <p class="ns-cbar__copy">
      Usamos cookies analíticas y de marketing para mejorar tu experiencia.
      Al navegar este sitio aceptas su uso.
      <a
        href="/legales/aviso-de-privacidad"
        class="ns-cbar__link"
        target="_blank"
        rel="noopener noreferrer"
      >Ver Aviso de Privacidad</a>.
    </p>
    <div class="ns-cbar__actions">
      <button id="ns-cbar-custom" class="ns-cb ns-cb--ghost" type="button">
        Personalizar
      </button>
      <button id="ns-cbar-dismiss" class="ns-cb ns-cb--icon" type="button" aria-label="Cerrar aviso">
        ✕
      </button>
    </div>
  </div>
</div>

<!-- ── Panel de preferencias (no backdrop bloqueante) ───────────────────── -->
<div
  id="ns-cpanel"
  class="ns-cpanel"
  role="dialog"
  aria-modal="true"
  aria-labelledby="ns-cpanel-title"
  hidden
>
  <div class="ns-cpanel__card">
    <h2 id="ns-cpanel-title" class="ns-cpanel__title">Preferencias de cookies</h2>

    <div class="ns-cpanel__rows">
      <!-- Funcionales: siempre ON -->
      <div class="ns-crow">
        <div class="ns-crow__info">
          <span class="ns-crow__name">Funcionales</span>
          <span class="ns-crow__desc">Necesarias para el sitio. Siempre activas.</span>
        </div>
        <span class="ns-sw ns-sw--on ns-sw--locked" role="img" aria-label="Siempre activas"></span>
      </div>

      <!-- Analíticas: opt-out -->
      <label class="ns-crow ns-crow--interactive">
        <div class="ns-crow__info">
          <span class="ns-crow__name">Analíticas</span>
          <span class="ns-crow__desc">Meta Pixel y Google Analytics.</span>
        </div>
        <input type="checkbox" id="ns-ck-analytics" class="ns-sw-input" aria-label="Cookies analíticas">
        <span class="ns-sw" aria-hidden="true"></span>
      </label>

      <!-- Marketing: opt-out -->
      <label class="ns-crow ns-crow--interactive">
        <div class="ns-crow__info">
          <span class="ns-crow__name">Marketing</span>
          <span class="ns-crow__desc">Pixel CAPI para anuncios relevantes.</span>
        </div>
        <input type="checkbox" id="ns-ck-marketing" class="ns-sw-input" aria-label="Cookies de marketing">
        <span class="ns-sw" aria-hidden="true"></span>
      </label>
    </div>

    <div class="ns-cpanel__actions">
      <button id="ns-cp-save" class="ns-cb ns-cb--ghost" type="button">
        Guardar selección
      </button>
      <button id="ns-cp-all" class="ns-cb ns-cb--primary" type="button">
        Aceptar todas
      </button>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = 'nx-consent';

  interface ConsentData {
    v: number;
    analytics: boolean;
    marketing: boolean;
  }

  function getConsent(): ConsentData | null {
    try {
      const raw = localStorage.getItem(CONSENT_KEY);
      if (!raw) return null;
      return JSON.parse(raw) as ConsentData;
    } catch {
      return null;
    }
  }

  function setConsent(analytics: boolean, marketing: boolean): void {
    try {
      localStorage.setItem(CONSENT_KEY, JSON.stringify({ v: 1, analytics, marketing }));
    } catch { /* modo privado */ }
  }

  function fireTracking(analytics: boolean): void {
    if (!analytics) return;
    const w = window as unknown as { __ns_loadTracking?: () => void };
    if (typeof w.__ns_loadTracking === 'function') w.__ns_loadTracking();
  }

  function dismissBar(): void {
    const bar = document.getElementById('ns-cbar');
    if (bar) bar.hidden = true;
  }

  function hideAll(): void {
    dismissBar();
    const panel = document.getElementById('ns-cpanel');
    if (panel) { panel.hidden = true; panel.setAttribute('aria-modal', 'false'); }
  }

  function openPanel(): void {
    const panel = document.getElementById('ns-cpanel');
    if (!panel) return;
    const c = getConsent();
    const analyticsEl = document.getElementById('ns-ck-analytics') as HTMLInputElement | null;
    const marketingEl = document.getElementById('ns-ck-marketing') as HTMLInputElement | null;
    if (analyticsEl) analyticsEl.checked = c?.analytics ?? true;
    if (marketingEl) marketingEl.checked = c?.marketing ?? true;
    panel.hidden = false;
    panel.setAttribute('aria-modal', 'true');
    (panel.querySelector('button') as HTMLButtonElement | null)?.focus();
  }

  function acceptAll(): void {
    setConsent(true, true);
    fireTracking(true);
    hideAll();
  }

  function saveSelection(): void {
    const analyticsEl = document.getElementById('ns-ck-analytics') as HTMLInputElement | null;
    const marketingEl = document.getElementById('ns-ck-marketing') as HTMLInputElement | null;
    const analytics = analyticsEl?.checked ?? false;
    const marketing = marketingEl?.checked ?? false;
    setConsent(analytics, marketing);
    fireTracking(analytics);
    hideAll();
  }

  document.addEventListener('keydown', (e) => {
    const panel = document.getElementById('ns-cpanel');
    if (e.key === 'Escape' && panel && !panel.hidden) {
      panel.hidden = true;
      panel.setAttribute('aria-modal', 'false');
      (document.getElementById('ns-cbar-custom') as HTMLButtonElement | null)?.focus();
    }
  });

  // ── Init: auto-accept en primera visita (modelo opt-out LFPDPPP) ──────────
  const existing = getConsent();
  if (!existing) {
    // Primera visita: acepta todo automáticamente y muestra aviso informativo
    setConsent(true, true);
    fireTracking(true);
    const bar = document.getElementById('ns-cbar');
    if (bar) bar.hidden = false;
  } else if (existing.analytics) {
    fireTracking(true);
  }

  document.getElementById('ns-cbar-dismiss')?.addEventListener('click', dismissBar);
  document.getElementById('ns-cbar-custom')?.addEventListener('click', openPanel);
  document.getElementById('ns-cp-all')?.addEventListener('click', acceptAll);
  document.getElementById('ns-cp-save')?.addEventListener('click', saveSelection);

  (window as unknown as { __ns_resetConsent?: () => void }).__ns_resetConsent = () => {
    try { localStorage.removeItem(CONSENT_KEY); } catch { /* noop */ }
    const bar = document.getElementById('ns-cbar');
    if (bar) bar.hidden = false;
  };
</script>

<style>
  /* ── Bar slim ────────────────────────────────────────────────────────────── */
  .ns-cbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--color-dark-4, #233043);
    color: #fff;
    box-shadow: 0 -2px 16px rgba(0, 0, 0, 0.4);
    border-top: 2px solid var(--color-accent, #3eeaf3);
  }

  .ns-cbar__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 1200px;
    margin-inline: auto;
    padding: 0.5rem 1.25rem;
    min-height: 4rem; /* 64px */
  }

  .ns-cbar__copy {
    flex: 1;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-neutral-200, #d0d8e4);
    margin: 0;
  }

  .ns-cbar__link {
    color: var(--color-accent, #3eeaf3);
    text-underline-offset: 2px;
  }
  .ns-cbar__link:hover { opacity: 0.85; }

  .ns-cbar__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* ── Buttons ─────────────────────────────────────────────────────────────── */
  .ns-cb {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0 1.375rem;
    font-family: var(--font-subheading, sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: var(--radius-3, 6px);
    border: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1;
  }

  .ns-cb--primary {
    background: var(--color-accent, #3eeaf3);
    color: var(--color-accent-ink, #003366);
    border-color: var(--color-accent, #3eeaf3);
  }
  .ns-cb--primary:hover { filter: brightness(1.08); }
  .ns-cb--primary:active { transform: translateY(1px); }

  .ns-cb--ghost {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.35);
  }
  .ns-cb--ghost:hover {
    border-color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.07);
  }

  /* × dismiss icon button */
  .ns-cb--icon {
    background: transparent;
    color: rgba(255, 255, 255, 0.55);
    border-color: transparent;
    padding: 0 0.5rem;
    min-height: 2.5rem;
    font-size: 1rem;
  }
  .ns-cb--icon:hover { color: #fff; }

  .ns-cb:focus-visible {
    outline: 3px solid var(--color-accent, #3eeaf3);
    outline-offset: 2px;
  }

  /* ── Preferences panel ──────────────────────────────────────────────────── */
  .ns-cpanel {
    position: fixed;
    bottom: 5rem;
    left: 50%;
    transform: translateX(-50%);
    width: min(440px, calc(100vw - 2rem));
    z-index: 1001;
    background: var(--color-dark-4, #233043);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 12px;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.55);
    padding: 1.25rem;
  }

  .ns-cpanel__title {
    font-family: var(--font-subheading, sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
  }

  .ns-cpanel__rows {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin-bottom: 1.125rem;
  }

  .ns-cpanel__actions {
    display: flex;
    gap: 0.625rem;
    justify-content: flex-end;
  }

  .ns-cpanel__actions .ns-cb {
    min-height: 2.5rem;
    font-size: 0.875rem;
    padding: 0 1.125rem;
  }

  /* ── Cookie row ─────────────────────────────────────────────────────────── */
  .ns-crow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .ns-crow:last-child { border-bottom: none; }
  .ns-crow--interactive { cursor: pointer; }
  .ns-crow--interactive:hover .ns-crow__name { color: var(--color-accent, #3eeaf3); }

  .ns-crow__info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .ns-crow__name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    transition: color 0.15s;
  }

  .ns-crow__desc {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.3;
  }

  /* ── Toggle switch ──────────────────────────────────────────────────────── */
  .ns-sw-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .ns-sw {
    display: block;
    flex-shrink: 0;
    width: 42px;
    height: 24px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.2);
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    position: relative;
    transition: background 0.2s, border-color 0.2s;
  }

  .ns-sw::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.2s;
  }

  .ns-sw-input:checked ~ .ns-sw {
    background: var(--color-accent, #3eeaf3);
    border-color: var(--color-accent, #3eeaf3);
  }
  .ns-sw-input:checked ~ .ns-sw::after { transform: translateX(18px); }

  .ns-sw-input:focus-visible ~ .ns-sw {
    outline: 3px solid var(--color-accent, #3eeaf3);
    outline-offset: 2px;
  }

  .ns-sw--on {
    background: var(--color-accent, #3eeaf3);
    border-color: var(--color-accent, #3eeaf3);
  }
  .ns-sw--on::after { transform: translateX(18px); }
  .ns-sw--locked { opacity: 0.6; cursor: not-allowed; }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .ns-cbar__inner {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      padding: 0.625rem 1rem;
      min-height: unset;
    }

    .ns-cbar__copy { font-size: 0.8125rem; }

    .ns-cbar__actions { justify-content: flex-end; }

    .ns-cbar__actions .ns-cb {
      min-height: 2.5rem;
      font-size: 0.875rem;
      padding: 0 1rem;
    }

    .ns-cpanel {
      bottom: 0;
      left: 0;
      right: 0;
      transform: none;
      width: 100%;
      border-radius: 12px 12px 0 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ns-cb, .ns-sw, .ns-sw::after, .ns-crow__name { transition: none; }
  }
</style>
