---
/**
 * ProofBar — métrica agregada Beaudoin + 5 logos autorizados.
 * Datos: project_casos_prueba_social.md (validado con Efer 2026-05-12).
 * Hare Krishna marcado `data-pending-auth` hasta cierre formal de DH-NEW-01.
 */
interface Logo {
  src: string;
  alt: string;
  pendingAuth?: boolean;
}

interface Props {
  metricaAgregada?: string;
  contexto?: string;
  logos?: Logo[];
}

const {
  metricaAgregada = '+42% margen delivery · $0 → $300k/mes en arranque · 4.4 → 4.6★ en <2 meses',
  contexto = 'en 3 de 5 restaurantes acompañados por NextSwift',
  logos = [
    { src: '/images/logos/pangas.webp', alt: 'Pangas Sabores del Mar' },
    { src: '/images/logos/temaky.webp', alt: 'Temaky Sushi' },
    { src: '/images/logos/oita-fresh.webp', alt: 'Oita Fresh' },
    { src: '/images/logos/sr-boneless.webp', alt: 'Sr. Boneless' },
    { src: '/images/logos/hare-krishna.webp', alt: 'Hare Krishna', pendingAuth: true },
  ],
} = Astro.props;
---

<aside class="proof-bar" aria-label="Resultados verificables en restaurantes acompañados">
  <p class="proof-bar__metric">
    <strong>{metricaAgregada}</strong>
    <span class="proof-bar__context">— {contexto}</span>
  </p>
  {logos.length > 0 && (
    <ul class="proof-bar__logos" role="list">
      {logos.map((l) => (
        <li class="proof-bar__logo-item" data-pending-auth={l.pendingAuth ? 'true' : undefined}>
          <img
            src={l.src}
            alt={l.alt}
            loading="lazy"
            decoding="async"
            width="120"
            height="60"
            class="proof-bar__logo"
          />
        </li>
      ))}
    </ul>
  )}
</aside>

<style>
  .proof-bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-7) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .proof-bar__metric {
    margin: 0;
    font-family: var(--font-subheading);
    font-size: var(--fs-body);
    line-height: var(--line-snug);
    color: var(--color-text);
    text-align: center;
  }

  .proof-bar__metric strong {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-dark-1);
    font-size: clamp(1rem, 0.92rem + 0.4vw, 1.25rem);
    display: block;
    margin-bottom: var(--space-2);
  }

  .proof-bar__context {
    color: var(--color-text-muted);
    font-size: 0.95em;
  }

  .proof-bar__logos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: var(--space-5);
    align-items: center;
    justify-items: center;
    max-width: var(--content-max);
    margin-inline: auto;
    width: 100%;
  }

  .proof-bar__logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3rem;
  }

  .proof-bar__logo {
    max-width: 100%;
    max-height: 3rem;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.75;
    transition: filter var(--dur-2) var(--ease-out), opacity var(--dur-2) var(--ease-out);
  }

  .proof-bar__logo-item:hover .proof-bar__logo,
  .proof-bar__logo-item:focus-within .proof-bar__logo {
    filter: grayscale(0);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .proof-bar__logo {
      transition: none;
    }
  }
</style>
