---
/**
 * ProofBar — barra ancla de 3 PROMESAS operativas del Acelerador (M16 plan_de_mejoras_v1).
 *
 * Contexto: el ProofBar legacy (P4: métrica agregada Beaudoin + 5 logos) quedó cubierto por
 * <SocialProof variant="agregada"/> + variant="logos". Este componente se reescribe con un
 * propósito nuevo y NO solapado: anclar, justo bajo el hero, las 3 PROMESAS del programa
 * (lo que el cliente RECIBE), frente a la PRUEBA social (lo que YA pasó: "+42% margen…").
 *
 * Por eso NO duplica la métrica agregada de SocialProof ni el mini-dashboard del hero:
 *   - dashboard hero  = prueba (+42% / 10 días al diagnóstico / 4.6★)
 *   - SocialProof      = prueba masiva ($0 → $300k/mes · 4.4 → 4.6★)
 *   - ProofBar (aquí)  = promesa (10 días · +3-7 pp · garantía firmada)
 *
 * Diseño: barra contenida, tono superficie-alt, 3 columnas equiespaciadas con divisores
 * (ícono pequeño + cifra .metric-md + label). Mobile: stack vertical de 3 filas. Alto < 100px
 * en desktop. Íconos SVG inline provisionales — M18 los centralizará en <Icon/>.
 */
type IconName = 'dias' | 'margen' | 'garantia';

interface Promesa {
  icon: IconName;
  metric: string;
  label: string;
}

interface Props {
  promesas?: Promesa[];
  ariaLabel?: string;
}

const {
  promesas = [
    { icon: 'dias',     metric: '10 días',  label: 'hábiles de implementación' },
    { icon: 'margen',   metric: '+3-7 pp',  label: 'de margen recuperado' },
    { icon: 'garantia', metric: 'Garantía', label: 'operativa firmada' },
  ],
  ariaLabel = 'Promesas operativas del Acelerador NextSwift',
} = Astro.props;
---

<aside class="proof-bar" aria-label={ariaLabel}>
  <ul class="proof-bar__list" role="list">
    {promesas.map((p: Promesa) => (
      <li class="proof-bar__item">
        <span class="proof-bar__icon" aria-hidden="true">
          {p.icon === 'dias' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <path d="M16 2v4M8 2v4M3 10h18" />
            </svg>
          )}
          {p.icon === 'margen' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
              <polyline points="16 7 22 7 22 13" />
            </svg>
          )}
          {p.icon === 'garantia' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              <path d="m9 12 2 2 4-4" />
            </svg>
          )}
        </span>
        <span class="proof-bar__text">
          <span class="proof-bar__metric metric-md">{p.metric}</span>
          <span class="proof-bar__label">{p.label}</span>
        </span>
      </li>
    ))}
  </ul>
</aside>

<style>
  /* Barra contenida (vive dentro del Section del hero, entre <Hero/> y la métrica agregada).
     Tono superficie-alt para diferenciarse del fondo blanco del hero sin gritar. */
  .proof-bar {
    margin-block: var(--space-2);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-4);
    box-shadow: var(--shadow-1);
    /* space-3 (no space-4): mantiene el alto < 100px desktop — criterio de verificación M16.
       Sigue siendo "compacto"; el contenido de cada columna ya ronda ~64px. */
    padding-block: var(--space-3);
    padding-inline: var(--space-4);
  }

  .proof-bar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr; /* mobile: 3 filas apiladas */
    gap: var(--space-3);
  }

  .proof-bar__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  /* Mobile: divisor superior entre filas (no en la primera). */
  .proof-bar__item + .proof-bar__item {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
  }

  .proof-bar__icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: var(--radius-2);
    /* Tinte accent: aporta el cyan de marca sin fallar contraste (el ícono es decorativo). */
    background: rgba(62, 234, 243, 0.14);
    color: var(--color-primary-dark);
  }

  .proof-bar__icon svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .proof-bar__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  /* .proof-bar__metric hereda tipografía de .metric-md (utilities.css / M15).
     Aquí solo se ajusta layout: line-height 1 (en vez de 1.1) para apretar el alto del bar. */
  .proof-bar__metric {
    display: block;
    line-height: 1;
  }

  .proof-bar__label {
    font-family: var(--font-subheading);
    font-size: 0.8125rem;
    line-height: var(--line-snug);
    /* dark-3 (no text-muted): pasa WCAG AA 4.5:1 sobre surface-alt (~7.7:1). */
    color: var(--color-dark-3);
  }

  /* Desktop: 3 columnas equiespaciadas con divisores verticales. */
  @media (min-width: 768px) {
    .proof-bar {
      padding-inline: var(--space-5);
    }

    .proof-bar__list {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      align-items: stretch;
    }

    .proof-bar__item {
      justify-content: center;
      padding-inline: var(--space-5);
    }

    .proof-bar__item + .proof-bar__item {
      border-top: 0;
      padding-top: 0;
      border-left: 1px solid var(--color-border);
    }
  }
</style>
