---
/**
 * ProofBar — barra ancla de 3 PROMESAS operativas del Acelerador (M16 plan_de_mejoras_v1).
 *
 * Contexto: el ProofBar legacy (P4: métrica agregada Beaudoin + 5 logos) quedó cubierto por
 * <SocialProof variant="agregada"/> + variant="logos". Este componente se reescribe con un
 * propósito nuevo y NO solapado: anclar, justo bajo el hero, las 3 PROMESAS del programa
 * (lo que el cliente RECIBE), frente a la PRUEBA social (lo que YA pasó: "+42% margen…").
 *
 * Por eso NO duplica la métrica agregada de SocialProof ni el mini-dashboard del hero:
 *   - dashboard hero  = prueba (+42% / 10 días al diagnóstico / 4.6★)
 *   - SocialProof      = prueba masiva ($0 → $300k/mes · 4.4 → 4.6★)
 *   - ProofBar (aquí)  = promesa (10 días · +3-7 pp · garantía firmada)
 *
 * Diseño: barra contenida, tono superficie-alt, 3 columnas equiespaciadas con divisores
 * (ícono pequeño + cifra + label). Mobile: stack vertical de 3 filas. Alto < 100px
 * en desktop. Íconos SVG inline provisionales — M18 los centralizará en <Icon/>.
 * M18 (TB-06): la cifra baja de .metric-md (big-number) a texto de apoyo (--fs-lead) para
 * no competir con el dispositivo-firma <MarginLeak/>; son promesas, no prueba.
 *
 * V4-07 (2026-07-11): la franja leía como 3 cards genéricas bordeadas (borde+sombra+radius
 * en el contenedor) -> refuerza el card-soup que v4 está matando. Se aplana a franja de
 * datos: el contenedor pierde borde/sombra/radius y queda acotado solo por hairlines
 * top/bottom (--color-border), sin elevación. La cifra pasa a --font-mono tabular +
 * --color-action y el label adopta el MISMO tratamiento que .hero__metric-label (uppercase,
 * --tracking-eyebrow) -> unifica el lenguaje "tablero de operador" entre Hero y ProofBar.
 * Las 3 promesas y su copy NO cambian.
 */
type IconName = 'dias' | 'margen' | 'garantia';

interface Promesa {
  icon: IconName;
  metric: string;
  label: string;
}

interface Props {
  promesas?: Promesa[];
  ariaLabel?: string;
}

const {
  promesas = [
    { icon: 'dias',     metric: '10 días',  label: 'hábiles de implementación' },
    { icon: 'margen',   metric: '+3-7 pp',  label: 'de margen recuperado' },
    { icon: 'garantia', metric: 'Garantía', label: 'operativa firmada' },
  ],
  ariaLabel = 'Promesas operativas del Acelerador NextSwift',
} = Astro.props;
---

<aside class="proof-bar" aria-label={ariaLabel}>
  <ul class="proof-bar__list" role="list">
    {promesas.map((p: Promesa) => (
      <li class="proof-bar__item">
        <span class="proof-bar__icon" aria-hidden="true">
          {p.icon === 'dias' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <path d="M16 2v4M8 2v4M3 10h18" />
            </svg>
          )}
          {p.icon === 'margen' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
              <polyline points="16 7 22 7 22 13" />
            </svg>
          )}
          {p.icon === 'garantia' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              <path d="m9 12 2 2 4-4" />
            </svg>
          )}
        </span>
        <span class="proof-bar__text">
          <span class="proof-bar__metric">{p.metric}</span>
          <span class="proof-bar__label">{p.label}</span>
        </span>
      </li>
    ))}
  </ul>
</aside>

<style>
  /* Barra contenida (vive dentro del Section del hero, entre <Hero/> y la métrica agregada).
     Tono superficie-alt para diferenciarse del fondo blanco del hero sin gritar.
     V4-07: sin borde+sombra+radius (eso leía como card) -> solo hairlines top/bottom que
     acotan la franja, superficie quieta, cero elevación. */
  .proof-bar {
    margin-block: var(--space-2);
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    /* space-3 (no space-4): mantiene el alto < 100px desktop — criterio de verificación M16.
       Sigue siendo "compacto"; el contenido de cada columna ya ronda ~64px. */
    padding-block: var(--space-3);
    padding-inline: var(--space-4);
  }

  .proof-bar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr; /* mobile: 3 filas apiladas */
    gap: var(--space-3);
  }

  .proof-bar__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  /* Mobile: divisor superior entre filas (no en la primera). */
  .proof-bar__item + .proof-bar__item {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
  }

  .proof-bar__icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: var(--radius-2);
    /* Tinte accent: aporta el cyan de marca sin fallar contraste (el ícono es decorativo). */
    background: rgba(62, 234, 243, 0.14);
    color: var(--color-primary-dark);
  }

  .proof-bar__icon svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .proof-bar__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  /* M18 (TB-06): estas son PROMESAS (no prueba), y el big-number (.metric-md, Oswald
     hasta 2.5rem) competía con el dispositivo-firma <MarginLeak/> —el único artefacto de
     prueba con forma propia—. Se baja a texto de apoyo, sin escala display.
     V4-07: de Fraunces a --font-mono tabular + --color-action — mismo tratamiento que
     .hero__metric-value (Hero.astro), firma "tablero de operador" compartida entre hero
     y esta franja. */
  .proof-bar__metric {
    display: block;
    margin: 0;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums lining-nums;
    font-feature-settings: "tnum" 1, "lnum" 1;
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 600;
    line-height: 1;
    color: var(--color-action);
  }

  /* V4-07: mismo tratamiento que .hero__metric-label (Hero.astro) — uppercase +
     --tracking-eyebrow — para que la franja lea como continuación del "tablero" del hero
     en vez de un label de card genérica. */
  .proof-bar__label {
    font-family: var(--font-subheading);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    /* dark-3 (no text-muted): pasa WCAG AA 4.5:1 sobre surface-alt (~7.7:1). */
    color: var(--color-dark-3);
  }

  /* Desktop: 3 columnas equiespaciadas con divisores verticales. */
  @media (min-width: 768px) {
    .proof-bar {
      padding-inline: var(--space-5);
    }

    .proof-bar__list {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      align-items: stretch;
    }

    .proof-bar__item {
      justify-content: center;
      padding-inline: var(--space-5);
    }

    .proof-bar__item + .proof-bar__item {
      border-top: 0;
      padding-top: 0;
      border-left: 1px solid var(--color-border);
    }
  }
</style>
