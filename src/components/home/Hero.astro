---
/**
 * Hero — Above-the-Fold del home. Fase 4 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 * Copy verbatim brief §9.1. CTAs bifurcados Ciancio (brief §5).
 * Tracking dual Pixel + CAPI con dedup event_id (fire-and-forget, no bloquea redirect).
 *
 * Visual (M13 plan_de_mejoras_v1) — dualidad "operador en piso + estratega financiero".
 * FALLBACK ACTIVO: el split-screen real (cocina cliente + dashboard P&L) todavía NO tiene
 * assets. Mientras tanto: foto-efer (operador) + mini-dashboard con datos REALES (estratega).
 * Las 3 cifras salen de testimonios.ts / SocialProof métrica agregada — NO inventadas:
 *   +42% margen delivery neto (Temaky) · 10 días al diagnóstico (promesa core) · 4.6★ (Pangas).
 * TODO(M13): cuando Efer entregue assets, sustituir el fallback por split-screen real:
 *   - public/images/hero-cocina.webp     (cocina real de cliente, con consentimiento; NO stock)
 *   - public/images/hero-dashboard.webp  (screenshot P&L real anonimizado; NO inventar dashboard)
 *   Layout objetivo: top 60% cocina / bottom 40% dashboard, divisor 2px var(--color-accent).
 */
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import CTAs from '../shared/CTAs.astro';

interface Props {
  eyebrow?: string;
  h1?: string;
  subhead?: string;
  bullets?: string[];
}

const {
  eyebrow = 'Sistemas operativos y rentabilidad B2B para restaurantes',
  h1 = 'Vendo pero no gano dinero',
  subhead = 'Rehabilitamos la economía y operación de tu restaurante en 10 días hábiles. Diagnóstico, plan, ejecución — con garantía operativa y dueño dentro de la cabina.',
  bullets = [
    'Diagnóstico de fuga de margen en 10 días: mermas, costeo, mix, descuentos, ticket promedio.',
    'Operación que funciona cuando no estás: SOPs, encargado entrenado, dashboard semanal.',
    'Crecimiento que no te quiebra: paid media + canal directo + retención, en ese orden.',
  ],
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-h1">
  <div class="hero__copy">
    <Eyebrow tone="accent">{eyebrow}</Eyebrow>
    <Heading as="h1" class="hero__h1">
      <span id="hero-h1">{h1}</span>
    </Heading>
    <Body size="lead" tone="muted" class="hero__subhead">{subhead}</Body>
    <ul class="hero__bullets" role="list">
      {bullets.map((b) => (
        <li>
          <svg class="hero__bullet-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>
    <CTAs variant="all" landing="home" />
    {/* Tracking Contact dedup Pixel+CAPI lo maneja el script hoisted de CTAs.astro. */}
  </div>

  <div class="hero__visual">
    <div class="hero__visual-frame">
      <img
        src="/images/foto-efer-480.webp"
        srcset="/images/foto-efer-480.webp 480w, /images/foto-efer.webp 640w"
        sizes="(max-width: 420px) 90vw, 384px"
        alt="Efer Lara, fundador de NextSwift — operador de restaurantes y consultor B2B"
        width="480"
        height="480"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="hero__visual-img"
      />
      <div class="hero__visual-scrim" aria-hidden="true"></div>

      {/* "Operador" — caption overlay inferior (M13 §3). Scrim garantiza contraste AA. */}
      <span class="hero__caption">Operador antes que consultor</span>

      {/* "Estratega" — mini-dashboard P&L (M13 §4, fallback). Cifras reales, sin imágenes nuevas → LCP intacto. */}
      <aside class="hero__dashboard" aria-label="Resultados documentados con clientes de NextSwift">
        <p class="hero__dashboard-head">
          <span class="hero__dashboard-dot" aria-hidden="true"></span>
          Tablero NextSwift
        </p>
        <dl class="hero__dashboard-stats">
          <div class="hero__stat">
            <dt class="hero__stat-label">Margen delivery</dt>
            <dd class="hero__stat-value">+42%</dd>
          </div>
          <div class="hero__stat">
            <dt class="hero__stat-label">Al diagnóstico</dt>
            <dd class="hero__stat-value">10 días</dd>
          </div>
          <div class="hero__stat">
            <dt class="hero__stat-label">Reseñas</dt>
            <dd class="hero__stat-value">4.6<span class="hero__stat-star" aria-hidden="true">★</span></dd>
          </div>
        </dl>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    /* M16: padding-block inferior reducido (space-10 → space-7) para cerrar el vacío
       bajo el hero y conectar con la <ProofBar/> de promesas. */
    padding: var(--space-9) 0 var(--space-7);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--space-9);
      /* M16: bottom space-11 → space-7 (ídem, conecta hero → ProofBar). */
      padding: var(--space-10) 0 var(--space-7);
    }
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    min-width: 0;
  }

  .hero__h1 {
    text-wrap: balance;
  }

  .hero__subhead {
    max-width: 38rem;
  }

  .hero__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero__bullets li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-text);
  }

  .hero__bullet-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15rem;
  }

  .hero__cta-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .hero__cta-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .hero__visual {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-width: 0;
  }

  .hero__visual-frame {
    position: relative;
    width: 100%;
    max-width: 24rem;
    /* M13: retrato 4/5 para dar banda inferior al caption + dashboard sin tapar el rostro
       (foto 1:1 con object-fit cover recorta solo los lados, nunca la cabeza). */
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-5);
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-dark-1, #001a33), var(--color-primary-dark, #003366));
    box-shadow: var(--shadow-3);
  }

  .hero__visual-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border-radius: inherit;
  }

  /* Scrim inferior: garantiza contraste >=4.5:1 del caption blanco sobre cualquier foto. */
  .hero__visual-scrim {
    position: absolute;
    inset: auto 0 0 0;
    height: 48%;
    background: linear-gradient(
      to top,
      rgba(0, 26, 51, 0.88) 0%,
      rgba(0, 26, 51, 0.55) 38%,
      rgba(0, 26, 51, 0) 100%
    );
    pointer-events: none;
  }

  /* Caption "operador" — overlay inferior izquierdo. */
  .hero__caption {
    position: absolute;
    left: var(--space-4);
    bottom: var(--space-4);
    z-index: 2;
    max-width: 8.5rem;
    margin: 0;
    color: #fff;
    font-family: var(--font-subheading);
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: var(--line-snug);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-shadow: 0 1px 4px rgba(0, 12, 26, 0.5);
  }

  /* Mini-dashboard "estratega" — overlay inferior derecho. */
  .hero__dashboard {
    position: absolute;
    right: var(--space-3);
    bottom: var(--space-3);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: min(48%, 9.5rem);
    padding: var(--space-3);
    background: rgba(0, 26, 51, 0.92);
    border: 1px solid rgba(62, 234, 243, 0.38);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-2);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }

  .hero__dashboard-head {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin: 0;
    font-family: var(--font-subheading);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
  }

  .hero__dashboard-dot {
    flex-shrink: 0;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(62, 234, 243, 0.22);
  }

  .hero__dashboard-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: 0;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
  }

  .hero__stat-label {
    font-family: var(--font-subheading);
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-blue-light);
  }

  .hero__stat-value {
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 700;
    line-height: 1;
    color: #fff;
  }

  .hero__stat-star {
    color: var(--color-accent);
    margin-left: 0.05em;
  }

  /* Pantallas muy angostas (<=360px): aprieta los dos overlays para que no colisionen. */
  @media (max-width: 360px) {
    .hero__caption { max-width: 7rem; font-size: 0.75rem; }
    .hero__dashboard { width: 47%; padding: var(--space-2); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cta-primary,
    .hero__cta-secondary {
      transition: none;
    }
  }
</style>
