---
/**
 * Hero — Above-the-Fold del home. Fase 4 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 * Copy verbatim brief §9.1. CTAs bifurcados Ciancio (brief §5).
 * Tracking dual Pixel + CAPI con dedup event_id (fire-and-forget, no bloquea redirect).
 *
 * Visual (M13 plan_de_mejoras_v1) — dualidad "operador en piso + estratega financiero".
 * FALLBACK ACTIVO: el split-screen real (cocina cliente + dashboard P&L) todavía NO tiene
 * assets. Mientras tanto: foto-efer (operador) + mini-dashboard con datos REALES (estratega).
 * Las 3 cifras salen de testimonios.ts / SocialProof métrica agregada — NO inventadas:
 *   +42% margen delivery neto (Temaky) · 10 días al diagnóstico (promesa core) · 4.6★ (Pangas).
 * TODO(M13): cuando Efer entregue assets, sustituir el fallback por split-screen real:
 *   - public/images/hero-cocina.webp     (cocina real de cliente, con consentimiento; NO stock)
 *   - public/images/hero-dashboard.webp  (screenshot P&L real anonimizado; NO inventar dashboard)
 *   Layout objetivo: top 60% cocina / bottom 40% dashboard, divisor 2px var(--color-accent).
 */
import { Picture } from 'astro:assets';
import fotoEfer from '../../assets/foto-efer.webp';
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import CTAs from '../shared/CTAs.astro';

interface Props {
  eyebrow?: string;
  h1?: string;
  claim?: string;
  subhead?: string;
  bullets?: string[];
}

const {
  eyebrow = 'Partner operativo B2B para restaurantes de 50-150 comensales',
  h1 = 'Vendo pero no gano dinero',
  // M10 (T1-02/T8-01): resultado cuantificado bajo el H1 de dolor. Cifra CONSERVADORA y
  // defendible — coherente con Stakes.astro ("3-7 puntos en 90 días", ya en producción) y
  // con la categoría única de M9. VALIDADA por Efer (2026-07-02).
  claim = 'Recuperamos entre 3 y 7 puntos de margen operativo en ~90 días, sobre tu base actual.',
  subhead = 'Rehabilitamos la economía y operación de tu restaurante en 10 días hábiles. Diagnóstico, plan, ejecución — con garantía operativa y dueño dentro de la cabina.',
  bullets = [
    'Diagnóstico de fuga de margen en 10 días: mermas, costeo, mix, descuentos, ticket promedio.',
    'Operación que funciona cuando no estás: SOPs, encargado entrenado, dashboard semanal.',
    'Crecimiento que no te quiebra: paid media + canal directo + retención, en ese orden.',
  ],
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-h1">
  <div class="hero__copy">
    <Eyebrow tone="accent">{eyebrow}</Eyebrow>
    <Heading as="h1" class="hero__h1">
      <span id="hero-h1">{h1}</span>
    </Heading>

    {/* M10: claim de RESULTADO cuantificado — la voz de dolor del H1 engancha, este número
        cierra con el resultado. Cifra "3-7 pts de margen en ~90 días" validada por Efer (2026-07-02). */}
    <p class="hero__claim">{claim}</p>

    <Body size="lead" tone="muted" class="hero__subhead">{subhead}</Body>

    {/* M8 (T6-02): tira de PRUEBA — solo móvil (<768px). Sube las 3 cifras del
        mini-dashboard al primer viewport, donde >70% del tráfico sí las ve.
        En desktop se oculta: ahí las cifras viven en el overlay de la foto
        (.hero__dashboard). Mismos datos reales: +42% (Temaky) · 10 días (promesa) · 4.6★ (Pangas). */}
    <dl class="hero__metrics" aria-label="Resultados documentados con clientes de NextSwift">
      <div class="hero__metric">
        <dt class="hero__metric-label">Margen delivery</dt>
        <dd class="hero__metric-value">+42%</dd>
      </div>
      <div class="hero__metric">
        <dt class="hero__metric-label">Al diagnóstico</dt>
        <dd class="hero__metric-value">10 días</dd>
      </div>
      <div class="hero__metric">
        <dt class="hero__metric-label">Reseñas</dt>
        <dd class="hero__metric-value">4.6<span class="hero__metric-star" aria-hidden="true">★</span></dd>
      </div>
    </dl>

    <ul class="hero__bullets" role="list">
      {bullets.map((b) => (
        <li>
          <svg class="hero__bullet-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>
    <CTAs variant="all" landing="home" />
    {/* Tracking Contact dedup Pixel+CAPI lo maneja el script hoisted de CTAs.astro. */}
  </div>

  <div class="hero__visual">
    <div class="hero__visual-frame">
      {/* M23 (T5-07): migrado de <img> nativa a astro:assets <Picture>. Genera AVIF+WebP
          responsivos (fallback WebP) desde el original src/assets/foto-efer.webp (640×640).
          Sigue siendo el LCP del home: loading=eager + fetchpriority=high se reenvían al <img>.
          El sizing visual lo controla el CSS del frame (4/5, object-fit cover). */}
      <Picture
        src={fotoEfer}
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        widths={[384, 480, 640]}
        sizes="(max-width: 420px) 90vw, 384px"
        alt="Efer Lara, fundador de NextSwift — operador de restaurantes y consultor B2B"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="hero__visual-img"
      />
      <div class="hero__visual-scrim" aria-hidden="true"></div>

      {/* "Operador" — caption overlay inferior (M13 §3). Scrim garantiza contraste AA. */}
      <span class="hero__caption">Operador antes que consultor</span>

      {/* "Estratega" — mini-dashboard P&L (M13 §4, fallback). Cifras reales, sin imágenes nuevas → LCP intacto. */}
      <aside class="hero__dashboard" aria-label="Resultados documentados con clientes de NextSwift">
        <p class="hero__dashboard-head">
          <span class="hero__dashboard-dot" aria-hidden="true"></span>
          Tablero NextSwift
        </p>
        <dl class="hero__dashboard-stats">
          <div class="hero__stat">
            <dt class="hero__stat-label">Margen delivery</dt>
            <dd class="hero__stat-value">+42%</dd>
          </div>
          <div class="hero__stat">
            <dt class="hero__stat-label">Al diagnóstico</dt>
            <dd class="hero__stat-value">10 días</dd>
          </div>
          <div class="hero__stat">
            <dt class="hero__stat-label">Reseñas</dt>
            <dd class="hero__stat-value">4.6<span class="hero__stat-star" aria-hidden="true">★</span></dd>
          </div>
        </dl>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    /* M16: padding-block inferior reducido (space-10 → space-7) para cerrar el vacío
       bajo el hero y conectar con la <ProofBar/> de promesas.
       M8 (T6-01): padding-top móvil recortado (space-9 → space-4). La <Section spacing="lg">
       que envuelve al hero ya aporta el padding superior (~space-11); el padding-top propio
       lo duplicaba → ~163px de vacío entre header y H1 en <=375px. */
    padding: var(--space-4) 0 var(--space-7);
    align-items: center;
  }

  /* M21 (T6-04): 2 columnas SOLO a partir de 821px = por encima del breakpoint de
     navegación --bp-nav (820px, definido en Header.astro). Antes el hero pasaba a 2 col
     a 768px mientras el Header ya era hamburguesa a <=820px → franja 768-820px híbrida
     (nav móvil + layout desktop) con el H1 estrecho. Ahora <=820px = un solo modo móvil.
     Nota: los @media no pueden leer var(--bp-nav); el literal es el espejo del token. */
  @media (min-width: 821px) { /* --bp-nav + 1 */
    .hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--space-9);
      /* M16: bottom space-11 → space-7 (ídem, conecta hero → ProofBar). */
      padding: var(--space-10) 0 var(--space-7);
    }
  }

  /* M21: en la banda tablet (481-820px) el hero es de una sola columna a ancho completo;
     el clamp desktop de --fs-h1 (1.8rem + 2.4vw, hasta 64px) crecía a ~47-48px y quedaba
     sobredimensionado. Se acota el H1 del hero a un tamaño tablet (≈36-40px) sin tocar el
     token global ni el desktop (>=821px, donde reaparece el clamp completo en 2 columnas).
     <=480px conserva el override compacto de --fs-h1 (tokens.css). */
  @media (min-width: 481px) and (max-width: 820px) { /* hasta --bp-nav */
    .hero__h1 {
      font-size: clamp(2.25rem, 1.6rem + 1.8vw, 2.875rem); /* 36 → ~40 px */
    }
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    min-width: 0;
  }

  .hero__h1 {
    text-wrap: balance;
  }

  .hero__subhead {
    max-width: 38rem;
  }

  /* M10: claim de resultado cuantificado (cifra validada por Efer). Barra accent a la
     izquierda — mismo lenguaje visual que .leak (Stakes) y .caso-ancla__metric (landings).
     Texto en --color-text (alto contraste AA sobre el hero claro); el accent es solo borde. */
  .hero__claim {
    margin: 0;
    padding-left: var(--space-3);
    border-left: 4px solid var(--color-accent);
    font-family: var(--font-subheading);
    font-size: var(--fs-lead);
    font-weight: 700;
    line-height: var(--line-snug);
    color: var(--color-text);
    max-width: 38rem;
    text-wrap: balance;
  }

  /* M8 (T6-02): tira de PRUEBA móvil. Tono surface-alt (fondo claro del hero) con valores
     en accent-on-light (#147D83, 4.89:1 AA) — el #3EEAF3 fallaría contraste sobre claro. */
  .hero__metrics {
    display: flex;
    gap: var(--space-3);
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-4);
    box-shadow: var(--shadow-1);
  }

  .hero__metric {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
    flex: 1 1 0;
    min-width: 0;
  }

  .hero__metric-label {
    font-family: var(--font-subheading);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-dark-3); /* 7.7:1 sobre surface-alt (AA) */
  }

  .hero__metric-value {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-accent-on-light);
  }

  .hero__metric-star {
    color: var(--color-accent-on-light);
    margin-left: 0.05em;
  }

  /* Desktop: las cifras viven en el overlay de la foto (.hero__dashboard); la tira se oculta.
     M21: alineado a --bp-nav (821px) — en la franja 768-820px (nav móvil) la tira sigue visible. */
  @media (min-width: 821px) { /* --bp-nav + 1 */
    .hero__metrics { display: none; }
  }

  .hero__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero__bullets li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-text);
  }

  .hero__bullet-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15rem;
  }

  .hero__cta-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .hero__cta-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .hero__visual {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-width: 0;
  }

  .hero__visual-frame {
    position: relative;
    width: 100%;
    max-width: 24rem;
    /* M13: retrato 4/5 para dar banda inferior al caption + dashboard sin tapar el rostro
       (foto 1:1 con object-fit cover recorta solo los lados, nunca la cabeza). */
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-5);
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-dark-1, #001a33), var(--color-primary-dark, #003366));
    box-shadow: var(--shadow-3);
  }

  /* M23: la salida de astro:assets <Picture> (<picture> + <img>) no recibe el scope
     de este componente, así que se apunta vía :global() anclado al frame (sí scopeado).
     display:contents retira el <picture> del árbol de cajas → el <img> conserva el
     sizing del frame (100%/100%, object-fit cover), idéntico al <img> nativo anterior. */
  .hero__visual-frame :global(picture) {
    display: contents;
  }

  .hero__visual-frame :global(.hero__visual-img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border-radius: inherit;
  }

  /* Scrim inferior: garantiza contraste >=4.5:1 del caption blanco sobre cualquier foto. */
  .hero__visual-scrim {
    position: absolute;
    inset: auto 0 0 0;
    height: 48%;
    background: linear-gradient(
      to top,
      rgba(0, 26, 51, 0.88) 0%,
      rgba(0, 26, 51, 0.55) 38%,
      rgba(0, 26, 51, 0) 100%
    );
    pointer-events: none;
  }

  /* Caption "operador" — overlay inferior izquierdo. */
  .hero__caption {
    position: absolute;
    left: var(--space-4);
    bottom: var(--space-4);
    z-index: 2;
    max-width: 8.5rem;
    margin: 0;
    color: #fff;
    font-family: var(--font-subheading);
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: var(--line-snug);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-shadow: 0 1px 4px rgba(0, 12, 26, 0.5);
  }

  /* Mini-dashboard "estratega" — overlay inferior derecho. */
  .hero__dashboard {
    position: absolute;
    right: var(--space-3);
    bottom: var(--space-3);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: min(48%, 9.5rem);
    padding: var(--space-3);
    background: rgba(0, 26, 51, 0.92);
    border: 1px solid rgba(62, 234, 243, 0.38);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-2);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }

  .hero__dashboard-head {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin: 0;
    font-family: var(--font-subheading);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
  }

  .hero__dashboard-dot {
    flex-shrink: 0;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(62, 234, 243, 0.22);
  }

  .hero__dashboard-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: 0;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
  }

  .hero__stat-label {
    font-family: var(--font-subheading);
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-blue-light);
  }

  .hero__stat-value {
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 700;
    line-height: 1;
    color: #fff;
  }

  .hero__stat-star {
    color: var(--color-accent);
    margin-left: 0.05em;
  }

  /* M8 (T6-02): en móvil la PRUEBA se muestra en .hero__metrics (primer viewport), no en el
     overlay de la foto. Se oculta el dashboard para no duplicar la cifra; la foto conserva
     solo el caption "operador". En desktop el overlay sigue intacto. */
  /* M21: oculto en todo el modo móvil (<=820px = --bp-nav), no solo <=767px. Así en la franja
     768-820px (nav hamburguesa, hero a 1 columna) la prueba se ve en .hero__metrics y no se
     duplica con el overlay del dashboard. */
  @media (max-width: 820px) { /* = --bp-nav */
    .hero__dashboard { display: none; }
  }

  /* Pantallas muy angostas (<=360px): aprieta el caption para que no se desborde. */
  @media (max-width: 360px) {
    .hero__caption { max-width: 7rem; font-size: 0.75rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cta-primary,
    .hero__cta-secondary {
      transition: none;
    }
  }
</style>
