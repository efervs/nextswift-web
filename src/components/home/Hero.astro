---
/**
 * Hero — Above-the-Fold del home. Fase 4 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 * Copy verbatim brief §9.1. CTAs bifurcados Ciancio (brief §5).
 * Tracking dual Pixel + CAPI con dedup event_id (fire-and-forget, no bloquea redirect).
 */
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import CTAs from '../shared/CTAs.astro';

interface Props {
  eyebrow?: string;
  h1?: string;
  subhead?: string;
  bullets?: string[];
}

const {
  eyebrow = 'Sistemas operativos y rentabilidad B2B para restaurantes',
  h1 = 'Vendo pero no gano dinero',
  subhead = 'Rehabilitamos la economía y operación de tu restaurante en 10 días hábiles. Diagnóstico, plan, ejecución — con garantía operativa y dueño dentro de la cabina.',
  bullets = [
    'Diagnóstico de fuga de margen en 10 días: mermas, costeo, mix, descuentos, ticket promedio.',
    'Operación que funciona cuando no estás: SOPs, encargado entrenado, dashboard semanal.',
    'Crecimiento que no te quiebra: paid media + canal directo + retención, en ese orden.',
  ],
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-h1">
  <div class="hero__copy">
    <Eyebrow tone="accent">{eyebrow}</Eyebrow>
    <Heading as="h1" class="hero__h1">
      <span id="hero-h1">{h1}</span>
    </Heading>
    <Body size="lead" tone="muted" class="hero__subhead">{subhead}</Body>
    <ul class="hero__bullets" role="list">
      {bullets.map((b) => (
        <li>
          <svg class="hero__bullet-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>
    <CTAs variant="all" landing="home" />
    {/* Tracking Contact dedup Pixel+CAPI lo maneja el script hoisted de CTAs.astro. */}
  </div>

  <div class="hero__visual">
    <div class="hero__visual-frame">
      <img
        src="/images/foto-efer.webp"
        alt="Efer Lara, fundador de NextSwift — operador de restaurantes y consultor B2B"
        width="480"
        height="480"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="hero__visual-img"
      />
    </div>
    <span class="hero__visual-anchor">Operador antes que consultor</span>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    padding: var(--space-9) 0 var(--space-10);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--space-9);
      padding: var(--space-10) 0 var(--space-11);
    }
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    min-width: 0;
  }

  .hero__h1 {
    text-wrap: balance;
  }

  .hero__subhead {
    max-width: 38rem;
  }

  .hero__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero__bullets li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-text);
  }

  .hero__bullet-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15rem;
  }

  .hero__cta-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .hero__cta-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .hero__visual {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-width: 0;
  }

  .hero__visual-frame {
    position: relative;
    width: 100%;
    max-width: 24rem;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-5);
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-dark-1, #001a33), var(--color-primary-dark, #003366));
    box-shadow: var(--shadow-3);
  }

  .hero__visual-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  .hero__visual-anchor {
    display: block;
    margin-top: var(--space-3);
    text-align: center;
    padding: var(--space-2) var(--space-4);
    color: var(--color-text-muted, #6b7280);
    font-family: var(--font-subheading);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cta-primary,
    .hero__cta-secondary {
      transition: none;
    }
  }
</style>
