---
/**
 * Hero — Above-the-Fold del home. Fase 4 del PLAN_IMPLEMENTACION_NEXTSWIFT.
 * Copy verbatim brief §9.1. CTAs bifurcados Ciancio (brief §5).
 * Tracking dual Pixel + CAPI con dedup event_id (fire-and-forget, no bloquea redirect).
 *
 * Visual (M16 v3, plan_de_mejoras_v3) — reponderado a la TESIS. Antes: foto-efer grande
 * + mini-dashboard INVENTADO (confesado aquí como "FALLBACK ACTIVO", TB-02). Ahora la
 * columna visual ES el drenaje de margen con la cifra REAL vía <MarginLeak/> — el
 * dispositivo-firma de la marca; el H1 de dolor domina y Efer pasa a firma de apoyo
 * (avatar). No se inventan cifras: "3–7 pts de margen/mes" = headline de Stakes en vivo
 * e inverso de "recuperar 3–7 pts en ~90 días" (validado por Efer 2026-07-02). La prueba
 * (+42% / 10 días / 4.6★) ya vive en <ProofBar/> + <SocialProof/> justo debajo del hero.
 */
import { Picture } from 'astro:assets';
import fotoEfer from '../../assets/foto-efer.webp';
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import CTAs from '../shared/CTAs.astro';
import MarginLeak from '../shared/MarginLeak.astro';

interface Props {
  eyebrow?: string;
  h1?: string;
  claim?: string;
  subhead?: string;
  bullets?: string[];
}

const {
  eyebrow = 'Partner operativo B2B para restaurantes de 50-150 comensales',
  h1 = 'Vendo pero no gano dinero',
  // M10 (T1-02/T8-01): resultado cuantificado bajo el H1 de dolor. Cifra CONSERVADORA y
  // defendible — coherente con Stakes.astro ("3-7 puntos en 90 días", ya en producción) y
  // con la categoría única de M9. VALIDADA por Efer (2026-07-02).
  claim = 'Recuperamos entre 3 y 7 puntos de margen operativo en ~90 días, sobre tu base actual.',
  subhead = 'Rehabilitamos la economía y operación de tu restaurante en 10 días hábiles. Diagnóstico, plan, ejecución — con garantía operativa y dueño dentro de la cabina.',
  bullets = [
    'Diagnóstico de fuga de margen en 10 días: mermas, costeo, mix, descuentos, ticket promedio.',
    'Operación que funciona cuando no estás: SOPs, encargado entrenado, dashboard semanal.',
    'Crecimiento que no te quiebra: paid media + canal directo + retención, en ese orden.',
  ],
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-h1">
  <div class="hero__copy">
    <Eyebrow tone="accent" class="hero__eyebrow">{eyebrow}</Eyebrow>
    <Heading as="h1" variant="display" class="hero__h1">
      <span id="hero-h1">{h1}</span>
    </Heading>

    {/* M10: claim de RESULTADO cuantificado — la voz de dolor del H1 engancha, este número
        cierra con el resultado. Cifra "3-7 pts de margen en ~90 días" validada por Efer (2026-07-02). */}
    <p class="hero__claim">{claim}</p>

    <Body size="lead" tone="muted" class="hero__subhead">{subhead}</Body>

    {/* M8 (T6-02): tira de PRUEBA — solo móvil (<768px). Sube las 3 cifras del
        mini-dashboard al primer viewport, donde >70% del tráfico sí las ve.
        En desktop se oculta: ahí las cifras viven en el overlay de la foto
        (.hero__dashboard). Mismos datos reales: +42% (Temaky) · 10 días (promesa) · 4.6★ (Pangas). */}
    <dl class="hero__metrics" aria-label="Resultados documentados con clientes de NextSwift">
      <div class="hero__metric">
        <dt class="hero__metric-label">Margen delivery</dt>
        <dd class="hero__metric-value">+42%</dd>
      </div>
      <div class="hero__metric">
        <dt class="hero__metric-label">Al diagnóstico</dt>
        <dd class="hero__metric-value">10 días</dd>
      </div>
      <div class="hero__metric">
        <dt class="hero__metric-label">Reseñas</dt>
        <dd class="hero__metric-value">4.6<span class="hero__metric-star" aria-hidden="true">★</span></dd>
      </div>
    </dl>

    <ul class="hero__bullets" role="list">
      {bullets.map((b) => (
        <li>
          <svg class="hero__bullet-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>
    <CTAs variant="all" landing="home" />
    {/* Tracking Contact dedup Pixel+CAPI lo maneja el script hoisted de CTAs.astro. */}
  </div>

  <div class="hero__visual">
    {/* M16 v3 (TB-01/TB-02): el visual ES la tesis. El dispositivo-firma <MarginLeak/>
        da forma a la fuga de margen con la cifra REAL, reemplazando el mini-dashboard
        inventado. Cifra en vivo: "3–7 pts de margen/mes" (headline de Stakes; inverso de
        la promesa core validada por Efer). */}
    <MarginLeak
      size="hero"
      tone="on-light"
      caption="Margen operativo · cada mes sin sistema"
      metric="3–7 pts"
      unit="de margen que se van por la coladera"
      drained={32}
    />

    {/* Firma de autoridad en rol de APOYO (decisión Efer, §6): avatar pequeño, no el
        protagonista. Ya no es el LCP (antes 384px eager+high → ahora 48px). */}
    <figure class="hero__signature">
      <Picture
        src={fotoEfer}
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        widths={[48, 96, 128]}
        sizes="48px"
        alt="Efer Lara, fundador de NextSwift"
        loading="eager"
        decoding="async"
        class="hero__signature-img"
      />
      <figcaption class="hero__signature-cap">
        <span class="hero__signature-name">Efer Lara</span>
        <span class="hero__signature-role">Operador antes que consultor</span>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    /* M16: padding-block inferior reducido (space-10 → space-7) para cerrar el vacío
       bajo el hero y conectar con la <ProofBar/> de promesas.
       M8 (T6-01): padding-top móvil recortado (space-9 → space-4). La <Section spacing="lg">
       que envuelve al hero ya aporta el padding superior (~space-11); el padding-top propio
       lo duplicaba → ~163px de vacío entre header y H1 en <=375px. */
    padding: var(--space-4) 0 var(--space-7);
    align-items: center;
  }

  /* M21 (T6-04): 2 columnas SOLO a partir de 821px = por encima del breakpoint de
     navegación --bp-nav (820px, definido en Header.astro). Antes el hero pasaba a 2 col
     a 768px mientras el Header ya era hamburguesa a <=820px → franja 768-820px híbrida
     (nav móvil + layout desktop) con el H1 estrecho. Ahora <=820px = un solo modo móvil.
     Nota: los @media no pueden leer var(--bp-nav); el literal es el espejo del token. */
  @media (min-width: 821px) { /* --bp-nav + 1 */
    .hero {
      /* M16 v3: el H1 de dolor domina — la columna de copy pesa más que el visual
         (antes 1.15/0.85, billing casi 50/50 con el retrato). */
      grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
      gap: var(--space-9);
      /* M16: bottom space-11 → space-7 (ídem, conecta hero → ProofBar). */
      padding: var(--space-10) 0 var(--space-7);
    }
  }

  /* M21: en la banda tablet (481-820px) el hero es de una sola columna a ancho completo;
     el clamp desktop de --fs-h1 (1.8rem + 2.4vw, hasta 64px) crecía a ~47-48px y quedaba
     sobredimensionado. Se acota el H1 del hero a un tamaño tablet (≈36-40px) sin tocar el
     token global ni el desktop (>=821px, donde reaparece el clamp completo en 2 columnas).
     <=480px conserva el override compacto de --fs-h1 (tokens.css). */
  @media (min-width: 481px) and (max-width: 820px) { /* hasta --bp-nav */
    .hero__h1 {
      font-size: clamp(2.25rem, 1.6rem + 1.8vw, 2.875rem); /* 36 → ~40 px */
    }
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    min-width: 0;
  }

  .hero__h1 {
    text-wrap: balance;
  }

  /* M17 (TB-04/TB-08): contraste de peso Oswald-firma. El eyebrow (kicker) baja al
     extremo LIGERO del eje variable de Oswald (300) frente al H1 display a 700 —
     misma familia CONGELADA, extremos opuestos del eje = la firma tipográfica. Solo
     el eyebrow del hero (la tesis); los demás eyebrows quedan como están (fuera de
     alcance). Oswald ya está precargada ATF (M23) → sin costo de LCP. El color y el
     tracking (--tracking-eyebrow) los hereda del componente Eyebrow → contraste AA
     intacto (el peso no cambia el contraste de color). */
  .hero :global(.hero__eyebrow) {
    font-family: var(--font-heading);
    font-weight: 300;
  }
  @media (max-width: 480px) {
    /* Piso de peso en móvil: 300 uppercase a ~11px (M20) se afina de más; 400 conserva
       el contraste con el H1 sin sacrificar escaneabilidad. */
    .hero :global(.hero__eyebrow) { font-weight: 400; }
  }

  .hero__subhead {
    max-width: 38rem;
  }

  /* M10: claim de resultado cuantificado (cifra validada por Efer). Barra accent a la
     izquierda — mismo lenguaje visual que .leak (Stakes) y .caso-ancla__metric (landings).
     Texto en --color-text (alto contraste AA sobre el hero claro); el accent es solo borde. */
  .hero__claim {
    margin: 0;
    padding-left: var(--space-3);
    border-left: 4px solid var(--color-accent);
    font-family: var(--font-subheading);
    font-size: var(--fs-lead);
    font-weight: 700;
    line-height: var(--line-snug);
    color: var(--color-text);
    max-width: 38rem;
    text-wrap: balance;
  }

  /* M8 (T6-02): tira de PRUEBA móvil. Tono surface-alt (fondo claro del hero) con valores
     en accent-on-light (#147D83, 4.89:1 AA) — el #3EEAF3 fallaría contraste sobre claro. */
  .hero__metrics {
    display: flex;
    gap: var(--space-3);
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-4);
    box-shadow: var(--shadow-1);
  }

  .hero__metric {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
    flex: 1 1 0;
    min-width: 0;
  }

  .hero__metric-label {
    font-family: var(--font-subheading);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-dark-3); /* 7.7:1 sobre surface-alt (AA) */
  }

  /* TD-08: en el breakpoint angosto (~360-390px) "Margen delivery" (la etiqueta
     más larga) rompe a 2 líneas dentro de su tercio de flex mientras "Al
     diagnóstico" y "Reseñas" quedan en 1 → filas dispares dentro del chip.
     Se afina SOLO tamaño/tracking del label (sin tocar el texto) y se reserva
     una altura de 2 líneas fija para las 3 columnas, así el chip queda con
     filas parejas sin importar cuál etiqueta envuelve. */
  @media (max-width: 390px) {
    .hero__metric-label {
      font-size: 0.625rem;
      letter-spacing: 0.02em;
      min-height: calc(1.2em * 2);
    }
  }

  .hero__metric-value {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-accent-on-light);
  }

  .hero__metric-star {
    color: var(--color-accent-on-light);
    margin-left: 0.05em;
  }

  /* Desktop: las cifras viven en el overlay de la foto (.hero__dashboard); la tira se oculta.
     M21: alineado a --bp-nav (821px) — en la franja 768-820px (nav móvil) la tira sigue visible. */
  @media (min-width: 821px) { /* --bp-nav + 1 */
    .hero__metrics { display: none; }
  }

  .hero__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero__bullets li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: var(--space-3);
    align-items: start;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-text);
  }

  .hero__bullet-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.15rem;
  }

  .hero__cta-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .hero__cta-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  /* M16 v3: la columna visual es ahora la TESIS (drenaje de margen), enmarcada como un
     readout de P&L (surface-alt + borde) — no una foto. El dispositivo-firma <MarginLeak/>
     es el protagonista; la firma de Efer va al pie, en rol de apoyo. */
  .hero__visual {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    min-width: 0;
    padding: var(--space-6);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-5);
    box-shadow: var(--shadow-1);
  }

  /* Firma de autoridad (apoyo): avatar pequeño + nombre/rol, con divisor superior.
     El retrato dejó de ser el LCP (antes 384px eager+high) → ahora 48px; el LCP pasa
     al H1 en texto, más rápido de pintar. */
  .hero__signature {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  /* astro:assets <Picture> emite <picture><img>; display:contents lo retira del árbol
     de cajas para que el <img> tome el sizing de .hero__signature-img. */
  .hero__signature :global(picture) {
    display: contents;
  }

  .hero__signature :global(.hero__signature-img) {
    display: block;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-pill);
    object-fit: cover;
    object-position: center;
    flex-shrink: 0;
  }

  .hero__signature-cap {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
    min-width: 0;
  }

  .hero__signature-name {
    font-family: var(--font-heading);
    font-size: var(--fs-body);
    font-weight: 600;
    line-height: 1.1;
    color: var(--color-text);
  }

  .hero__signature-role {
    font-family: var(--font-subheading);
    font-size: 0.8125rem;
    line-height: var(--line-snug);
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cta-primary,
    .hero__cta-secondary {
      transition: none;
    }
  }

  /* M4 (TD-03): en laptops de poca altura (<=900px, p.ej. 1366x768 o 1440x900) el
     padding-top propio (space-10, arriba) se suma al padding superior de la
     <Section spacing="lg"> que envuelve al hero (~space-11) y empuja el CTA primario
     fuera del primer viewport — mismo bug que M8 ya resolvió en móvil, aquí reaparecido
     en el breakpoint desktop. Se recorta el padding-top y el ritmo vertical interno SOLO
     por altura; el ancho sigue mandando en el layout de 2 columnas (sin cambios ahí).
     Va al final de la hoja para ganar la cascada sobre las reglas base de igual
     especificidad (@media no suma especificidad). */
  @media (min-width: 821px) and (max-height: 900px) {
    .hero {
      padding-top: 0;
    }
    .hero__copy {
      gap: var(--space-1);
    }
    .hero__bullets {
      gap: 0;
    }
  }

  /* Banda 901-1100px de alto (p.ej. 1920x1080): el hero ya casi cabe completo; solo se
     recorta el padding-top lo justo para que el 2do CTA no quede cortado en el borde
     inferior, sin tocar el ritmo interno (hero se mantiene "intacto"). */
  @media (min-width: 821px) and (min-height: 901px) and (max-height: 1100px) {
    .hero {
      padding-top: var(--space-9);
    }
  }
</style>
