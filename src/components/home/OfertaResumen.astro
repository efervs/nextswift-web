---
/**
 * OfertaResumen — Bloque resumen del Acelerador 3 Palancas en home.
 * Mini-versión de la oferta núcleo. Apunta a /acelerador para la página completa.
 * P7 / Fase 8 del plan extendido — value stacking comprimido.
 *
 * M8: diferenciación visual de las 3 palancas (antes idénticas, Captura7.png).
 * Cada palanca recibe un `icon` (SVG lucide-style inline, provisional hasta M18)
 * y un `accentColor` propio: Financiera → accent cyan, Operativa → primary azul,
 * Comercial → primary-dark navy. Cada card lleva top-bar 6px + chip 40×40 del
 * color de su palanca, título a `--fs-h2` y hover-lift. `accentInk` define el
 * color del trazo del ícono para legibilidad sobre el chip. Sin emojis
 * (regla CLAUDE.md anti-decorativo). Copy de promesas y CTA primary intactos.
 */
import Eyebrow from '../ui/Eyebrow.astro';
import Heading from '../ui/Heading.astro';
import Body from '../ui/Body.astro';
import Button from '../ui/Button.astro';

// Íconos lucide-style provisionales; nombres alineados al sprite previsto en M18
// (calculadora · engranaje · grafica). engranaje/grafica idénticos a los de M7.
type IconKey = 'calculadora' | 'engranaje' | 'grafica';

interface Palanca {
  nombre: string;
  promesa: string;
  icon: IconKey;
  accentColor: string; // color de top-bar + chip
  accentInk: string;   // trazo del ícono sobre el chip (legibilidad)
}

const palancas: Palanca[] = [
  {
    nombre: 'Financiera',
    promesa: 'Recuperación de 3-7 puntos de margen real en 90 días.',
    icon: 'calculadora',
    accentColor: 'var(--color-accent)',
    accentInk: 'var(--color-accent-ink)',
  },
  {
    nombre: 'Operativa',
    promesa: 'SOPs, encargado entrenado y dashboard semanal — el restaurante funciona cuando no estás.',
    icon: 'engranaje',
    accentColor: 'var(--color-primary)',
    accentInk: '#FFFFFF',
  },
  {
    nombre: 'Comercial',
    promesa: 'Tráfico directo, recurrencia y reducción de dependencia de marketplaces.',
    icon: 'grafica',
    accentColor: 'var(--color-primary-dark)',
    accentInk: '#FFFFFF',
  },
];
---

<section class="oferta-resumen" aria-labelledby="oferta-resumen-heading">
  <div class="oferta-resumen__inner">
    <header class="oferta-resumen__header">
      <Eyebrow>La oferta núcleo</Eyebrow>
      <Heading as="h2" id="oferta-resumen-heading">
        Acelerador 3 Palancas: financiera, operativa, comercial
      </Heading>
      <Body size="lead" tone="muted">
        Un solo paquete que ataca margen, autonomía y ventas al mismo tiempo. 10 días hábiles. Garantía operativa.
      </Body>
    </header>

    <ul class="oferta-resumen__palancas" role="list">
      {palancas.map((p) => (
        <li class="palanca-tile" style={`--accent: ${p.accentColor}; --accent-ink: ${p.accentInk};`}>
          <span class="palanca-tile__icon" aria-hidden="true">
            {p.icon === 'calculadora' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="2" width="16" height="20" rx="2" />
                <line x1="8" y1="6" x2="16" y2="6" />
                <line x1="16" y1="14" x2="16" y2="18" />
                <path d="M8 10h.01" />
                <path d="M12 10h.01" />
                <path d="M16 10h.01" />
                <path d="M8 14h.01" />
                <path d="M12 14h.01" />
                <path d="M8 18h.01" />
                <path d="M12 18h.01" />
              </svg>
            )}
            {p.icon === 'engranaje' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12.5 2h-1a2 2 0 0 0-2 2 1.7 1.7 0 0 1-.85 1.48l-.36.2a1.7 1.7 0 0 1-1.7 0l-.13-.07a2 2 0 0 0-2.73.73l-.5.87a2 2 0 0 0 .73 2.73l.13.07a1.7 1.7 0 0 1 .85 1.48v.42a1.7 1.7 0 0 1-.85 1.48l-.13.07a2 2 0 0 0-.73 2.73l.5.87a2 2 0 0 0 2.73.73l.13-.07a1.7 1.7 0 0 1 1.7 0l.36.2A1.7 1.7 0 0 1 9.5 20a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2 1.7 1.7 0 0 1 .85-1.48l.36-.2a1.7 1.7 0 0 1 1.7 0l.13.07a2 2 0 0 0 2.73-.73l.5-.87a2 2 0 0 0-.73-2.73l-.13-.07a1.7 1.7 0 0 1-.85-1.48v-.42a1.7 1.7 0 0 1 .85-1.48l.13-.07a2 2 0 0 0 .73-2.73l-.5-.87a2 2 0 0 0-2.73-.73l-.13.07a1.7 1.7 0 0 1-1.7 0l-.36-.2A1.7 1.7 0 0 1 14.5 4a2 2 0 0 0-2-2z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            )}
            {p.icon === 'grafica' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v16a2 2 0 0 0 2 2h16" />
                <path d="m7 14 4-4 3 3 5-5" />
                <path d="M19 8h2v2" />
              </svg>
            )}
          </span>
          <h3 class="palanca-tile__nombre">Palanca {p.nombre}</h3>
          <p class="palanca-tile__promesa">{p.promesa}</p>
        </li>
      ))}
    </ul>

    <div class="oferta-resumen__cta">
      <Button variant="primary" size="lg" href="/acelerador">
        Ver la oferta completa
        <span aria-hidden="true">&nbsp;&rarr;</span>
      </Button>
    </div>
  </div>
</section>

<style>
  .oferta-resumen {
    width: 100%;
    background: var(--color-surface);
  }
  .oferta-resumen__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-9) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .oferta-resumen__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--content-narrow);
  }
  .oferta-resumen__palancas {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 768px) {
    .oferta-resumen__palancas { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  }

  /* M8 — card diferenciada: top-bar 6px + chip de ícono, ambos en --accent. */
  .palanca-tile {
    --accent: var(--color-primary);   /* fallback; sobreescrito inline por palanca */
    --accent-ink: #FFFFFF;
    padding: var(--space-5);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-top: 6px solid var(--accent);
    border-radius: var(--radius-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition:
      transform var(--dur-2) var(--ease-out),
      border-top-width var(--dur-2) var(--ease-out),
      box-shadow var(--dur-2) var(--ease-out);
  }

  .palanca-tile:hover {
    transform: translateY(-4px);
    border-top-width: 8px;
    box-shadow: var(--shadow-3);
  }

  @media (prefers-reduced-motion: reduce) {
    .palanca-tile { transition: box-shadow var(--dur-2) var(--ease-out); }
    .palanca-tile:hover { transform: none; }
  }

  /* Chip 40×40 con el ícono. Trazo en --accent-ink para contraste sobre --accent. */
  .palanca-tile__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-2);
    background: var(--accent);
    color: var(--accent-ink);
  }
  .palanca-tile__icon svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  .palanca-tile__nombre {
    font-family: var(--font-heading);
    font-size: var(--fs-h2);
    line-height: var(--line-tight);
    color: var(--color-primary-dark);
    margin: 0;
  }
  .palanca-tile__promesa {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--line-base);
    color: var(--color-text);
    margin: 0;
  }
  .oferta-resumen__cta { display: flex; flex-wrap: wrap; gap: var(--space-3); }
</style>
