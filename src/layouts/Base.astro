---
/**
 * Base — layout institucional. Inyecta tokens, fonts, meta SEO default y skip-link.
 * Slots: `head` (override SEO específico), `default` (contenido principal).
 */
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import StickyCTAMobile from '../components/layout/StickyCTAMobile.astro';
import CookieBanner from '../components/legal/CookieBanner.astro';

// Font preloads — Vite resuelve URL con content-hash; reduce FOUT en LCP.
import oswald from '@fontsource-variable/oswald/files/oswald-latin-wght-normal.woff2?url';
import sspN from '@fontsource/source-sans-pro/files/source-sans-pro-latin-400-normal.woff2?url';
import sspSb from '@fontsource/source-sans-pro/files/source-sans-pro-latin-600-normal.woff2?url';
import latoN from '@fontsource/lato/files/lato-latin-400-normal.woff2?url';
import latoBd from '@fontsource/lato/files/lato-latin-700-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'NextSwift — Consultoría B2B para restaurantes en México',
  description = 'Rehabilitamos restaurantes que venden pero no ganan dinero. Diagnóstico, plan y ejecución en 10 días hábiles. 11 garantías formales. Dueño dentro de la cabina.',
  canonical = new URL(Astro.url.pathname, 'https://www.nextswift.mx').toString(),
  ogImage = 'https://www.nextswift.mx/images/og/default.png',
  noindex = false,
} = Astro.props;

const META_PIXEL_ID = '1545738293336210';
const GA4_MEASUREMENT_ID = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID ?? '';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'NextSwift',
  url: 'https://www.nextswift.mx',
  logo: 'https://www.nextswift.mx/images/logo-nextswift.webp',
  description:
    'Consultoría B2B mexicana que rehabilita restaurantes que venden pero no ganan dinero. Diagnóstico, plan y ejecución en 10 días hábiles.',
  areaServed: 'MX',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+52-811-042-5674',
    contactType: 'sales',
    areaServed: 'MX',
    availableLanguage: ['Spanish'],
  },
};
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#003366" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="NextSwift" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Iconos */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />

    {/* Preload fuentes críticas — subset latin, pesos usados en ATF */}
    <link rel="preload" as="font" type="font/woff2" crossorigin href={oswald} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={sspN} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={sspSb} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={latoN} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={latoBd} />

    {/* JSON-LD Organization schema */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />

    {/* Tracking loader — consent-gated (P22 / CookieBanner).
        Pixel + GA4 SDK se cargan al accept; tracking.ts dispara los events
        (PageView/Lead/etc.) con event_id compartido contra /api/capi para
        dedup en Meta Events Manager.

        El track('PageView') NO se hace aquí inline (delegado a tracking.ts
        para que comparta event_id con CAPI). Sin event_id no hay dedup,
        de ahí el cambio vs P22 original. */}
    <script is:inline define:vars={{ pixelId: META_PIXEL_ID, ga4Id: GA4_MEASUREMENT_ID }}>
      (function () {
        function loadPixelSDK() {
          if (window.fbq) return;
          !(function (f, b, e, v, n, t, s) {
            if (f.fbq) return;
            n = f.fbq = function () {
              n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
            };
            if (!f._fbq) f._fbq = n;
            n.push = n;
            n.loaded = !0;
            n.version = '2.0';
            n.queue = [];
            t = b.createElement(e);
            t.async = !0;
            t.src = v;
            s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s);
          })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
          window.fbq('init', pixelId);
        }
        function loadGA4() {
          if (!ga4Id) return;            // GA4 opcional; no-op si env vacía
          if (window.__ns_ga4_loaded) return;
          window.__ns_ga4_loaded = true;
          window.dataLayer = window.dataLayer || [];
          window.gtag = function () { window.dataLayer.push(arguments); };
          window.gtag('js', new Date());
          window.gtag('config', ga4Id, { send_page_view: false });
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4Id;
          document.head.appendChild(s);
        }
        function initTracking() {
          loadPixelSDK();
          loadGA4();
          // Re-fire PageView con event_id (dedup Pixel ↔ CAPI). Si el module
          // script de tracking ya cargó, dispara. Si no, queda el flag y el
          // module script lo dispara al hidratar.
          if (window.nxTrack && typeof window.nxTrack.pageView === 'function') {
            window.nxTrack.pageView();
          } else {
            window.__ns_pendingPageView = true;
          }
        }
        window.__ns_loadTracking = initTracking;
        try {
          var _nc = localStorage.getItem('nx-consent');
          if (_nc) {
            var _np = JSON.parse(_nc);
            if (_np && _np.analytics) initTracking();
          }
        } catch (e) { /* private mode */ }
      })();
    </script>

    {/* UTM capture + tracking wiring — P12 (UTM) + P21 (tracking).
       Corre como module script (deferred); UTM captura ANTES de cualquier
       CTA tardío. tracking se expone como window.nxTrack para handlers
       inline (StickyCTAMobile, CookieBanner, wa.me anchors). */}
    <script>
      import { captureUTMFromURL } from '../lib/utm';
      import * as nxTrack from '../lib/tracking';

      captureUTMFromURL();
      (window as unknown as { nxTrack: typeof nxTrack }).nxTrack = nxTrack;

      // Initial PageView. Si consent='all', dispara Pixel + CAPI + GA4 con
      // event_id compartido. Si consent != 'all', no-op (tracking.ts
      // chequea cookieConsent internamente).
      void nxTrack.pageView();

      // Si __ns_loadTracking llegó antes que este module y dejó pendiente
      // un re-fire, lo limpiamos. (La llamada anterior ya cubrió el caso.)
      try {
        delete (window as unknown as { __ns_pendingPageView?: boolean }).__ns_pendingPageView;
      } catch { /* noop */ }

      // Auto-wire wa.me clicks → Contact(whatsapp). Capture phase para
      // disparar antes del redirect; keepalive en fetch garantiza envío.
      document.addEventListener(
        'click',
        (ev) => {
          const path = (ev.composedPath?.() ?? []) as EventTarget[];
          const anchor = (path.find(
            (n) => n instanceof HTMLAnchorElement && /wa\.me/i.test((n as HTMLAnchorElement).href),
          ) as HTMLAnchorElement | undefined)
            ?? ((ev.target as HTMLElement | null)?.closest?.('a[href*="wa.me"]') as HTMLAnchorElement | null)
            ?? null;
          if (!anchor) return;
          void nxTrack.contact('whatsapp');
        },
        { capture: true },
      );
    </script>

    {/* Slot SEO override por página */}
    <slot name="head" />
  </head>

  <body>
    <a href="#main" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <StickyCTAMobile />
    <CookieBanner />
  </body>
</html>
