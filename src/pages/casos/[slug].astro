---
/**
 * /casos/[slug] — Detalle por caso. Estructura Beaudoin: Antes → Intervención → Resultado.
 *
 * Solo renderiza casos con `authorized: true`. Sr. Boneless no llega aquí
 * (no tiene `.md`, solo logo en banda de /casos-de-exito).
 *
 * Schema.org Article — valida con Google Rich Results Test al deploy.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/ui/Section.astro';
import Heading from '../../components/ui/Heading.astro';
import Body from '../../components/ui/Body.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import { buildWaUrl } from '../../lib/whatsapp-url.ts';

export async function getStaticPaths() {
  const entries = await getCollection('cases', (e) => e.data.authorized);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'cases'>; }
const { entry } = Astro.props;
const c = entry.data;

const waCaso = buildWaUrl({
  source: 'cases',
  content: `cta-caso-${c.slug}`,
  customMessage: `Hola, leí el caso de ${c.client} y quiero hablar de mi restaurante.`,
});

const canonical = `https://www.nextswift.mx/casos/${c.slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `Caso ${c.client} — ${c.result[0].metric}: ${c.result[0].value}`,
  datePublished: c.publishDate.toISOString().slice(0, 10),
  author: { '@type': 'Organization', name: 'NextSwift' },
  publisher: {
    '@type': 'Organization',
    name: 'NextSwift',
    logo: { '@type': 'ImageObject', url: 'https://www.nextswift.mx/images/logo-nextswift.webp' },
  },
  image: `https://www.nextswift.mx${c.logo}`,
  mainEntityOfPage: canonical,
  about: { '@type': 'Service', name: 'NextSwift Acelerador 3 Palancas' },
  description: c.before.slice(0, 200),
};

const breadcrumbsSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://www.nextswift.mx/' },
    { '@type': 'ListItem', position: 2, name: 'Casos de éxito', item: 'https://www.nextswift.mx/casos-de-exito' },
    { '@type': 'ListItem', position: 3, name: c.client, item: canonical },
  ],
};
---

<Base
  title={`Caso ${c.client} — ${c.result[0].metric}: ${c.result[0].value} | NextSwift`}
  description={`Caso real autorizado de ${c.client} (${c.sector}). ${c.result[0].metric}: ${c.result[0].value} en ${c.result[0].period}. Métrica verificable.`}
  canonical={canonical}
  ogType="article"
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(articleSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbsSchema)}
  />

  <Section spacing="lg" tone="surface" as="article">
    <a href="/casos-de-exito" class="back-link">← Todos los casos</a>

    <div class="caso-head">
      <img
        src={c.logo}
        alt={`Logo de ${c.client}`}
        width="160"
        height="80"
        loading="eager"
        decoding="async"
        class="caso-head__logo"
      />
      <Eyebrow tone="accent">{c.sector}</Eyebrow>
      <Heading as="h1" size="h1">{c.client}</Heading>
      {c.inProgress && (
        <Badge tone="accent">Caso activo · en ejecución</Badge>
      )}
    </div>

    <div class="caso-section">
      <Eyebrow tone="neutral">Estado antes</Eyebrow>
      <Heading as="h2" size="h3">Qué encontramos</Heading>
      <Body size="lead">{c.before}</Body>
    </div>

    <div class="caso-section">
      <Eyebrow tone="neutral">Intervención</Eyebrow>
      <Heading as="h2" size="h3">Qué hicimos</Heading>
      <Body size="lead">{c.intervention}</Body>
    </div>

    <div class="caso-section">
      <Eyebrow tone="neutral">Resultado</Eyebrow>
      <Heading as="h2" size="h3">Qué cambió, con cifras</Heading>
      <ul class="caso-metrics" role="list">
        {c.result.map((r) => (
          <li class="caso-metric">
            <span class="caso-metric__value">{r.value}</span>
            <span class="caso-metric__label">{r.metric}</span>
            <span class="caso-metric__period">{r.period}</span>
          </li>
        ))}
      </ul>
    </div>

    {c.quote && c.quoteAttribution && (
      <figure class="caso-quote">
        <blockquote>
          <Body size="lead">“{c.quote}”</Body>
        </blockquote>
        <figcaption>— {c.quoteAttribution}</figcaption>
      </figure>
    )}
  </Section>

  <Section spacing="lg" tone="dark" as="section">
    <Eyebrow tone="on-dark">Tu siguiente paso</Eyebrow>
    <Heading as="h2" size="h2" tone="on-dark">
      ¿Tu situación se parece a la de {c.client}?
    </Heading>
    <Body size="lead" tone="on-dark" class="caso-cta-body">
      Empezamos por un diagnóstico de 10 días hábiles. Si no vemos potencial real,
      lo decimos en la primera reunión.
    </Body>
    <div class="caso-cta-row">
      <Button variant="primary" size="lg" href="/acelerador">Aplicar al Acelerador</Button>
      <Button variant="wa" size="lg" href={waCaso} rel="noopener" target="_blank">
        Hablar con Efer ahora
      </Button>
    </div>
  </Section>
</Base>

<style>
  .back-link {
    display: inline-block;
    font-family: var(--font-subheading);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-5);
  }
  .back-link:hover { color: var(--color-primary-dark); }

  .caso-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-9);
  }
  .caso-head__logo {
    max-height: 4rem;
    width: auto;
    object-fit: contain;
  }

  .caso-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-9);
    max-width: var(--content-narrow);
  }

  .caso-metrics {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
    max-width: none;
  }
  @media (min-width: 48rem) {
    .caso-metrics { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  }
  .caso-metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-5);
    background: var(--color-surface-alt);
    border-radius: var(--radius-4);
    border: 1px solid var(--color-border);
  }
  .caso-metric__value {
    font-family: var(--font-heading);
    font-size: var(--fs-h2);
    font-weight: 600;
    line-height: var(--line-tight);
    color: var(--color-dark-1);
  }
  .caso-metric__label {
    font-family: var(--font-subheading);
    font-weight: 600;
    color: var(--color-text);
  }
  .caso-metric__period {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .caso-quote {
    margin: var(--space-9) 0 0;
    padding: var(--space-6);
    border-inline-start: 4px solid var(--color-accent);
    background: var(--color-surface-alt);
    border-radius: 0 var(--radius-3) var(--radius-3) 0;
  }
  .caso-quote blockquote { margin: 0; }
  .caso-quote figcaption {
    margin-top: var(--space-3);
    font-family: var(--font-subheading);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .caso-cta-body { margin-top: var(--space-4); }
  .caso-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
</style>
