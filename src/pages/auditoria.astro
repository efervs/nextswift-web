---
/**
 * /auditoria — Form multi-step de calificación dura.
 * P13 / Fase 15. Spec: PLAN_IMPLEMENTACION_NEXTSWIFT_CONDENSADO.md §P13.
 *
 * 6 pasos:
 *   1) Rango de ventas brutas mensuales ($MXN) — piso $300k (rebote inline).
 *   2) Cuello principal (6 dolores de nav-orden-dolores.md).
 *   3) Unidades / sucursales.
 *   4) Rol del decisor.
 *   5) Ventana de implementación.
 *   6) Email + WhatsApp.
 *
 * Fricción positiva intencional (Hormozi vetting + Beaudoin single-CTA).
 * Selección "<$300k" -> pantalla no-fit (sin POST a HubSpot).
 * UTM se persiste como hidden inputs leyendo sessionStorage (lib/utm.ts).
 */
import Base from '../layouts/Base.astro';
import Section from '../components/ui/Section.astro';
import Heading from '../components/ui/Heading.astro';
import Body from '../components/ui/Body.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import Icon from '../components/ui/Icon.astro';
import { buildWaUrl } from '../lib/whatsapp-url';
import { testimonioByObjecion } from '../data/testimonios';

const waFallbackUrl = buildWaUrl({
  source: 'auditoria',
  content: 'audit_form_fallback',
  context: 'sin_form',
  customMessage: 'Hola Efer, prefiero coordinar la auditoría directo por aquí. Vendo mensualmente',
});

const SALES_OPTIONS = [
  { value: '<300k', label: 'Menos de $300,000 / mes', disqualify: true },
  { value: '300k-500k', label: '$300,000 – $500,000 / mes' },
  { value: '500k-1M', label: '$500,000 – $1,000,000 / mes' },
  { value: '1M-2M', label: '$1,000,000 – $2,000,000 / mes' },
  { value: '>2M', label: 'Más de $2,000,000 / mes' },
];

const PAIN_OPTIONS = [
  { value: 'utilidad', label: 'Vendo pero no gano dinero' },
  { value: 'ventas-delivery', label: 'Las ventas están flojas' },
  { value: 'autonomia', label: 'El negocio depende demasiado de mí' },
  { value: 'personal', label: 'Mi personal es un desmadre' },
  { value: 'metricas-control', label: 'No tengo claridad real de números' },
  { value: 'crecimiento-controlado', label: 'Quiero crecer sin caos' },
];

const ROLE_OPTIONS = [
  { value: 'dueno', label: 'Dueño' },
  { value: 'socio', label: 'Socio' },
  { value: 'gerente_operativo', label: 'Gerente operativo' },
  { value: 'otro', label: 'Otro' },
];

const TIMING_OPTIONS = [
  { value: 'inmediata', label: 'Inmediata — en los próximos 30 días' },
  { value: '60d', label: 'En los próximos 60 días' },
  { value: '90d', label: 'En los próximos 90 días' },
  { value: 'explorando', label: 'Solo estoy explorando' },
];

const TOTAL_STEPS = 6;

// M6 (TC-02): reversión de riesgo + prueba social junto al submit del paso 6 (BOFU).
// Copy de garantías = mismo verbatim de CTAs.astro (M12, incl. escasez confirmada por Efer 2026-07-02).
// Testimonio = único autorizado que ancla "esto es teoría o ustedes operan" (objeción más cercana a
// la duda de un prospecto que ya sometió 6 pasos y está por firmar).
const trustTestimonio = testimonioByObjecion('teoria-vs-implementacion');
---

<Base
  title="Auditoría de viabilidad — NextSwift"
  description="Solicite una auditoría de viabilidad. 6 preguntas. Calificamos su caso antes de agendar. Solo restaurantes con $300k+/mes de ventas brutas."
  noindex={true}
>
  <Section width="narrow" spacing="lg" id="audit-section">
    <header class="audit__header">
      <Eyebrow>Solicitud de auditoría · 2 minutos</Eyebrow>
      <Heading as="h1" size="h1">Verifique si su restaurante califica</Heading>
      <Body size="lead" tone="muted">
        El Acelerador de 3 Palancas no es para todos. Estas {TOTAL_STEPS} preguntas nos dicen, en menos de
        2 minutos, si su caso es viable. Si no califica, se lo decimos sin rodeos.
      </Body>
    </header>

    <div
      id="audit"
      class="audit"
      data-total-steps={TOTAL_STEPS}
      aria-live="polite"
    >
      <div class="audit__progress" role="group" aria-label="Progreso del formulario">
        <div class="audit__progress-meta">
          <span id="audit-step-label">Paso 1 de {TOTAL_STEPS}</span>
          <span id="audit-step-pct">0%</span>
        </div>
        <progress id="audit-progress" max="100" value="0" aria-label="Progreso"></progress>
      </div>

      {/* M16 — anuncia "Paso X de N: <pregunta>" a lectores de pantalla antes de mover el foco al h2 */}
      <div id="audit-live" class="sr-only" aria-live="polite" aria-atomic="true"></div>

      <form id="audit-form" novalidate aria-label="Formulario de solicitud de auditoría">
        {/* Paso 1 — Sales range */}
        <section class="audit__step" data-step="1">
          <h2 class="audit__q-label" tabindex="-1"><span class="audit__q-num">1.</span> ¿Cuánto vende su restaurante al mes (bruto, todas las plataformas)?</h2>
          <p class="audit__q-helper">Tomamos el bruto promedio de los últimos 3 meses.</p>
          <fieldset class="audit__radios" id="q-salesrange" aria-describedby="q-salesrange-error">
            <legend class="sr-only">Rango de ventas mensuales</legend>
            {SALES_OPTIONS.map((opt) => (
              <label class="audit__radio">
                <input
                  type="radio"
                  name="salesrange"
                  value={opt.value}
                  data-disqualify={opt.disqualify ? 'true' : 'false'}
                  required
                />
                <span>{opt.label}</span>
              </label>
            ))}
          </fieldset>
          <p class="audit__error" id="q-salesrange-error" role="alert" aria-live="polite"></p>
        </section>

        {/* Paso 2 — Pain */}
        <section class="audit__step" data-step="2" hidden>
          <h2 class="audit__q-label" tabindex="-1"><span class="audit__q-num">2.</span> ¿Cuál es el cuello principal hoy?</h2>
          <p class="audit__q-helper">Elija el dolor más urgente. No el más bonito de admitir — el real.</p>
          <fieldset class="audit__radios" id="q-painprimary" aria-describedby="q-painprimary-error">
            <legend class="sr-only">Cuello principal</legend>
            {PAIN_OPTIONS.map((opt) => (
              <label class="audit__radio">
                <input type="radio" name="painprimary" value={opt.value} required />
                <span>{opt.label}</span>
              </label>
            ))}
          </fieldset>
          <p class="audit__error" id="q-painprimary-error" role="alert" aria-live="polite"></p>
        </section>

        {/* Paso 3 — Units */}
        <section class="audit__step" data-step="3" hidden>
          <h2 class="audit__q-label" id="audit-q-units-label" tabindex="-1"><span class="audit__q-num">3.</span> ¿Cuántas unidades o sucursales opera?</h2>
          <p class="audit__q-helper">Incluya dark kitchens y sucursales en franquicia que controle.</p>
          <div class="audit__input-row">
            <input
              type="number"
              id="q-units"
              name="units"
              class="audit__input"
              inputmode="numeric"
              enterkeyhint="next"
              pattern="[0-9]*"
              min="1"
              max="999"
              step="1"
              required
              autocomplete="off"
              aria-labelledby="audit-q-units-label"
              aria-describedby="q-units-error"
            />
          </div>
          <p class="audit__error" id="q-units-error" role="alert" aria-live="polite"></p>
        </section>

        {/* Paso 4 — Decisor role */}
        <section class="audit__step" data-step="4" hidden>
          <h2 class="audit__q-label" tabindex="-1"><span class="audit__q-num">4.</span> ¿Cuál es su rol en el negocio?</h2>
          <p class="audit__q-helper">Hablamos directo con quien firma. Si no es usted, lo coordinamos.</p>
          <fieldset class="audit__radios" id="q-decisor_role" aria-describedby="q-decisor_role-error">
            <legend class="sr-only">Rol del decisor</legend>
            {ROLE_OPTIONS.map((opt) => (
              <label class="audit__radio">
                <input type="radio" name="decisor_role" value={opt.value} required />
                <span>{opt.label}</span>
              </label>
            ))}
          </fieldset>
          <p class="audit__error" id="q-decisor_role-error" role="alert" aria-live="polite"></p>
        </section>

        {/* Paso 5 — Timing */}
        <section class="audit__step" data-step="5" hidden>
          <h2 class="audit__q-label" tabindex="-1"><span class="audit__q-num">5.</span> ¿En qué ventana quiere implementar?</h2>
          <p class="audit__q-helper">El Acelerador arranca en 10 días hábiles. Si no es ahora, lo agendamos.</p>
          <fieldset class="audit__radios" id="q-timing" aria-describedby="q-timing-error">
            <legend class="sr-only">Ventana de implementación</legend>
            {TIMING_OPTIONS.map((opt) => (
              <label class="audit__radio">
                <input type="radio" name="timing" value={opt.value} required />
                <span>{opt.label}</span>
              </label>
            ))}
          </fieldset>
          <p class="audit__error" id="q-timing-error" role="alert" aria-live="polite"></p>
        </section>

        {/* Paso 6 — Email + WA */}
        <section class="audit__step" data-step="6" hidden>
          <h2 class="audit__q-label" tabindex="-1"><span class="audit__q-num">6.</span> ¿Cómo lo contactamos?</h2>
          <p class="audit__q-helper">Confidencial. Solo Efer ve estos datos. Sin SPAM.</p>

          <div class="audit__field">
            <label for="q-firstname" class="audit__q-label as-label">Nombre (opcional)</label>
            <input
              type="text"
              id="q-firstname"
              name="firstname"
              class="audit__input"
              autocomplete="given-name"
              enterkeyhint="next"
              placeholder="Ej. Alejandro"
            />
          </div>

          <div class="audit__field">
            <label for="q-email" class="audit__q-label as-label">Correo electrónico</label>
            <input
              type="email"
              id="q-email"
              name="email"
              class="audit__input"
              inputmode="email"
              enterkeyhint="next"
              autocomplete="email"
              placeholder="usted@surestaurante.com"
              required
              aria-describedby="q-email-error"
            />
            <p class="audit__error" id="q-email-error" role="alert" aria-live="polite"></p>
          </div>

          <div class="audit__field">
            <label for="q-whatsapp" class="audit__q-label as-label">WhatsApp</label>
            <input
              type="tel"
              id="q-whatsapp"
              name="whatsapp"
              class="audit__input"
              inputmode="tel"
              enterkeyhint="send"
              autocomplete="tel"
              pattern="[0-9]*"
              placeholder="10 dígitos, ej. 8110425674"
              required
              aria-describedby="q-whatsapp-error"
            />
            <p class="audit__error" id="q-whatsapp-error" role="alert" aria-live="polite"></p>
          </div>

          <div class="audit__field audit__privacy-check">
            <label class="audit__privacy-label">
              <input
                type="checkbox"
                id="q-privacy"
                name="privacy_accepted"
                value="true"
                required
                aria-describedby="q-privacy-error"
              />
              <span>
                He leído y acepto el{' '}
                <a href="/legales/aviso-de-privacidad" target="_blank" rel="noopener" class="audit__privacy-link">
                  Aviso de Privacidad
                </a>{' '}
                y autorizo a Efer contactarme por correo y WhatsApp para coordinar la auditoría.
              </span>
            </label>
            <p class="audit__error" id="q-privacy-error" role="alert" aria-live="polite"></p>
          </div>

          {/* M6 (TC-02): reversión de riesgo + prueba social junto al submit — sin esto, el
              prospecto llega a "Solicitar auditoría" tras 6 pasos sin ninguna señal de confianza. */}
          <div class="audit__trust" aria-label="Garantías y prueba social">
            <ul class="audit__trust-list" role="list">
              <li class="audit__trust-item">
                <Icon name="shield" size={16} class="audit__trust-icon" />
                <span>Auditoría previa sin costo — si no aplica el programa, se lo decimos antes de firmar.</span>
              </li>
              <li class="audit__trust-item">
                <Icon name="shield" size={16} class="audit__trust-icon" />
                <span>Cancelación sin compromiso en los primeros 30 días.</span>
              </li>
              <li class="audit__trust-item">
                <Icon name="shield" size={16} class="audit__trust-icon" />
                <span>Solo <strong>8 cupos por trimestre</strong> — disponibilidad limitada.</span>
              </li>
            </ul>

            {trustTestimonio && (
              <blockquote class="audit__trust-quote">
                {trustTestimonio.cita && <p>&ldquo;{trustTestimonio.cita}&rdquo;</p>}
                <footer>
                  {trustTestimonio.roleLabel && <span class="audit__trust-role">{trustTestimonio.roleLabel}</span>}
                  <span class="audit__trust-metrica">{trustTestimonio.metrica}</span>
                </footer>
              </blockquote>
            )}
          </div>
        </section>

        {/* Pantalla no-fit */}
        <section class="audit__step audit__step--nofit" data-step="nofit" hidden>
          <h2 class="audit__nofit-title" tabindex="-1">Hoy no encajamos — y se lo decimos sin rodeos.</h2>
          <p class="audit__nofit-copy">
            El Acelerador de 3 Palancas está diseñado para restaurantes con $300,000+/mes de ventas brutas.
            Debajo de ese piso, el ROI no se sostiene y le saldría más caro contratarnos que el problema mismo.
          </p>
          <p class="audit__nofit-copy">
            Lo que sí puede hacer hoy, gratis:
          </p>
          <ul class="audit__nofit-list">
            <li>
              <a href="/diagnostico" class="audit__nofit-link">
                Tomar el diagnóstico de fuga de margen
              </a> — 10 preguntas, recibe estimado + 3 recomendaciones.
            </li>
            <li>
              <a href="/blog" class="audit__nofit-link">
                Leer el blog de NextSwift
              </a> — material operativo para restaurantes en crecimiento.
            </li>
            <li>
              <a href={waFallbackUrl} class="audit__nofit-link" rel="noopener nofollow" target="_blank">
                Escribirle a Efer directo
              </a> si quiere una segunda opinión informal.
            </li>
          </ul>
        </section>

        {/* Hidden — UTM persistidos desde sessionStorage en client-side */}
        <input type="hidden" name="utm_source" id="utm_source" />
        <input type="hidden" name="utm_medium" id="utm_medium" />
        <input type="hidden" name="utm_campaign" id="utm_campaign" />
        <input type="hidden" name="utm_landing" id="utm_landing" />
        <input type="hidden" name="quiz_event_id" id="quiz_event_id" />

        {/* Navegación */}
        <nav class="audit__nav" aria-label="Navegación del formulario">
          <button type="button" id="audit-back" class="btn btn--ghost btn--md" enterkeyhint="previous" hidden>
            ← Atrás
          </button>
          <button type="button" id="audit-next" class="btn btn--primary btn--lg" enterkeyhint="next">
            Siguiente →
          </button>
          <button type="submit" id="audit-submit" class="btn btn--primary btn--lg" enterkeyhint="send" hidden>
            Solicitar auditoría
          </button>
        </nav>
      </form>

      <p class="audit__abandon">
        ¿Prefiere hablar directo? <a href={waFallbackUrl} rel="noopener nofollow" target="_blank">Escríbale a Efer</a>.
      </p>
    </div>
  </Section>
</Base>

<script>
  import { readUTMFromSessionStorage } from '../lib/utm';
  import { readQuizHandoff } from '../lib/quiz';

  const PIXEL_EVENT = 'CompleteRegistration';
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const root = document.getElementById('audit');
  const form = document.getElementById('audit-form') as HTMLFormElement | null;
  if (!root || !form) throw new Error('Audit root missing');

  // F22 — silencia el StickyCTAMobile global mientras el form multi-step está activo
  document.body.dataset.hasStickyForm = 'true';

  const steps = Array.from(root.querySelectorAll<HTMLElement>('.audit__step'));
  const stepLabel = document.getElementById('audit-step-label')!;
  const stepPct = document.getElementById('audit-step-pct')!;
  const progress = document.getElementById('audit-progress') as HTMLProgressElement;
  const btnBack = document.getElementById('audit-back') as HTMLButtonElement;
  const btnNext = document.getElementById('audit-next') as HTMLButtonElement;
  const btnSubmit = document.getElementById('audit-submit') as HTMLButtonElement;
  const liveRegion = document.getElementById('audit-live')!;

  const TOTAL_STEPS = Number(root.dataset.totalSteps ?? 6);

  // M16 — inyecta el contexto del paso en la región aria-live. El setTimeout deja que el
  // cambio de paso (hidden/visible) se asiente en el DOM antes de que el lector lo anuncie.
  function announce(message: string): void {
    window.setTimeout(() => { liveRegion.textContent = message; }, 60);
  }

  // Hidratar UTMs desde sessionStorage y URL params (?eid= viene del quiz)
  const utm = readUTMFromSessionStorage();
  if (utm) {
    (document.getElementById('utm_source') as HTMLInputElement).value = utm.source;
    (document.getElementById('utm_medium') as HTMLInputElement).value = utm.medium;
    (document.getElementById('utm_campaign') as HTMLInputElement).value = utm.campaign;
    (document.getElementById('utm_landing') as HTMLInputElement).value = utm.landing;
  }
  const urlParams = new URLSearchParams(window.location.search);
  const eidFromQuiz = urlParams.get('eid');
  if (eidFromQuiz) {
    (document.getElementById('quiz_event_id') as HTMLInputElement).value = eidFromQuiz;
  }

  // M8 (TC-05): si llega del CTA del quiz y el handoff sigue en sessionStorage,
  // prefila salesrange/painprimary y saltamos los pasos 1-2 (BOFU de 6 a 4 pasos
  // para el lead ya calificado por el quiz). Match parcial (solo uno de los dos
  // valores reconocido) se trata como catálogo desalineado: no se salta nada.
  let visible = [1, 2, 3, 4, 5, 6];
  let nofitFromHandoff = false;
  if (urlParams.get('from') === 'diagnostico') {
    const handoff = readQuizHandoff();
    if (handoff) {
      const salesRadio = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="salesrange"]'))
        .find((el) => el.value === handoff.salesrange);
      const painRadio = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="painprimary"]'))
        .find((el) => el.value === handoff.painprimary);
      if (salesRadio && painRadio) {
        salesRadio.checked = true;
        painRadio.checked = true;
        visible = [3, 4, 5, 6];
        nofitFromHandoff = salesRadio.dataset.disqualify === 'true';
      }
    }
  }

  type State = { step: number; nofit: boolean };
  let state: State = { step: visible[0], nofit: nofitFromHandoff };

  function stepEl(n: number | 'nofit'): HTMLElement | undefined {
    return steps.find((s) => s.dataset.step === String(n));
  }

  function render(): void {
    steps.forEach((s) => {
      s.hidden = true;
      s.removeAttribute('aria-current');
    });
    if (state.nofit) {
      stepEl('nofit')!.hidden = false;
      stepEl('nofit')!.setAttribute('aria-current', 'step');
      btnBack.hidden = true;
      btnNext.hidden = true;
      btnSubmit.hidden = true;
      stepLabel.textContent = 'No es fit con el Acelerador';
      stepPct.textContent = '';
      progress.value = 0;
      // M16 — anunciar y enfocar el encabezado del rebote no-fit (antes no había gestión de foco)
      const nofitHeading = stepEl('nofit')!.querySelector<HTMLElement>('.audit__nofit-title');
      announce(nofitHeading?.textContent?.trim() ?? 'No es fit con el Acelerador');
      nofitHeading?.focus({ preventScroll: false });
      return;
    }
    const idx = visible.indexOf(state.step);
    const total = visible.length;
    const activeStep = stepEl(state.step)!;
    activeStep.hidden = false;
    activeStep.setAttribute('aria-current', 'step');
    btnBack.hidden = idx === 0;
    btnNext.hidden = idx === total - 1;
    btnSubmit.hidden = idx !== total - 1;
    stepLabel.textContent = `Paso ${idx + 1} de ${total}`;
    const pct = Math.round((idx / total) * 100);
    stepPct.textContent = `${pct}%`;
    progress.value = pct;
    // M16 — anunciar la pregunta y mover el foco al encabezado del paso (no al input): el lector
    // lee el contexto antes del control; el Tab posterior lleva al primer input visible.
    const heading = activeStep.querySelector<HTMLElement>('h2.audit__q-label');
    announce(`Paso ${idx + 1} de ${total}: ${heading?.textContent?.trim() ?? ''}`);
    if (heading) heading.focus({ preventScroll: false });
  }

  function clearError(stepNum: number): void {
    const el = stepEl(stepNum);
    if (!el) return;
    el.querySelectorAll('.audit__error').forEach((p) => (p.textContent = ''));
  }

  function setError(stepNum: number, errorId: string, msg: string): void {
    const el = stepEl(stepNum);
    if (!el) return;
    const errEl = el.querySelector<HTMLElement>(`#${errorId}`);
    if (errEl) errEl.textContent = msg;
  }

  function getRadioValue(name: string): string | null {
    const checked = form!.querySelector<HTMLInputElement>(`input[name="${name}"]:checked`);
    return checked ? checked.value : null;
  }

  // M9 (TC-08/TC-09): extraídas para poder validar en blur (feedback inmediato) y en
  // validateStep (red de seguridad al pulsar Siguiente/Enviar) sin duplicar mensajes.
  function validateUnitsField(): boolean {
    const v = (form!.elements.namedItem('units') as HTMLInputElement).value.trim();
    const num = Number(v);
    if (!v || !Number.isFinite(num) || num < 1 || num > 999) {
      setError(3, 'q-units-error', 'Ingrese un número entre 1 y 999.');
      return false;
    }
    setError(3, 'q-units-error', '');
    return true;
  }

  function validateEmailField(): boolean {
    const email = (form!.elements.namedItem('email') as HTMLInputElement).value.trim().toLowerCase();
    if (!email || !EMAIL_RE.test(email)) {
      setError(6, 'q-email-error', 'Correo inválido.');
      return false;
    }
    setError(6, 'q-email-error', '');
    return true;
  }

  function validateWaField(): boolean {
    const wa = (form!.elements.namedItem('whatsapp') as HTMLInputElement).value.trim();
    const digits = wa.replace(/\D/g, '');
    const tenDigits = digits.length === 10 || (digits.length === 12 && digits.startsWith('52'));
    if (!wa || !tenDigits) {
      setError(6, 'q-whatsapp-error', 'WhatsApp: 10 dígitos (con o sin +52).');
      return false;
    }
    setError(6, 'q-whatsapp-error', '');
    return true;
  }

  (form.elements.namedItem('units') as HTMLInputElement)?.addEventListener('blur', validateUnitsField);
  (form.elements.namedItem('email') as HTMLInputElement)?.addEventListener('blur', validateEmailField);
  (form.elements.namedItem('whatsapp') as HTMLInputElement)?.addEventListener('blur', validateWaField);

  function validateStep(n: number): boolean {
    clearError(n);
    if (n === 1) {
      const v = getRadioValue('salesrange');
      if (!v) { setError(1, 'q-salesrange-error', 'Elija un rango.'); return false; }
      return true;
    }
    if (n === 2) {
      const v = getRadioValue('painprimary');
      if (!v) { setError(2, 'q-painprimary-error', 'Elija el cuello principal.'); return false; }
      return true;
    }
    if (n === 3) {
      return validateUnitsField();
    }
    if (n === 4) {
      const v = getRadioValue('decisor_role');
      if (!v) { setError(4, 'q-decisor_role-error', 'Elija su rol.'); return false; }
      return true;
    }
    if (n === 5) {
      const v = getRadioValue('timing');
      if (!v) { setError(5, 'q-timing-error', 'Elija una ventana.'); return false; }
      return true;
    }
    if (n === 6) {
      const emailOk = validateEmailField();
      const waOk = validateWaField();
      const privacy = (form!.elements.namedItem('privacy_accepted') as HTMLInputElement)?.checked;
      let ok = emailOk && waOk;
      if (!privacy) {
        setError(6, 'q-privacy-error', 'Debe aceptar el Aviso de Privacidad para continuar.');
        ok = false;
      } else {
        setError(6, 'q-privacy-error', '');
      }
      return ok;
    }
    return true;
  }

  // Step 1: si elige "<300k" -> rebote inmediato a pantalla no-fit
  form.addEventListener('change', (ev) => {
    const t = ev.target as HTMLInputElement;
    if (t.name === 'salesrange' && t.dataset.disqualify === 'true') {
      state.nofit = true;
      render();
    }
  });

  btnNext.addEventListener('click', () => {
    if (!validateStep(state.step)) return;
    const idx = visible.indexOf(state.step);
    if (idx < visible.length - 1) {
      state.step = visible[idx + 1];
      render();
    }
  });

  btnBack.addEventListener('click', () => {
    const idx = visible.indexOf(state.step);
    if (idx > 0) {
      state.step = visible[idx - 1];
      render();
    }
  });

  // Enter avanza salvo en radio fieldset (que ya tiene su navegación natural)
  form.addEventListener('keydown', (ev) => {
    if (ev.key !== 'Enter') return;
    const target = ev.target as HTMLElement;
    if (target.tagName === 'TEXTAREA') return;
    if (target.tagName === 'INPUT' && (target as HTMLInputElement).type === 'submit') return;
    ev.preventDefault();
    if (!btnSubmit.hidden) {
      btnSubmit.click();
    } else if (!btnNext.hidden) {
      btnNext.click();
    }
  });

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!validateStep(TOTAL_STEPS)) return;
    btnSubmit.disabled = true;
    btnSubmit.textContent = 'Enviando…';

    const eventId = generateEventId();

    const emailRaw = (form.elements.namedItem('email') as HTMLInputElement).value.trim().toLowerCase();
    const waRaw = (form.elements.namedItem('whatsapp') as HTMLInputElement).value.trim();
    const waDigits = waRaw.replace(/\D/g, '');
    const whatsapp = waDigits.length === 10 ? `+52${waDigits}` : `+${waDigits}`;

    const payload = {
      source: 'form_auditoria' as const,
      event_id: eventId,
      email: emailRaw,
      whatsapp,
      firstname: (form.elements.namedItem('firstname') as HTMLInputElement).value.trim(),
      salesrange: getRadioValue('salesrange'),
      painprimary: getRadioValue('painprimary'),
      units: (form.elements.namedItem('units') as HTMLInputElement).value.trim(),
      decisor_role: getRadioValue('decisor_role'),
      timing: getRadioValue('timing'),
      utm_source: (form.elements.namedItem('utm_source') as HTMLInputElement).value,
      utm_medium: (form.elements.namedItem('utm_medium') as HTMLInputElement).value,
      utm_campaign: (form.elements.namedItem('utm_campaign') as HTMLInputElement).value,
      utm_landing: (form.elements.namedItem('utm_landing') as HTMLInputElement).value,
      quiz_event_id: (form.elements.namedItem('quiz_event_id') as HTMLInputElement).value,
    };

    let redirectTo = '/gracias-auditoria';
    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = (await res.json().catch(() => ({}))) as { success?: boolean; redirect?: string; error?: string };
      if (!res.ok || !data.success) {
        console.error('[audit] /api/lead falló', res.status, data);
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Solicitar auditoría';
        setError(TOTAL_STEPS, 'q-email-error', data.error ?? 'No pudimos enviar la solicitud. Intente de nuevo o escriba a Efer.');
        return;
      }
      if (data.redirect) redirectTo = data.redirect;
    } catch (err) {
      console.error('[audit] network error', err);
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Solicitar auditoría';
      setError(TOTAL_STEPS, 'q-email-error', 'Sin conexión. Intente de nuevo en unos segundos.');
      return;
    }

    // Pixel CompleteRegistration (client) — mismo event_id que CAPI server
    try {
      const fbq = (window as unknown as { fbq?: (...args: unknown[]) => void }).fbq;
      if (typeof fbq === 'function') {
        fbq(
          'track',
          PIXEL_EVENT,
          {
            content_name: 'form_auditoria',
            salesrange: payload.salesrange,
            painprimary: payload.painprimary,
          },
          { eventID: eventId },
        );
      }
    } catch (err) {
      console.warn('[audit] fbq CompleteRegistration falló.', err);
    }

    window.location.assign(redirectTo);
  });

  function generateEventId(): string {
    const c = window.crypto;
    if (c && typeof c.randomUUID === 'function') {
      return c.randomUUID().replace(/-/g, '').slice(0, 16);
    }
    return Math.random().toString(36).slice(2, 10) + Date.now().toString(36).slice(-6);
  }

  render();
</script>

