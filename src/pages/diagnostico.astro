---
/**
 * /diagnostico — Quiz lead magnet "Diagnóstico de fuga de margen".
 * P11 / Fase 13. Spec: PLAN_IMPLEMENTACION_NEXTSWIFT_CONDENSADO.md §P11.
 *
 * Spec resumido:
 * - 8 preguntas placeholder (TODO DH-NEW-02), todas por rango/radio (M7) + 1 paso captura email/WA + 1 paso resultado.
 * - JS vanilla. State en memoria + sessionStorage. Sin framework.
 * - Cálculo determinístico en src/lib/quiz.ts (no aleatorio).
 * - Submit -> POST mocked /api/lead.ts (P13 entrega endpoint real) + Pixel Lead + CAPI Lead dedup por event_id.
 * - CTA primario al resultado: /auditoria (404 hasta P13). CTA ghost: wa.me UTM-prefilled (P12 entregará helper).
 *
 * M7 (plan_de_mejoras_v3.md, TC-03/TC-04): la fricción TOFU estaba invertida — el
 * quiz gratuito abría con facturación exacta en input abierto mientras el BOFU
 * (/auditoria) ya usaba rangos para lo mismo. Se nivela: paso 1 (y el resto de
 * preguntas numéricas) por rango/radio, con "no lo sé" neutral en food cost y
 * comisión de delivery. Detalle de la fórmula en src/lib/quiz.ts.
 */
import Base from '../layouts/Base.astro';
import Section from '../components/ui/Section.astro';
import Heading from '../components/ui/Heading.astro';
import Body from '../components/ui/Body.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import { QUESTIONS } from '../lib/quiz';
import { buildWaUrl } from '../lib/whatsapp-url';

const totalSteps = QUESTIONS.length + 2; // preguntas + captura + resultado
const waPrefillUrl = buildWaUrl({
  source: 'quiz',
  content: 'diagnostico_fallback',
  context: 'pre_resultado',
  customMessage: 'Hola Efer, abandoné el diagnóstico de fuga de margen y prefiero hablar directo. Quiero',
});
---

<Base
  title="Diagnóstico de fuga de margen — NextSwift"
  description={`Responda ${QUESTIONS.length} preguntas rápidas (todas de opción múltiple) y reciba un estimado personalizado de cuánto pierde su restaurante al mes — más 3 recomendaciones específicas. 1-2 minutos, sin sesión de ventas.`}
  noindex={true}
>
  <Section width="narrow" spacing="lg" id="quiz-section">
    <header class="quiz-header">
      <Eyebrow>Diagnóstico · 1-2 minutos</Eyebrow>
      <Heading as="h1" size="h1">Diagnóstico de fuga de margen</Heading>
      <Body size="lead" tone="muted">
        Responda {QUESTIONS.length} preguntas de opción múltiple y le devolvemos un estimado del dinero que pierde
        su restaurante al mes, más 3 recomendaciones específicas. Sin sesión de ventas.
      </Body>
    </header>

    {/* TODO DH-NEW-02: reemplazar las 8 preguntas placeholder por la lista canónica que Efer entregará. */}
    <div
      id="quiz"
      class="quiz"
      data-total-steps={totalSteps}
      aria-live="polite"
    >
      <div class="quiz__progress" role="group" aria-label="Progreso del diagnóstico">
        <div class="quiz__progress-meta">
          <span id="quiz-step-label">Pregunta 1 de {QUESTIONS.length}</span>
          <span id="quiz-step-pct">0%</span>
        </div>
        <progress id="quiz-progress" max="100" value="0" aria-label="Progreso"></progress>
      </div>

      {/* M16 — anuncia "Pregunta X de N: <pregunta>" a lectores de pantalla antes de mover el foco al h2 */}
      <div id="quiz-live" class="sr-only" aria-live="polite" aria-atomic="true"></div>

      {QUESTIONS.map((q, idx) => (
        <section
          class="quiz__step"
          data-step={idx + 1}
          data-question-id={q.id}
          data-question-type={q.type}
          hidden
        >
          <h2 class="quiz__q-label" id={`q-${q.id}-label`} tabindex="-1">
            <span class="quiz__q-num">{idx + 1}.</span> {q.label}
          </h2>
          {q.helper && <p class="quiz__q-helper">{q.helper}</p>}

          {q.type === 'number' && (
            <div class="quiz__input-row">
              {q.unit && <span class="quiz__unit" aria-hidden="true">{q.unit}</span>}
              <input
                type="number"
                inputmode={q.inputmode ?? 'numeric'}
                enterkeyhint="next"
                pattern="[0-9]*"
                min={q.min}
                max={q.max}
                step={q.step}
                name={q.id}
                id={`q-${q.id}`}
                class="quiz__input"
                required
                autocomplete="off"
                aria-labelledby={`q-${q.id}-label`}
                aria-describedby={`q-${q.id}-error`}
              />
            </div>
          )}

          {q.type === 'radio' && q.options && (
            <fieldset class="quiz__radios" id={`q-${q.id}`} aria-describedby={`q-${q.id}-error`}>
              <legend class="sr-only">{q.label}</legend>
              {q.options.map((opt) => (
                <label class="quiz__radio">
                  <input type="radio" name={q.id} value={opt.value} required />
                  <span>{opt.label}</span>
                </label>
              ))}
            </fieldset>
          )}

          <p class="quiz__error" id={`q-${q.id}-error`} role="alert" aria-live="polite"></p>
        </section>
      ))}

      {/* Paso captura email + WhatsApp (penúltimo) */}
      <section class="quiz__step quiz__step--capture" data-step={QUESTIONS.length + 1} hidden>
        <div class="quiz__pre-result" id="quiz-pre-result" aria-live="polite">
          <p class="quiz__pre-result-eyebrow" id="quiz-pre-eyebrow">Cálculo terminado</p>
          {/* M2: arranca con guion (nunca "$0"); JS lo rellena con la cifra real o lo oculta si la fuga es 0. */}
          <p class="quiz__pre-result-amount" id="quiz-pre-amount" aria-hidden="true">—</p>
          <p class="quiz__pre-result-copy" data-variant="leak">
            Esto es solo la cifra. Para recibir las <strong>3 recomendaciones específicas</strong> de su caso,
            déjenos cómo contactarlo.
          </p>
          <p class="quiz__pre-result-copy" data-variant="no-leak" hidden>
            Con sus respuestas no salta una fuga evidente — pero el detalle fino sólo aparece con un par de datos
            más. Déjenos su contacto y le mandamos las <strong>3 recomendaciones específicas</strong> de su caso.
          </p>
        </div>

        <div class="quiz__field">
          <label for="q-email" class="quiz__q-label as-label">Correo electrónico</label>
          <input
            type="email"
            id="q-email"
            name="email"
            class="quiz__input"
            inputmode="email"
            enterkeyhint="next"
            autocomplete="email"
            placeholder="usted@surestaurante.com"
            required
            aria-describedby="q-email-error"
          />
          <p class="quiz__error" id="q-email-error" role="alert" aria-live="polite"></p>
        </div>

        <div class="quiz__field">
          <label for="q-wa" class="quiz__q-label as-label">WhatsApp <span class="quiz__optional">(opcional)</span></label>
          <input
            type="tel"
            id="q-wa"
            name="whatsapp"
            class="quiz__input"
            inputmode="tel"
            enterkeyhint="send"
            autocomplete="tel"
            pattern="[0-9]*"
            placeholder="10 dígitos, ej. 8110425674"
            aria-describedby="q-wa-error"
          />
          <p class="quiz__error" id="q-wa-error" role="alert" aria-live="polite"></p>
        </div>

        <p class="quiz__legal">
          Sus respuestas son confidenciales. Sólo usamos el contacto para enviarle el reporte y, si aplica,
          coordinar la auditoría de viabilidad. Sin SPAM.
        </p>
      </section>

      {/* Paso resultado (último) */}
      <section class="quiz__step quiz__step--result" data-step={QUESTIONS.length + 2} hidden>
        <p class="quiz__result-eyebrow">Diagnóstico personalizado</p>
        {/* M2: el H2 lo construye JS (paintResult) — con cifra si hay fuga, o copy alternativo si es 0. Nunca "$0". */}
        <h2 class="quiz__result-h2" id="quiz-result-h2"></h2>
        <p class="quiz__result-arquetipo" id="quiz-result-arquetipo"></p>
        <ol class="quiz__result-recs" id="quiz-result-recs"></ol>

        <div class="quiz__result-ctas">
          <a
            href="/auditoria?from=diagnostico"
            class="btn btn--primary btn--lg btn--full"
            id="quiz-cta-primary"
            data-cta="quiz_to_auditoria"
          >
            Solicitar auditoría de viabilidad
          </a>
          <a
            href={waPrefillUrl}
            id="quiz-cta-wa"
            class="btn btn--ghost btn--md btn--full"
            rel="noopener nofollow"
            target="_blank"
            data-cta="quiz_to_whatsapp"
          >
            Hablar con Efer ahora
          </a>
        </div>

        <p class="quiz__result-foot">
          El diagnóstico se calcula con sus respuestas y la fórmula declarada en
          <code>src/lib/quiz.ts</code>. La auditoría real confirma o corrige el número.
        </p>
      </section>

      {/* Navegación */}
      <nav class="quiz__nav" aria-label="Navegación del quiz">
        <button type="button" id="quiz-back" class="btn btn--ghost btn--md" enterkeyhint="previous" hidden>
          ← Atrás
        </button>
        <button type="button" id="quiz-next" class="btn btn--primary btn--lg" enterkeyhint="next">
          Siguiente →
        </button>
        <button type="button" id="quiz-submit" class="btn btn--primary btn--lg" enterkeyhint="send" hidden>
          Ver mi diagnóstico
        </button>
      </nav>

      <p class="quiz__abandon">
        ¿Prefiere saltar el quiz? <a href={waPrefillUrl} rel="noopener nofollow" target="_blank">Escríbale a Efer directo</a>.
      </p>
    </div>
  </Section>
</Base>

<script>
  import {
    QUESTIONS,
    answersToInputs,
    computeMarginLeak,
    cuelloToPainPrimary,
    writeQuizHandoff,
    type QuizAnswer,
    type QuizResult,
  } from '../lib/quiz';

  const STORAGE_KEY = 'nextswift_quiz_state_v1';
  const PIXEL_EVENT = 'Lead';
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  type State = {
    step: number;                     // 1..totalSteps
    answers: Record<string, string | number>;
  };

  const quizRoot = document.getElementById('quiz');
  if (!(quizRoot instanceof HTMLElement)) throw new Error('Quiz root missing');

  // F22 — silencia el StickyCTAMobile global mientras el quiz está activo
  document.body.dataset.hasStickyForm = 'true';

  const stepLabel = document.getElementById('quiz-step-label')!;
  const stepPct = document.getElementById('quiz-step-pct')!;
  const progress = document.getElementById('quiz-progress') as HTMLProgressElement;
  const btnBack = document.getElementById('quiz-back') as HTMLButtonElement;
  const btnNext = document.getElementById('quiz-next') as HTMLButtonElement;
  const btnSubmit = document.getElementById('quiz-submit') as HTMLButtonElement;
  const liveRegion = document.getElementById('quiz-live')!;
  const steps = Array.from(quizRoot.querySelectorAll<HTMLElement>('.quiz__step'));

  // M16 — inyecta el contexto del paso en la región aria-live. El setTimeout deja que el
  // cambio de paso (hidden/visible) se asiente en el DOM antes de que el lector lo anuncie.
  function announce(message: string): void {
    window.setTimeout(() => { liveRegion.textContent = message; }, 60);
  }

  const captureStepIdx = QUESTIONS.length + 1;
  const resultStepIdx = QUESTIONS.length + 2;

  function loadState(): State {
    try {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return { step: 1, answers: {} };
      const parsed = JSON.parse(raw) as State;
      if (typeof parsed.step !== 'number' || parsed.step < 1 || parsed.step > QUESTIONS.length) {
        return { step: 1, answers: parsed.answers ?? {} };
      }
      return parsed;
    } catch {
      return { step: 1, answers: {} };
    }
  }

  function saveState(): void {
    try {
      // No persistimos email/wa por privacidad
      const persisted = { ...state, answers: { ...state.answers } };
      delete persisted.answers.email;
      delete persisted.answers.whatsapp;
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(persisted));
    } catch {
      // sessionStorage puede no estar disponible (modo privado iOS); seguimos sin persistir.
    }
  }

  const state: State = loadState();

  function render(): void {
    steps.forEach((s) => {
      const idx = Number(s.dataset.step);
      s.hidden = idx !== state.step;
    });

    const isCapture = state.step === captureStepIdx;
    const isResult = state.step === resultStepIdx;
    const isQuestion = !isCapture && !isResult;

    // Progreso (1..QUESTIONS.length -> 0..90%, captura 95%, resultado 100%)
    let pct = 0;
    let label = '';
    if (isQuestion) {
      pct = Math.round(((state.step - 1) / QUESTIONS.length) * 90);
      label = `Pregunta ${state.step} de ${QUESTIONS.length}`;
    } else if (isCapture) {
      pct = 95;
      label = 'Contacto — penúltimo paso';
    } else {
      pct = 100;
      label = 'Diagnóstico listo';
    }
    progress.value = pct;
    stepPct.textContent = `${pct}%`;
    stepLabel.textContent = label;

    btnBack.hidden = state.step <= 1 || isResult;
    btnNext.hidden = isCapture || isResult;
    btnSubmit.hidden = !isCapture;

    if (isQuestion) {
      const currentSection = steps.find((s) => Number(s.dataset.step) === state.step);
      if (currentSection) {
        const qid = currentSection.dataset.questionId!;
        const saved = state.answers[qid];
        if (saved !== undefined && saved !== '') {
          if (currentSection.dataset.questionType === 'number') {
            const input = currentSection.querySelector<HTMLInputElement>('input[type="number"]');
            if (input) input.value = String(saved);
          } else {
            const radio = currentSection.querySelector<HTMLInputElement>(`input[type="radio"][value="${saved}"]`);
            if (radio) radio.checked = true;
          }
        }
        // M16 — anunciar la pregunta y mover el foco al encabezado (no al input): el lector
        // lee el contexto antes del control; el Tab posterior lleva al primer input.
        const heading = currentSection.querySelector<HTMLElement>('.quiz__q-label');
        announce(`${label}: ${QUESTIONS[state.step - 1].label}`);
        heading?.focus({ preventScroll: true });
      }
    }

    if (isCapture) {
      const inputs = answersToInputs(answersToArray());
      const result = computeMarginLeak(inputs);
      renderPreResult(result);
    }

    if (isResult) {
      paintResult();
    }
  }

  function formatMXN(n: number): string {
    return '$' + n.toLocaleString('es-MX');
  }

  // M2 — pinta el bloque previo a la captura sin mostrar "$0" nunca.
  // leakMXN > 0  -> cifra real + copy "esto es solo la cifra".
  // leakMXN == 0 -> oculta la cifra y muestra copy alternativo (sin fabricar números).
  function renderPreResult(result: QuizResult): void {
    const hasLeak = result.leakMXN > 0;
    const amountEl = document.getElementById('quiz-pre-amount');
    const eyebrowEl = document.getElementById('quiz-pre-eyebrow');
    const root = document.getElementById('quiz-pre-result');

    if (amountEl) {
      if (hasLeak) {
        amountEl.textContent = formatMXN(result.leakMXN) + '/mes';
        amountEl.hidden = false;
        amountEl.removeAttribute('aria-hidden');
      } else {
        amountEl.hidden = true;
        amountEl.setAttribute('aria-hidden', 'true');
      }
    }
    if (eyebrowEl) eyebrowEl.textContent = hasLeak ? 'Cálculo terminado' : 'Casi listo';
    if (root) {
      root.querySelectorAll<HTMLElement>('.quiz__pre-result-copy').forEach((el) => {
        const variant = el.getAttribute('data-variant');
        el.hidden = hasLeak ? variant !== 'leak' : variant !== 'no-leak';
      });
    }
  }

  function answersToArray(): QuizAnswer[] {
    return Object.entries(state.answers)
      .filter(([id]) => QUESTIONS.some((q) => q.id === id))
      .map(([id, value]) => ({ id, value: value as string | number }));
  }

  function readCurrentStepValue(): { id: string; value: string | number } | null {
    const currentSection = steps.find((s) => Number(s.dataset.step) === state.step);
    if (!currentSection) return null;
    const qid = currentSection.dataset.questionId;
    const qtype = currentSection.dataset.questionType;
    if (!qid) return null;

    if (qtype === 'number') {
      const input = currentSection.querySelector<HTMLInputElement>('input[type="number"]');
      if (!input) return null;
      const raw = input.value.trim();
      if (raw === '') return { id: qid, value: '' };
      const num = Number(raw);
      if (!Number.isFinite(num)) return { id: qid, value: '' };
      return { id: qid, value: num };
    } else {
      const checked = currentSection.querySelector<HTMLInputElement>('input[type="radio"]:checked');
      if (!checked) return { id: qid, value: '' };
      return { id: qid, value: checked.value };
    }
  }

  function showError(stepEl: HTMLElement | null, message: string): void {
    if (!stepEl) return;
    const errEl = stepEl.querySelector<HTMLElement>('.quiz__error');
    if (errEl) errEl.textContent = message;
  }

  function clearError(stepEl: HTMLElement | null): void {
    if (!stepEl) return;
    const errEl = stepEl.querySelector<HTMLElement>('.quiz__error');
    if (errEl) errEl.textContent = '';
  }

  // M9 (TC-08/TC-09): extraídas para poder validar en blur (feedback inmediato) y en
  // validateAndCommit (red de seguridad al pulsar Siguiente/Enviar) sin duplicar mensajes.
  function validateEmailField(): boolean {
    const input = document.getElementById('q-email') as HTMLInputElement;
    const err = document.getElementById('q-email-error');
    const email = input.value.trim();
    if (!email || !EMAIL_RE.test(email)) {
      if (err) err.textContent = 'Ingrese un correo válido.';
      return false;
    }
    if (err) err.textContent = '';
    return true;
  }

  function validateWaField(): boolean {
    const input = document.getElementById('q-wa') as HTMLInputElement;
    const err = document.getElementById('q-wa-error');
    const wa = input.value.trim().replace(/\D/g, '');
    // M13: WA opcional en TOFU; solo validar formato si el usuario lo escribió.
    if (wa && (wa.length < 10 || wa.length > 13)) {
      if (err) err.textContent = 'Ingrese 10 dígitos (sin lada internacional).';
      return false;
    }
    if (err) err.textContent = '';
    return true;
  }

  document.getElementById('q-email')?.addEventListener('blur', validateEmailField);
  document.getElementById('q-wa')?.addEventListener('blur', validateWaField);

  // M9 — min/max en blur para preguntas 'number' (infra genérica de quiz.ts; sin uso
  // activo hoy porque las 8 preguntas actuales son 'radio', ver M7). focusout burbujea,
  // a diferencia de blur, por eso se delega en quizRoot en vez de por input.
  quizRoot.addEventListener('focusout', (ev) => {
    const target = ev.target as HTMLElement;
    if (!(target instanceof HTMLInputElement) || target.type !== 'number') return;
    const section = target.closest<HTMLElement>('.quiz__step');
    if (!section || section.dataset.questionType !== 'number') return;
    const q = QUESTIONS.find((qq) => qq.id === section.dataset.questionId);
    const errEl = section.querySelector<HTMLElement>('.quiz__error');
    if (!q || !errEl) return;
    const raw = target.value.trim();
    if (raw === '') return; // vacío lo cubre la red de seguridad al avanzar
    const num = Number(raw);
    if (!Number.isFinite(num)) return;
    if (q.min !== undefined && num < q.min) {
      errEl.textContent = `Mínimo aceptado: ${q.min}.`;
      return;
    }
    if (q.max !== undefined && num > q.max) {
      errEl.textContent = `Máximo aceptado: ${q.max}.`;
      return;
    }
    errEl.textContent = '';
  });

  function validateAndCommit(): boolean {
    const currentSection = steps.find((s) => Number(s.dataset.step) === state.step) ?? null;
    clearError(currentSection);

    if (state.step <= QUESTIONS.length) {
      const q = QUESTIONS[state.step - 1];
      const read = readCurrentStepValue();
      if (!read || read.value === '') {
        showError(currentSection, 'Responda esta pregunta para continuar.');
        return false;
      }
      if (q.type === 'number' && typeof read.value === 'number') {
        if (q.min !== undefined && read.value < q.min) {
          showError(currentSection, `Mínimo aceptado: ${q.min}.`);
          return false;
        }
        if (q.max !== undefined && read.value > q.max) {
          showError(currentSection, `Máximo aceptado: ${q.max}.`);
          return false;
        }
      }
      state.answers[q.id] = read.value;
      saveState();
      return true;
    }

    if (state.step === captureStepIdx) {
      const emailOk = validateEmailField();
      const waOk = validateWaField();
      if (!emailOk || !waOk) return false;
      state.answers.email = (document.getElementById('q-email') as HTMLInputElement).value.trim();
      state.answers.whatsapp = (document.getElementById('q-wa') as HTMLInputElement).value.trim().replace(/\D/g, '');
      return true;
    }

    return true;
  }

  btnNext.addEventListener('click', () => {
    if (!validateAndCommit()) return;
    if (state.step < QUESTIONS.length) {
      state.step += 1;
      saveState();
      render();
    } else if (state.step === QUESTIONS.length) {
      state.step = captureStepIdx;
      render();
    }
  });

  btnBack.addEventListener('click', () => {
    if (state.step === captureStepIdx) {
      state.step = QUESTIONS.length;
      render();
      return;
    }
    if (state.step > 1) {
      state.step -= 1;
      saveState();
      render();
    }
  });

  btnSubmit.addEventListener('click', async () => {
    if (!validateAndCommit()) return;
    await handleSubmit();
  });

  // Enter avanza si no estamos en radio fieldset
  quizRoot.addEventListener('keydown', (ev) => {
    if (ev.key !== 'Enter') return;
    const target = ev.target as HTMLElement;
    if (target.tagName === 'TEXTAREA') return;
    ev.preventDefault();
    if (!btnSubmit.hidden) {
      btnSubmit.click();
    } else if (!btnNext.hidden) {
      btnNext.click();
    }
  });

  async function handleSubmit(): Promise<void> {
    btnSubmit.disabled = true;
    btnSubmit.textContent = 'Calculando…';

    const inputs = answersToInputs(answersToArray());
    const result = computeMarginLeak(inputs);
    const eventId = generateEventId();

    const payload = {
      source: 'quiz',
      event_id: eventId,
      email: state.answers.email,
      whatsapp: state.answers.whatsapp,
      inputs,
      result,
      ts: new Date().toISOString(),
    };

    // POST /api/lead.ts — P11 mocked (endpoint llega en P13). Best-effort, NO bloquea UX.
    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        console.warn(`[quiz] /api/lead respondió ${res.status} (esperado hasta P13).`);
      }
    } catch (err) {
      console.warn('[quiz] /api/lead no disponible aún (P13 lo entrega).', err);
    }

    // Pixel Lead (client) + CAPI Lead (server) — dedup por mismo event_id
    try {
      const fbq = (window as unknown as { fbq?: (...args: unknown[]) => void }).fbq;
      if (typeof fbq === 'function') {
        fbq(
          'track',
          PIXEL_EVENT,
          {
            content_name: 'quiz_diagnostico',
            value: result.leakMXN,
            currency: 'MXN',
          },
          { eventID: eventId },
        );
      }
    } catch (err) {
      console.warn('[quiz] fbq Lead falló.', err);
    }

    try {
      await fetch('/api/capi', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          event_name: PIXEL_EVENT,
          event_id: eventId,
          url: window.location.href,
          user_data: {},
          custom_data: {
            content_name: 'quiz_diagnostico',
            value: result.leakMXN,
            currency: 'MXN',
          },
        }),
      });
    } catch (err) {
      console.warn('[quiz] CAPI Lead falló.', err);
    }

    // M8 (TC-05): persiste facturación + dolor ANTES de limpiar, para que /auditoria
    // no vuelva a preguntarlos (handoff sobrevive el borrado de STORAGE_KEY de abajo).
    const salesrange = String(state.answers.ventas_totales ?? '');
    if (salesrange) {
      writeQuizHandoff({ salesrange, painprimary: cuelloToPainPrimary(inputs.cuello) });
    }

    // Limpia el state antes de mostrar resultado para que un nuevo quiz parta limpio
    try { sessionStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }

    // Avanza a paso resultado (in-page). El plan condensado también admite redirect a /gracias-quiz;
    // se prioriza mostrar el resultado primero (principio "valor antes de captura — y después de captura,
    // entrega el valor visible") y dejar los CTAs gobernar el siguiente paso.
    state.step = resultStepIdx;
    (resultStepEl()).dataset.eid = eventId;
    render();
  }

  function resultStepEl(): HTMLElement {
    return steps.find((s) => Number(s.dataset.step) === resultStepIdx)!;
  }

  function paintResult(): void {
    const inputs = answersToInputs(answersToArray());
    const result: QuizResult = computeMarginLeak(inputs);

    // M2 — H2 construido en JS: con cifra si hay fuga, copy alternativo si es 0. Nunca "$0".
    const h2 = document.getElementById('quiz-result-h2');
    if (h2) {
      h2.textContent = '';
      if (result.leakMXN > 0) {
        h2.appendChild(document.createTextNode('Fuga estimada: '));
        const span = document.createElement('span');
        span.textContent = formatMXN(result.leakMXN);
        h2.appendChild(span);
        h2.appendChild(document.createTextNode(' MXN/mes'));
      } else {
        h2.textContent = 'Su operación no muestra una fuga evidente — pero sí 3 ajustes de alto retorno.';
      }
    }

    const arqEl = document.getElementById('quiz-result-arquetipo');
    if (arqEl) arqEl.textContent = result.arquetipo;

    const recsEl = document.getElementById('quiz-result-recs');
    if (recsEl) {
      recsEl.innerHTML = '';
      result.recommendations.forEach((rec) => {
        const li = document.createElement('li');
        li.textContent = rec;
        recsEl.appendChild(li);
      });
    }

    const eid = resultStepEl().dataset.eid ?? '';
    const ctaPrimary = document.getElementById('quiz-cta-primary') as HTMLAnchorElement | null;
    if (ctaPrimary && eid) {
      ctaPrimary.href = `/auditoria?from=diagnostico&eid=${encodeURIComponent(eid)}`;
    }

    const ctaWa = document.getElementById('quiz-cta-wa') as HTMLAnchorElement | null;
    if (ctaWa) {
      const arqText = result.arquetipo;
      const msg = result.leakMXN > 0
        ? `Hola Efer, mi diagnóstico arrojó fuga de ${formatMXN(result.leakMXN)}/mes — arquetipo: ${arqText}. Quiero`
        : `Hola Efer, hice el diagnóstico — arquetipo: ${arqText}. Quiero`;
      const utms = new URLSearchParams({
        utm_source: 'site',
        utm_medium: 'wa',
        utm_campaign: 'quiz',
        utm_content: 'quiz_result',
        utm_term: result.arquetipo.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
      }).toString();
      const text = encodeURIComponent(`${msg} [quiz/result]\n${utms}`);
      ctaWa.href = `https://wa.me/528110425674?text=${text}`;
    }
  }

  function generateEventId(): string {
    const c = window.crypto;
    if (c && typeof c.randomUUID === 'function') {
      return c.randomUUID().replace(/-/g, '').slice(0, 16);
    }
    return Math.random().toString(36).slice(2, 10) + Date.now().toString(36).slice(-6);
  }

  render();
</script>

