---
/**
 * /gracias-quiz — Confirmación post-quiz (Fase 16).
 * Recibe ?eid=<event_id> del quiz para dedup de Pixel `Lead`.
 * Dispara Google Ads conversion tag específico (env: PUBLIC_GOOGLE_ADS_LABEL_QUIZ).
 */
import Base from '../layouts/Base.astro';
import Section from '../components/ui/Section.astro';
import Heading from '../components/ui/Heading.astro';
import Body from '../components/ui/Body.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import ConversionTags from '../components/shared/ConversionTags.astro';
import { buildWaUrl } from '../lib/whatsapp-url';

const waUrl = buildWaUrl({
  source: 'quiz',
  content: 'gracias_quiz_cta_secondary',
  context: 'post_quiz',
  customMessage:
    'Hola Efer, acabo de terminar el diagnóstico de fuga de margen y quiero adelantar la conversación.',
});
---

<Base
  title="Diagnóstico recibido — NextSwift"
  description="Recibimos su diagnóstico de fuga de margen. Si su caso califica para el Acelerador, Efer le contactará dentro de 24 horas hábiles."
  noindex={true}
>
  <Section width="narrow" spacing="lg">
    <header class="gracias-hero">
      <Eyebrow tone="accent">Diagnóstico recibido</Eyebrow>
      <Heading as="h1" size="h1">
        Listo. Su diagnóstico está siendo procesado.
      </Heading>
      <Body size="lead" tone="muted">
        Recibirá un correo con su mapa de fugas y las 3 recomendaciones específicas
        para su restaurante en los próximos minutos. Si su fuga estimada califica
        para el Acelerador (ventas brutas ≥ $300k MXN/mes), Efer le escribirá por
        WhatsApp dentro de las próximas <strong>24 horas hábiles</strong> para
        validar el siguiente paso.
      </Body>
    </header>

    <div class="gracias-next">
      <p class="gracias-next__lede">Mientras tanto, vea cómo resolvimos casos similares:</p>
      <div class="gracias-next__ctas">
        <a href="/casos-de-exito" class="btn btn--primary btn--lg">
          Ver casos reales
        </a>
        <a href={waUrl} class="btn btn--ghost btn--lg" rel="noopener nofollow" target="_blank">
          Adelantar por WhatsApp
        </a>
      </div>
    </div>

    <div class="gracias-foot">
      <a href="/" class="gracias-foot__back">← Volver al inicio</a>
    </div>
  </Section>

  <ConversionTags type="quiz" />
</Base>

<style>
  .gracias-hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .gracias-next {
    margin-top: var(--space-7);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .gracias-next__lede {
    margin: 0;
    font-family: var(--font-subheading);
    color: var(--color-text-muted);
  }
  .gracias-next__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
  .gracias-foot {
    margin-top: var(--space-6);
    text-align: center;
  }
  .gracias-foot__back {
    color: var(--color-text-muted, #555);
  }
</style>
