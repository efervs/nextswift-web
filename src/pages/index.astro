---
import Base from '../layouts/Base.astro';
import Section from '../components/ui/Section.astro';
import Hero from '../components/home/Hero.astro';
import ProofBar from '../components/home/ProofBar.astro';
import GuideBlock from '../components/shared/GuideBlock.astro';
import ThreeStepPlan from '../components/shared/ThreeStepPlan.astro';
import Stakes from '../components/shared/Stakes.astro';
---

<Base>
  <Section spacing="lg" tone="surface">
    <Hero />
  </Section>

  <Section spacing="md" tone="alt">
    <ProofBar />
  </Section>

  <GuideBlock variant="home" />

  <Stakes variant="home" />

  <ThreeStepPlan variant="home" />

  <!-- TODO P8 OfertaResumen -->
</Base>
