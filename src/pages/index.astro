---
/**
 * Home (/) — orquestación principal.
 * Inyecta P14 (Fase 17 SocialProof + Fase 18 FAQ global).
 * ProofBar legacy (P4: métrica agregada + logos) → cubierto por <SocialProof variant="agregada"/> + variant="logos".
 * M16: ProofBar reescrito como barra de 3 PROMESAS operativas, anclada bajo el hero (entre Hero y SocialProof agregada).
 * P20: LocalBusiness + Service schema vía slot="head".
 *
 * M18 (TB-03/TB-06) — ritmo compositivo del home:
 *  - Momento ASIMÉTRICO: <OfertaResumen/> pasa de 3 cards idénticas a ancla (Financiera) +
 *    2 satélites → rompe la retícula de "N cards iguales" que se repetía sección a sección.
 *  - Prueba con FORMA PROPIA una sola vez: el dispositivo-firma <MarginLeak/> (hero + Stakes).
 *    El big-number repetido (Oswald hasta 2.5rem) se colapsa a texto de apoyo en <ProofBar/>
 *    y en <SocialProof variant="agregada"/> para no competir con la firma.
 *  - hover-lift reservado a cards NAVEGABLES (blog/casos): retirado de Stakes, Oferta y logos.
 *
 * V4-13 (anti card-soup) — doctrina de ritmo + elevación reservada:
 *  - RITMO por alternancia de SUPERFICIE, no por cajas: surface / surface-alt se turnan para
 *    separar secciones sin que cada una sea una card bordeada. Secuencia de fondos:
 *      Hero(surface) · logos(alt) · Stakes(ink-deep) · Plan(surface) · testimonios(surface)
 *      · Oferta(alt, FIRMA) · agregada(alt) · Garantías(surface, FIRMA) · FAQ(alt).
 *  - ELEVACIÓN RESERVADA a 2 momentos-firma (--elevation-signature): la oferta ancla y la
 *    garantía. Todo lo demás queda PLANO (superficies quietas + hairline). Tokens de ritmo
 *    (--rhythm-block/-lg/-within/-hairline, --elevation-signature/-flat) viven en tokens.css.
 */
import Base from '../layouts/Base.astro';
import Hero from '../components/home/Hero.astro';
import ProofBar from '../components/home/ProofBar.astro';
import SocialProof from '../components/shared/SocialProof.astro';
import ThreeStepPlan from '../components/shared/ThreeStepPlan.astro';
import Stakes from '../components/shared/Stakes.astro';
import OfertaResumen from '../components/home/OfertaResumen.astro';
import GarantiasResumen from '../components/shared/GarantiasResumen.astro';
import FAQ from '../components/shared/FAQ.astro';
import Section from '../components/ui/Section.astro';
import { buildLocalBusinessSchema, buildServiceSchema } from '../lib/seo';

const localBusinessSchema = buildLocalBusinessSchema();
const serviceSchema = buildServiceSchema({
  name: 'Acelerador 3 Palancas NextSwift',
  description:
    'Programa intensivo de implementación operativa en 10 días hábiles para restaurantes con ventas >= $300k MXN/mes. Tres palancas: financiera, operativa y comercial.',
  slug: 'acelerador',
});
---

<Base
  ogImage="https://www.nextswift.mx/images/og/home.png"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} />
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <Section spacing="lg" tone="surface">
    <Hero />
    <ProofBar />
    <SocialProof variant="agregada" tone="transparent" />
  </Section>

  <SocialProof variant="logos" tone="alt" />

  {/* V4-13: momento oscuro-firma (ink-deep). Ancla el arco de pérdida antes del plan. */}
  <Stakes variant="home" />

  {/* V4-13: superficie blanca quieta — el plan es SECUENCIA (timeline numerado), no cards.
      Plano (sin elevación); el respiro y la numeración dan la jerarquía. */}
  <ThreeStepPlan variant="home" />

  <SocialProof variant="testimonios" />

  {/* V4-13: MOMENTO-FIRMA #1 — la oferta ancla. Superficie papel (alt) + card ancla ELEVADA
      (--elevation-signature). Es de los 2 únicos bloques con sombra en el home. */}
  <OfertaResumen />

  {/* M11 (T1-05): prueba social pegada al CTA primario de la oferta. La cifra agregada real
      reaparece en la zona de conversión (no concentrada en una sola sección): testimonios
      arriba de la oferta + esta tira debajo flanquean el CTA /acelerador antes de la garantía. */}
  <SocialProof
    variant="agregada"
    tone="alt"
    contexto="cifras autorizadas por los dueños — la misma evidencia que documentamos en casos de éxito"
  />

  {/* M12: withCta={true} convierte GarantiasResumen en sección de cierre (garantía + CTA),
      repitiendo la llamada a la acción tras la lectura de las 4 garantías ancla.
      La garantía verbatim ya aparece junto al CTA primario del hero vía CTAs.astro.
      V4-13: MOMENTO-FIRMA #2 — la garantía. Superficie blanca + cards ELEVADAS
      (--elevation-signature). El otro único bloque con sombra del home. */}
  <GarantiasResumen tone="light" withCta={true} />

  <FAQ variant="global" tone="alt" />
</Base>
