# ============================================================
# NextSwift — Variables de entorno
# Copiar a .env.local para desarrollo local.
# Configurar en Cloudflare Pages → Settings → Env Variables.
# ============================================================

# HubSpot CRM Starter — token de API privado
HUBSPOT_TOKEN=

# Meta Conversions API — access token de conversiones
META_CAPI_TOKEN=

# Meta Pixel ID (ya público, pero centralizado aquí para CI)
META_PIXEL_ID=1545738293336210

# Cloudflare API token (para deploys programáticos si aplica)
CLOUDFLARE_API_TOKEN=

# ⚠️  NO agregar WHATSAPP_CLOUD_TOKEN — wa.me sin Cloud API (DH-06)
